cmd_statusline() {
    local agent="${1:-}" action="${2:-install}"

    case "$agent" in
        claude|claude-code|codex|openai)
            agent="$(_normalize_agent "$agent")" || return 1
            ;;
        install|show|-h|--help|help|"")
            action="${agent:-help}"
            if [[ "$action" != "help" && "$action" != "-h" && "$action" != "--help" ]]; then
                agent="$(_resolve_agent_or_prompt "" "Choose statusline target" "$(_active_profile)")" || return 1
            fi
            ;;
        *)
            echo -e "${RED}Unknown statusline target: $agent${RESET}" >&2
            echo "Usage: cctrl statusline <claude|codex> [install|show]" >&2
            return 1
            ;;
    esac

    case "$action" in
        install)
            if [[ "$agent" == "claude" ]]; then
                mkdir -p "$CLAUDE_DIR"
                [[ -f "$SETTINGS" ]] || echo "{}" > "$SETTINGS"
                local tmp status_cmd
                tmp="$(mktemp)"
                status_cmd="$SCRIPT_DIR/hooks/statusline.sh"
                jq --arg cmd "$status_cmd" '.statusLine = {type: "command", command: $cmd}' "$SETTINGS" > "$tmp" && mv "$tmp" "$SETTINGS"
                echo -e "${GREEN}Installed Claude statusline:${RESET} $status_cmd"
                return 0
            fi

            mkdir -p "$CODEX_DIR"
            local config="$CODEX_DIR/config.toml"
            [[ -f "$config" ]] || touch "$config"
            python3 - "$config" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
line = 'status_line = ["model-with-reasoning", "current-dir", "context-used", "git-branch", "run-state"]'
text = path.read_text() if path.exists() else ""
lines = text.splitlines()
out = []
found_tui = False
in_tui = False
set_line = False
current_table = ""

def append_tui_before_current_table():
    global set_line, found_tui
    if out and out[-1].strip():
        out.append("")
    out.extend(["[tui]", line, ""])
    found_tui = True
    set_line = True

for raw in lines:
    stripped = raw.strip()
    if stripped.startswith("[") and stripped.endswith("]"):
        if in_tui and not set_line:
            out.append(line)
            set_line = True
        if not found_tui and stripped.startswith("[tui."):
            append_tui_before_current_table()
        current_table = stripped
        in_tui = stripped == "[tui]"
        found_tui = found_tui or in_tui
        out.append(raw)
        continue
    if re.match(r"^status_line\s*=", stripped):
        if in_tui and not set_line:
            out.append(line)
            set_line = True
            continue
        # Top-level status_line is ignored by Codex TUI; remove it during migration.
        if current_table == "":
            continue
    out.append(raw)

if found_tui:
    if in_tui and not set_line:
        out.append(line)
else:
    if out and out[-1].strip():
        out.append("")
    out.extend(["[tui]", line])

path.write_text("\n".join(out).rstrip() + "\n")
PY
            echo -e "${GREEN}Installed Codex statusline:${RESET} $config"
            echo -e "${DIM}Restart Codex or run /statusline inside Codex to review it.${RESET}"
            ;;
        show)
            if [[ "$agent" == "claude" ]]; then
                if [[ -f "$SETTINGS" ]]; then
                    jq '.statusLine // "not configured"' "$SETTINGS"
                else
                    echo "not configured"
                fi
            else
                if [[ -f "$CODEX_DIR/config.toml" ]]; then
                    python3 - "$CODEX_DIR/config.toml" <<'PY'
import re
import sys
from pathlib import Path

lines = Path(sys.argv[1]).read_text().splitlines()
ignored_top_level = None
