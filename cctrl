}

_peer_codex_notify_references_hook() {
    local config="$1" hook_name="$2" hook_path="$3"
    [[ -f "$config" ]] || return 1
    grep -F "$hook_name" "$config" >/dev/null 2>&1 && return 0
    command -v python3 >/dev/null 2>&1 || return 1
    python3 - "$config" "$hook_name" "$hook_path" <<'PY'
import ast
import os
import re
import shutil
import sys

config_path, hook_name, hook_path = sys.argv[1:4]
notify = None
try:
    import tomllib
except Exception:
    tomllib = None

if tomllib is not None:
    try:
        with open(config_path, "rb") as fh:
            config = tomllib.load(fh)
        notify = config.get("notify")
    except Exception:
        sys.exit(1)
else:
    try:
        text = open(config_path, "r", encoding="utf-8").read()
    except OSError:
        sys.exit(1)
    for raw in text.splitlines():
        stripped = raw.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped.startswith("["):
            break
        match = re.match(r"notify\s*=\s*(.+)$", stripped)
        if not match:
            continue
        value = match.group(1).split("#", 1)[0].strip()
        try:
            notify = ast.literal_eval(value)
        except Exception:
            notify = value.strip("\"'")
        break

values = []
if isinstance(notify, str):
    values.append(notify)
elif isinstance(notify, list):
    values.extend(item for item in notify if isinstance(item, str))

config_dir = os.path.dirname(config_path)
needles = [hook_name.encode(), hook_path.encode()]
seen = set()

for value in values:
    expanded = os.path.expanduser(os.path.expandvars(value))
    paths = []
    if os.path.isabs(expanded):
        paths.append(expanded)
    else:
        found = shutil.which(expanded)
        if found:
            paths.append(found)
        paths.append(os.path.join(config_dir, expanded))

    for path in paths:
        if path in seen:
            continue
        seen.add(path)
        if not os.path.isfile(path):
            continue
        try:
            with open(path, "rb") as fh:
                content = fh.read(1024 * 1024)
        except OSError:
            continue
        if any(needle in content for needle in needles):
            sys.exit(0)

sys.exit(1)
PY
}

_peer_doorbell_registered() {
    local agent="${1:-}" config hook_name="peer-doorbell.sh" hook_path
    hook_path="$(_peer_doorbell_hook_path)"
    if [[ -z "$agent" || "$agent" == "claude" ]]; then
        for config in "$SETTINGS" "$HOME/.claude.json"; do
            [[ -f "$config" ]] || continue
            grep -F "$hook_name" "$config" >/dev/null 2>&1 && return 0
        done
    fi
    if [[ -z "$agent" || "$agent" == "codex" ]]; then
        config="$CODEX_DIR/config.toml"
        _peer_codex_notify_references_hook "$config" "$hook_name" "$hook_path" && return 0
    fi
    return 1
}

_peer_cmd_doctor() {
    local target="" json=false peers_doc messages peer_json checks="[]" check ok target_session target_agent="" hook_path
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)
                json=true; shift ;;
            -*)
                $json && _json_error "validation" "Unknown peer doctor flag: $1" || echo -e "${RED}Unknown peer doctor flag: $1${RESET}" >&2
                return 64 ;;
            *)
                if [[ -n "$target" ]]; then
                    $json && _json_error "validation" "Only one peer target is allowed" || echo -e "${RED}Only one peer target is allowed.${RESET}" >&2
                    return 64
                fi
                target="$1"; shift ;;
        esac
    done
    ok="$(command -v jq >/dev/null 2>&1 && echo true || echo false)"
    check="$(jq -n --arg name jq --argjson ok "$ok" '{name:$name,ok:$ok}')"
    checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    ok="$(command -v tmux >/dev/null 2>&1 && echo true || echo false)"
    check="$(jq -n --arg name tmux --argjson ok "$ok" '{name:$name,ok:$ok}')"
    checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    if messages="$(_mailbox_read_json 2>/dev/null)"; then ok=true; else ok=false; fi
    check="$(jq -n --arg name mailbox_parseable --argjson ok "$ok" --arg path "$MESSAGES_FILE" '{name:$name,ok:$ok,path:$path}')"
    checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    local lock_path="$(_mailbox_lock_path)" lock_stale=false lock_pid=""
    if [[ -d "$lock_path" && -f "$lock_path/pid" ]]; then
        lock_pid="$(cat "$lock_path/pid" 2>/dev/null || true)"
        _pid_alive "$lock_pid" || lock_stale=true
    fi
    check="$(jq -n --arg name stale_mailbox_lock --argjson ok "$(_peer_json_bool "$([[ "$lock_stale" != "true" ]] && echo true || echo false)")" --arg pid "$lock_pid" '{name:$name,ok:$ok,pid:($pid // "")}')"
    checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    hook_path="$(_peer_doorbell_hook_path)"
    ok="$([[ -f "$hook_path" ]] && echo true || echo false)"
    check="$(jq -n --arg name doorbell_hook_present --argjson ok "$ok" --arg path "$hook_path" '{name:$name,ok:$ok,path:$path}')"
    checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    ok="$([[ -x "$hook_path" ]] && echo true || echo false)"
    check="$(jq -n --arg name doorbell_hook_executable --argjson ok "$ok" --arg path "$hook_path" '{name:$name,ok:$ok,path:$path}')"
    checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    peers_doc="$(_peer_all_json)" || return 1
    if [[ -n "$target" ]]; then
        if ! peer_json="$(_peer_resolve_json "$target" 2>/dev/null)"; then
            check="$(jq -n --arg name peer_resolves --argjson ok false --arg target "$target" '{name:$name,ok:$ok,target:$target}')"
            checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
        else
            target="$(jq -r '.name' <<< "$peer_json")"
            target_agent="$(jq -r '.agent // empty' <<< "$peer_json")"
            check="$(jq -n --arg name peer_resolves --argjson ok true --arg target "$target" '{name:$name,ok:$ok,target:$target}')"
            checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
            if _peer_has_capability "$peer_json" "tmux"; then
                target_session="$(jq -r '.tmux_target // .session // empty' <<< "$peer_json")"
                if [[ -n "$target_session" ]] && command -v tmux >/dev/null 2>&1 && _tmux_run_with_timeout has-session -t "$target_session"; then ok=true; else ok=false; fi
                check="$(jq -n --arg name tmux_session_live --argjson ok "$ok" --arg session "$target_session" '{name:$name,ok:$ok,session:$session}')"
                checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
                if [[ "$ok" == "true" ]] && _tmux_run_with_timeout capture-pane -p -S -1 -t "$target_session"; then ok=true; else ok=false; fi
                check="$(jq -n --arg name pane_reachable --argjson ok "$ok" --arg session "$target_session" '{name:$name,ok:$ok,session:$session}')"
                checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
            fi
            ok="$(_peer_doctor_mcp_check "$target")"
            check="$(jq -n --arg name mcp_bridge --argjson ok "$ok" --arg peer "$target" '{name:$name,ok:$ok,peer:$peer}')"
            checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
        fi
    else
        check="$(jq -n --arg name peers_registered --argjson ok "$(jq -r '(.peers // []) | length > 0' <<< "$peers_doc")" '{name:$name,ok:$ok}')"
        checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    fi
    ok="$(_peer_doorbell_registered "$target_agent" && echo true || echo false)"
    check="$(jq -n --arg name doorbell_hook_registered --argjson ok "$ok" --arg agent "$target_agent" '{name:$name,ok:$ok,agent:(if $agent == "" then null else $agent end)}')"
    checks="$(jq --argjson c "$check" '. + [$c]' <<< "$checks")"
    if $json; then
        jq -n --arg target "$target" --argjson checks "$checks" '{ok: all($checks[]; .ok), target: ($target // ""), checks:$checks}'
    else
        jq -r '.[] | "\(.name): \(if .ok then "ok" else "FAIL" end)"' <<< "$checks"
    fi
}

