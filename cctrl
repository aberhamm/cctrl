                else
                    echo "not configured"
                fi
            fi
            ;;
        help|-h|--help)
            echo "Usage: cctrl statusline <claude|codex> [install|show]"
            echo ""
            echo "  claude install   Configure ~/.claude/settings.json statusLine command"
