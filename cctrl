#!/usr/bin/env bash
set -euo pipefail

# cctrl — Coding Agent Controller
# Manages settings profiles, tracks token usage locally, extensible via plugins.

# Resolve real path (works through symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"
PROFILES_DIR="$SCRIPT_DIR/profiles"
PLUGINS_DIR="$SCRIPT_DIR/plugins"
COSTS_DIR="$SCRIPT_DIR/costs"
SPENDING_LOG="$COSTS_DIR/spending.jsonl"
SHORTCUTS_FILE="$SCRIPT_DIR/data/shortcuts.json"
HOSTS_FILE="$SCRIPT_DIR/data/hosts.json"
CONFIG_FILE="$SCRIPT_DIR/data/config.json"
_peer_refresh_paths() {
    PEER_DATA_DIR="${CCTRL_DATA_DIR:-$SCRIPT_DIR/data}"
    PEERS_FILE="$PEER_DATA_DIR/peers.json"
    MESSAGES_FILE="$PEER_DATA_DIR/messages.jsonl"
}
_peer_refresh_paths
_session_refresh_paths() {
    SESSION_METADATA_DIR="${CCTRL_SESSION_METADATA_DIR:-$SCRIPT_DIR/data/sessions}"
}
_session_refresh_paths

CLAUDE_DIR="$HOME/.claude"
SETTINGS="$CLAUDE_DIR/settings.json"
PROJECTS_DIR="$CLAUDE_DIR/projects"
ACTIVE_FILE="$SCRIPT_DIR/.active-profile"
CODEX_DIR="${CODEX_HOME:-$HOME/.codex}"
CODEX_SESSIONS_DIR="$CODEX_DIR/sessions"
# Claude Code writes one <pid>.json per live session here; bridgeSessionId in
# that file is the authoritative remote-control liveness signal (null = not
# bridged). Honors CLAUDE_CONFIG_DIR; CCTRL_CLAUDE_SESSIONS_DIR overrides (tests).
CLAUDE_SESSIONS_DIR="${CCTRL_CLAUDE_SESSIONS_DIR:-${CLAUDE_CONFIG_DIR:-$CLAUDE_DIR}/sessions}"
CODEX_ARCHIVED_SESSIONS_DIR="$CODEX_DIR/archived_sessions"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

_active_profile() {
    if [[ -f "$ACTIVE_FILE" ]]; then
        cat "$ACTIVE_FILE"
    else
        echo "personal"
    fi
}

_profile_path() {
    echo "$PROFILES_DIR/${1}.json"
}

_profile_exists() {
    [[ -f "$(_profile_path "$1")" ]]
}

_supported_agents() {
    printf '%s\n' claude codex
}

_supported_agents_display() {
    local agent joined=""
    while IFS= read -r agent; do
        [[ -n "$joined" ]] && joined+=", "
        joined+="$agent"
    done < <(_supported_agents)
    printf '%s' "$joined"
}

_normalize_agent() {
    local agent
    agent="$(printf '%s' "${1:-claude}" | tr '[:upper:]' '[:lower:]')"
    case "$agent" in
        claude|claude-code) printf 'claude' ;;
        codex|openai) printf 'codex' ;;
        *)
            echo -e "${RED}Unknown agent: $1${RESET}" >&2
            echo -e "${DIM}Supported agents: $(_supported_agents_display)${RESET}" >&2
            return 1
            ;;
    esac
}

_config_default_agent() {
    [[ -f "$CONFIG_FILE" ]] || return 1
    command -v jq >/dev/null 2>&1 || return 1

    local configured
    configured="$(jq -r '.defaultAgent // .default_agent // empty' "$CONFIG_FILE" 2>/dev/null || true)"
    [[ -n "$configured" ]] || return 1

    case "$(printf '%s' "$configured" | tr '[:upper:]' '[:lower:]')" in
        claude|claude-code) printf 'claude' ;;
        codex|openai)       printf 'codex' ;;
        *)                  return 1 ;;
    esac
}

_configured_default_agent() {
    if [[ -n "${CCTRL_AGENT:-}" ]]; then
        _normalize_agent "$CCTRL_AGENT"
        return
    fi

    _config_default_agent
}

_default_agent() {
    _configured_default_agent
}

_default_agent_label() {
    local agent pref active
    active="$(_active_profile)"
    if pref="$(_profile_agent_preference "$active" 2>/dev/null)"; then
        if [[ "$pref" == "prompt" ]]; then
            printf 'prompt (profile %s)' "$active"
        else
            printf '%s (profile %s)' "$pref" "$active"
        fi
        return
    fi

    if agent="$(_configured_default_agent 2>/dev/null)"; then
        printf '%s' "$agent"
    else
        printf 'none configured'
    fi
}

_profile_agent_preference() {
    local profile="$1" pf value
    [[ -n "$profile" ]] || return 1
    _profile_exists "$profile" || return 1
    command -v jq >/dev/null 2>&1 || return 1

    pf="$(_profile_path "$profile")"
    value="$(jq -r '
        if has("defaultAgent") then
            if .defaultAgent == null then "__cctrl_prompt__" else (.defaultAgent | tostring) end
        elif has("default_agent") then
            if .default_agent == null then "__cctrl_prompt__" else (.default_agent | tostring) end
        else
            "__cctrl_missing__"
        end
    ' "$pf" 2>/dev/null || true)"

    case "$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')" in
        ""|__cctrl_missing__)
            return 1
            ;;
        __cctrl_prompt__|prompt|ask|choose|none|null|false)
            printf 'prompt'
            ;;
        *)
            _normalize_agent "$value"
            ;;
    esac
}

_prompt_agent_choice() {
    local prompt="${1:-Choose agent runtime}" answer agent normalized i
    local -a agents=()

    while IFS= read -r agent; do
        agents+=("$agent")
    done < <(_supported_agents)

    if ! _prompt_tty_available; then
        echo -e "${RED}No agent selected and prompting is unavailable.${RESET}" >&2
        echo -e "${DIM}Pass --agent <agent> ($(_supported_agents_display)) or set defaultAgent in ${CONFIG_FILE/#$HOME/~}.${RESET}" >&2
        return 1
    fi

    while true; do
        printf '%s:\n' "$prompt" > /dev/tty
        i=1
        for agent in "${agents[@]}"; do
            printf '  %d) %s\n' "$i" "$agent" > /dev/tty
            ((i++))
        done
        printf '> ' > /dev/tty
        IFS= read -r answer < /dev/tty || answer=""

        if [[ "$answer" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= ${#agents[@]} )); then
            printf '%s' "${agents[$((answer - 1))]}"
            return 0
        fi

        if [[ -n "$answer" ]] && normalized="$(_normalize_agent "$answer" 2>/dev/null)"; then
            printf '%s' "$normalized"
            return 0
        fi

        printf 'Please choose one of: %s\n' "$(_supported_agents_display)" > /dev/tty
    done
}

_resolve_agent_or_prompt() {
    local selected="${1:-}" prompt="${2:-Choose agent runtime}" profile="${3:-}" configured pref
    if [[ -n "$selected" ]]; then
        _normalize_agent "$selected"
        return
    fi

    if [[ -n "${CCTRL_AGENT:-}" ]]; then
        _normalize_agent "$CCTRL_AGENT"
        return
    fi

    if pref="$(_profile_agent_preference "$profile" 2>/dev/null)"; then
        if [[ "$pref" == "prompt" ]]; then
            _prompt_agent_choice "$prompt"
        else
            printf '%s' "$pref"
        fi
        return
    fi

    if configured="$(_config_default_agent)"; then
        printf '%s' "$configured"
        return
    fi

    _prompt_agent_choice "$prompt"
}

_agent_bin() {
    case "$1" in
        codex) printf 'codex' ;;
        *)     printf 'claude' ;;
    esac
}

_profile_model_for_agent() {
    local agent="$1" pf="$2" model
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0

    model="$(jq -r --arg agent "$agent" '
        (.agents[$agent].model // .model // empty)
    ' "$pf" 2>/dev/null)"
    [[ -n "$model" ]] || return 0

    # Existing profiles are Claude-oriented. Avoid accidentally passing a Claude
    # model alias such as "sonnet" into Codex when the active default is reused.
    if [[ "$agent" == "codex" ]]; then
        case "$(printf '%s' "$model" | tr '[:upper:]' '[:lower:]')" in
            *claude*|*sonnet*|*opus*|*haiku*|anthropic/*) return 0 ;;
        esac
    fi
    printf '%s' "$model"
}

_profile_args_for_agent() {
    local agent="$1" pf="$2"
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0
    jq -r --arg agent "$agent" '
        (.agents[$agent].args // [])
        | if type == "array" then .[] else empty end
        | tostring
    ' "$pf" 2>/dev/null
}

_profile_env_entries_for_agent() {
    local agent="$1" pf="$2"
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0
    jq -r --arg agent "$agent" '
        (has("agents")) as $has_agents
        | (
            if $has_agents then
                ((.env // {}) + (.agents[$agent].env // {}))
            elif $agent == "claude" then
                (.env // {})
            else
                {}
            end
          )
        | to_entries[]
        | "\(.key)\t\(.value|tostring|@base64)"
    ' "$pf" 2>/dev/null
}

# Export a profile's shared env plus agent-specific env into the current process
# so the selected agent inherits it. Legacy profiles with no `agents` block keep
# applying their top-level env to Claude only.
_apply_profile_overlay() {
    local agent="${1:-claude}" pf="${2:-}"
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0
    local key valb64 val
    while IFS=$'\t' read -r key valb64; do
        [[ -n "$key" ]] || continue
        # base64 -d (GNU/newer macOS) with -D fallback (older BSD/macOS).
        val="$(printf '%s' "$valb64" | base64 -d 2>/dev/null || printf '%s' "$valb64" | base64 -D 2>/dev/null)"
        export "$key=$val"
    done < <(_profile_env_entries_for_agent "$agent" "$pf")
}

# Resolve the launch model. Precedence: explicit CLI --model > profile model >
# empty (omit --model entirely and let the selected agent use its own default).
#   $1 = agent, $2 = cli_model (may be empty), $3 = profile_file (may be empty)
_resolve_model() {
    local agent="${1:-claude}" cli="${2:-}" pf="${3:-}"
    if [[ -n "$cli" ]]; then printf '%s' "$cli"; return; fi
    _profile_model_for_agent "$agent" "$pf"
}

_profile_overlay_json_for_agent() {
    local agent="$1" pf="$2"
    [[ -n "$pf" && -f "$pf" ]] || { echo '{"model":null,"env":{}}'; return 0; }
    command -v jq >/dev/null 2>&1 || { echo '{"model":null,"env":{}}'; return 0; }
    jq --arg agent "$agent" '
        if has("agents") then
            {
                model: (.agents[$agent].model // null),
                env: ((.env // {}) + (.agents[$agent].env // {}))
            }
        elif $agent == "claude" then
            {model: (.model // null), env: (.env // {})}
        else
            {model: null, env: {}}
        end
    ' "$pf" 2>/dev/null
}

_profile_summary() {
    local pf="$1"
    command -v jq >/dev/null 2>&1 || { printf 'model=unknown'; return; }
    jq -r '
        def model_for($a):
            if has("agents") then
                (.agents[$a].env.ANTHROPIC_MODEL // .agents[$a].model // empty)
            elif $a == "claude" then
                (.env.ANTHROPIC_MODEL // .model // empty)
            else
                empty
            end;
        def provider_for($a):
            if has("agents") then
                if (.agents[$a].env.CLAUDE_CODE_USE_BEDROCK // false) then "bedrock" else "direct" end
            elif $a == "claude" then
                if (.env.CLAUDE_CODE_USE_BEDROCK // false) then "bedrock" else "direct" end
            else
                "direct"
            end;
        [
            (model_for("claude") as $m | if $m != "" then "claude=\($m) via=\(provider_for("claude"))" else empty end),
            (model_for("codex") as $m | if $m != "" then "codex=\($m)" else empty end)
        ] | if length > 0 then join("  ") else "model=default" end
    ' "$pf" 2>/dev/null
}

_launch_apply_profile_args() {
    local agent="$1" pf="$2" parg
    while IFS= read -r parg; do
        [[ -n "$parg" ]] && LAUNCH_PROFILE_ARGS+=("$parg")
    done < <(_profile_args_for_agent "$agent" "$pf")

    if [[ ${#LAUNCH_PROFILE_ARGS[@]} -eq 0 ]]; then
        return 0
    fi

    local i=0 next
    while (( i < ${#LAUNCH_PROFILE_ARGS[@]} )); do
        parg="${LAUNCH_PROFILE_ARGS[$i]}"
        case "$parg" in
            --yolo|--dangerously-bypass-approvals-and-sandbox)
                LAUNCH_FULL_BYPASS=true
                LAUNCH_ACCESS_EXPLICIT=true
                ((i++))
                ;;
            --permission-mode)
                if (( i + 1 >= ${#LAUNCH_PROFILE_ARGS[@]} )); then
                    echo -e "${RED}Profile arg --permission-mode needs a value${RESET}" >&2
                    return 1
                fi
                next="${LAUNCH_PROFILE_ARGS[$((i + 1))]}"
                LAUNCH_PERMISSION_MODE="$next"
                LAUNCH_ACCESS_EXPLICIT=true
                ((i+=2))
                ;;
            --sandbox|-s|--ask-for-approval|-a)
                if (( i + 1 >= ${#LAUNCH_PROFILE_ARGS[@]} )); then
                    echo -e "${RED}Profile arg $parg needs a value${RESET}" >&2
                    return 1
                fi
                next="${LAUNCH_PROFILE_ARGS[$((i + 1))]}"
                LAUNCH_ACCESS_EXPLICIT=true
                LAUNCH_FLAGS+=("$parg" "$next")
                ((i+=2))
                ;;
            --remote|--remote-auth-token-env)
                if (( i + 1 >= ${#LAUNCH_PROFILE_ARGS[@]} )); then
                    echo -e "${RED}Profile arg $parg needs a value${RESET}" >&2
                    return 1
                fi
                next="${LAUNCH_PROFILE_ARGS[$((i + 1))]}"
                LAUNCH_FLAGS+=("$parg" "$next")
                ((i+=2))
                ;;
            *)
                LAUNCH_FLAGS+=("$parg")
                ((i++))
                ;;
        esac
    done
}

_launch_exec_agent() {
    local agent="$1" pf="$2" cli_model="$3" launch_name="$4" no_bridge="$5"
    local resume="$6" resume_val="$7" final_prompt="$8" bridge_dir="${9:-$PWD}"

    export CCTRL_AGENT="$agent"
    if [[ "${CCTRL_SESSION_KIND:-}" != "tmux" ]]; then
        export CCTRL_SESSION_KIND="foreground"
        unset CCTRL_SESSION_NAME CCTRL_SESSION_TARGET CCTRL_SESSION_PURPOSE
    fi

    LAUNCH_FLAGS=()
    LAUNCH_PROFILE_ARGS=()
    _launch_apply_profile_args "$agent" "$pf" || return 1

    local mdl
    mdl="$(_resolve_model "$agent" "$cli_model" "$pf")"
    [[ -n "$mdl" ]] && LAUNCH_FLAGS+=("--model" "$mdl")

    if [[ "$agent" == "claude" ]]; then
        if $LAUNCH_FULL_BYPASS; then
            LAUNCH_PERMISSION_MODE="bypassPermissions"
        fi
        if [[ ${#LAUNCH_FLAGS[@]} -gt 0 ]]; then
            LAUNCH_FLAGS=("--permission-mode" "${LAUNCH_PERMISSION_MODE:-bypassPermissions}" "${LAUNCH_FLAGS[@]}")
        else
            LAUNCH_FLAGS=("--permission-mode" "${LAUNCH_PERMISSION_MODE:-bypassPermissions}")
        fi
        [[ -n "$launch_name" ]] && LAUNCH_FLAGS+=("--name" "$launch_name")
        if [[ "$no_bridge" != "true" ]]; then
            # Bridge name reconciliation: when an explicit session name is set
            # (detached/tmux-managed launches always pass --name), derive the
            # remote-control prefix from that exact name so the Claude Code app
            # session lines up with the tmux session name and disambiguates
            # same-repo sessions (homelab--3 vs --4). Only fall back to the
            # cwd-derived slug for nameless foreground launches.
            local rc_prefix
            if [[ -n "$launch_name" ]]; then
                rc_prefix="${launch_name}-"
            else
                rc_prefix="$(_remote_prefix "$bridge_dir")"
            fi
            LAUNCH_FLAGS+=("--remote-control" "--remote-control-session-name-prefix" "$rc_prefix")
        fi

        if [[ "$resume" == "true" ]]; then
            if [[ -n "$resume_val" ]]; then
                LAUNCH_FLAGS+=("--resume" "$resume_val")
            else
                LAUNCH_FLAGS+=("--resume")
            fi
        fi
        [[ ${#LAUNCH_PASSTHROUGH[@]} -gt 0 ]] && LAUNCH_FLAGS+=("${LAUNCH_PASSTHROUGH[@]}")
        [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("$final_prompt")

        echo -e "${DIM}claude ${LAUNCH_FLAGS[*]}${RESET}"
        exec claude "${LAUNCH_FLAGS[@]}"
    fi

    if [[ -n "$LAUNCH_PERMISSION_MODE" && "$LAUNCH_PERMISSION_MODE" != "bypassPermissions" ]]; then
        echo -e "${RED}Codex can only translate --permission-mode bypassPermissions.${RESET}" >&2
        echo -e "${DIM}Use Codex-native flags like --sandbox and --ask-for-approval for other modes.${RESET}" >&2
        return 1
    fi

    [[ "$LAUNCH_PERMISSION_MODE" == "bypassPermissions" ]] && LAUNCH_FULL_BYPASS=true
    if $LAUNCH_FULL_BYPASS || ! $LAUNCH_ACCESS_EXPLICIT; then
        if [[ ${#LAUNCH_FLAGS[@]} -gt 0 ]]; then
            LAUNCH_FLAGS=("--yolo" "${LAUNCH_FLAGS[@]}")
        else
            LAUNCH_FLAGS=("--yolo")
        fi
    fi
    [[ ${#LAUNCH_PASSTHROUGH[@]} -gt 0 ]] && LAUNCH_FLAGS+=("${LAUNCH_PASSTHROUGH[@]}")

    if [[ "$resume" == "true" ]]; then
        if [[ -n "$resume_val" ]]; then
            [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("$resume_val" "$final_prompt") || LAUNCH_FLAGS+=("$resume_val")
        else
            [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("--last" "$final_prompt")
        fi
        echo -e "${DIM}codex resume ${LAUNCH_FLAGS[*]}${RESET}"
        exec codex resume "${LAUNCH_FLAGS[@]}"
    fi

    [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("$final_prompt")
    echo -e "${DIM}codex ${LAUNCH_FLAGS[*]}${RESET}"
    exec codex "${LAUNCH_FLAGS[@]}"
}

_log_event() {
    mkdir -p "$COSTS_DIR"
    local json="$1"
    echo "$json" >> "$SPENDING_LOG"
}

_log_switch() {
    _log_event "$(printf '{"ts":"%s","event":"switch","from":"%s","to":"%s"}' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$1" "$2")"
}

_slugify() {
    local value="${1:-}"
    value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g')"
    printf '%s' "$value"
}

_target_slug() {
    local input="${1:-$PWD}"
    local name
    if [[ -d "$input" ]]; then
        local root
        root="$(git -C "$input" rev-parse --show-toplevel 2>/dev/null || echo "$input")"
        name="$(basename "$root")"
    else
        name="$input"
    fi
    name="$(_slugify "$name")"
    [[ -z "$name" ]] && name="agent"
    printf '%s' "$name"
}


_device_tag() {
    # Explicit remote host aliases win. For direct local launches, recognize the
    # two personal machines so tmux session names stay machine-scoped.
    local tag host
    if [[ -n "${CCTRL_HOST_PREFIX:-}" ]]; then
        tag="$(_slugify "$CCTRL_HOST_PREFIX")"
        [[ -n "$tag" ]] && printf '%s' "$tag"
        return 0
    fi

    if [[ -n "${CCTRL_DEVICE_TAG:-}" ]]; then
        tag="$(_slugify "$CCTRL_DEVICE_TAG")"
        [[ -n "$tag" ]] && printf '%s' "$tag"
        return 0
    fi

    host="$(hostname 2>/dev/null || true)"
    host="$(printf '%s' "${host%.local}" | tr '[:upper:]' '[:lower:]')"
    case "$host" in
        ms-*|ms) printf 'ms' ;;
        mattbook-pro|macbook-pro|mbp|mbp-*) printf 'mbp' ;;
    esac
}

_context_slug() {
    # Canonical context names use stable segments:
    #   <device>--<target>           for foreground agent/bridge names
    #   TMUX--<device>--<target>     for detached tmux-backed agent names
    # The device segment comes from --host aliases, CCTRL_DEVICE_TAG, or known
    # local hostnames. Unknown hosts keep the historic untagged names.
    local include_tmux="${1:-false}" input="${2:-$PWD}"
    local name device out=""
    name="$(_target_slug "$input")"
    if [[ "$include_tmux" == "true" ]]; then
        out="TMUX"
    fi
    device="$(_device_tag)"
    if [[ -n "$device" ]]; then
        [[ -n "$out" ]] && out+="--"
        out+="$device"
    fi
    [[ -n "$out" ]] && out+="--"
    out+="$name"
    printf '%s' "${out:-agent}"
}

_session_slug() {
    # Host-aware slug used for non-tmux remote-control names.
    _context_slug false "${1:-$PWD}"
}

_tmux_session_slug() {
    # Tmux-managed sessions include an explicit TMUX segment so they stand out
    # in tmux lists, Claude Code display names, and bridge session names.
    _context_slug true "${1:-$PWD}"
}

_remote_prefix() {
    # Claude adds "-<generated-name>" after this prefix. A single trailing dash
    # yields final bridge names like TMUX--ms--cctrl--brisk-river.
    if [[ "${CCTRL_TMUX_CONTEXT:-}" == "1" ]]; then
        printf '%s-' "$(_tmux_session_slug "${1:-$PWD}")"
    else
        printf '%s-' "$(_session_slug "${1:-$PWD}")"
    fi
}

_detect_active() {
    # Profiles are overlays (model + env), not full settings snapshots, so a
    # whole-file match against the intentionally-richer global settings.json is
    # no longer meaningful. The active profile is whatever `cctrl use` recorded.
    if [[ -f "$ACTIVE_FILE" ]]; then
        cat "$ACTIVE_FILE"
    else
        echo "none"
    fi
}

# ── Commands ──────────────────────────────────────────────────────────

cmd_use() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl use <profile>${RESET}"
        echo "Available profiles:"
        cmd_ls
        return 1
    fi

    if ! _profile_exists "$name"; then
        echo -e "${RED}Profile '$name' not found.${RESET}"
        echo "Available profiles:"
        cmd_ls
        return 1
    fi

    local prev
    prev="$(_active_profile)"

    if [[ "$prev" == "$name" ]]; then
        echo -e "${DIM}Already on profile: ${BOLD}$name${RESET}"
        return 0
    fi

    # Overlay the profile's Claude model + env onto the existing global settings.json
    # (non-destructive: hooks, permissions, mcpServers, etc. are preserved).
    # Note: env is merged, so switching profiles cannot UNSET a key a prior
    # profile added. For clean per-session auth, prefer `cctrl start --profile`.
    local pf tmp
    pf="$(_profile_path "$name")"
    tmp="$(mktemp)"
    if [[ -f "$SETTINGS" ]]; then
        jq -s '.[0] as $g | .[1] as $p
               | $g + {model: ($p.model // $g.model),
                       env: (($g.env // {}) + ($p.env // {}))}' \
            "$SETTINGS" <(_profile_overlay_json_for_agent claude "$pf") > "$tmp"
    else
        mkdir -p "$(dirname "$SETTINGS")"
        _profile_overlay_json_for_agent claude "$pf" | jq '{model, env}' > "$tmp"
    fi
    if [[ -s "$tmp" ]]; then
        mv "$tmp" "$SETTINGS"
    else
        rm -f "$tmp"
        echo -e "${RED}Failed to merge profile into settings.${RESET}"; return 1
    fi
    echo "$name" > "$ACTIVE_FILE"
    _log_switch "$prev" "$name"

    echo -e "${GREEN}Switched to profile: ${BOLD}$name${RESET}"
    echo -e "${DIM}Default CCTRL profile is now '$name'.${RESET}"
    echo -e "${DIM}Merged Claude model + env into $SETTINGS for Claude Code compatibility.${RESET}"
    echo -e "${YELLOW}Prefer per-session launches with: cctrl start --profile $name${RESET}"
}

cmd_ls() {
    local active
    active="$(_detect_active)"

    if [[ ! -d "$PROFILES_DIR" ]] || [[ -z "$(ls "$PROFILES_DIR"/*.json 2>/dev/null)" ]]; then
        echo -e "${DIM}No profiles found. Use 'cctrl save <name>' to create one.${RESET}"
        return
    fi

    for f in "$PROFILES_DIR"/*.json; do
        local name
        name="$(basename "$f" .json)"
        local summary
        summary="$(_profile_summary "$f")"

        if [[ "$name" == "$active" ]]; then
            echo -e "  ${GREEN}* ${BOLD}$name${RESET}  ${DIM}$summary${RESET}"
        else
            echo -e "    $name  ${DIM}$summary${RESET}"
        fi
    done
}

cmd_current() {
    local active
    active="$(_detect_active)"
    echo -e "${BOLD}$active${RESET}"

    if _profile_exists "$active"; then
        local pf summary
        pf="$(_profile_path "$active")"
        summary="$(_profile_summary "$pf")"
        echo -e "${DIM}$summary${RESET}"

        if [[ -f "$SETTINGS" ]]; then
            local sub='{model: (.model // null), env: (.env // {})}'
            if ! diff -q <(jq -S "$sub" "$SETTINGS" 2>/dev/null) <(_profile_overlay_json_for_agent claude "$pf" | jq -S "$sub" 2>/dev/null) &>/dev/null; then
                echo -e "${YELLOW}Note: live Claude model/env differ from profile '${active}'${RESET}"
            fi
        fi
    fi
}

cmd_save() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl save <name>${RESET}"
        return 1
    fi

    if [[ ! -f "$SETTINGS" ]]; then
        echo -e "${RED}No settings.json found at $SETTINGS${RESET}"
        return 1
    fi

    if _profile_exists "$name"; then
        echo -en "${YELLOW}Profile '$name' already exists. Overwrite? [y/N] ${RESET}"
        read -r confirm
        [[ "$confirm" =~ ^[yY]$ ]] || return 1
    fi

    # Capture only the overlay-relevant Claude keys, not the whole
    # settings.json — profiles are auth/model overlays, not full snapshots.
    jq '{agents: {claude: {model: (.model // null), env: (.env // {})}}}' "$SETTINGS" > "$(_profile_path "$name")"
    echo "$name" > "$ACTIVE_FILE"
    echo -e "${GREEN}Saved current Claude model + env as profile: ${BOLD}$name${RESET}"
}

cmd_diff() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl diff <profile>${RESET}"
        return 1
    fi

    if ! _profile_exists "$name"; then
        echo -e "${RED}Profile '$name' not found.${RESET}"
        return 1
    fi

    # Compare only the Claude overlay subset (model + env); global settings.json
    # carries hooks/permissions/mcpServers a profile intentionally does not.
    local sub='{model: (.model // null), env: (.env // {})}'
    if command -v delta &>/dev/null; then
        delta <(jq -S "$sub" "$SETTINGS" 2>/dev/null) <(_profile_overlay_json_for_agent claude "$(_profile_path "$name")" | jq -S "$sub" 2>/dev/null) || true
    else
        diff --color=auto <(jq -S "$sub" "$SETTINGS" 2>/dev/null) <(_profile_overlay_json_for_agent claude "$(_profile_path "$name")" | jq -S "$sub" 2>/dev/null) || true
    fi
}

cmd_edit() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl edit <profile>${RESET}"
        return 1
    fi

    if ! _profile_exists "$name"; then
        echo -e "${RED}Profile '$name' not found.${RESET}"
        return 1
    fi

    "${EDITOR:-vim}" "$(_profile_path "$name")"
}

cmd_costs() {
    local range="${1:---month}"
    local project_filter="${2:-}"

    local num_periods
    case "$range" in
        --today|--current)  num_periods=1 ;;
        --week)             num_periods=1 ;;
        --month)            num_periods=4 ;;
        --all)              num_periods=9999 ;;
        *)                  num_periods=4 ;;
    esac

    python3 "$SCRIPT_DIR/lib/usage_costs.py" costs \
        "$PROJECTS_DIR" \
        "$CODEX_SESSIONS_DIR" \
        "$CODEX_ARCHIVED_SESSIONS_DIR" \
        "$num_periods" \
        "$project_filter" \
        "$SPENDING_LOG"
}

cmd_log() {
    if [[ ! -f "$SPENDING_LOG" ]]; then
        echo -e "${DIM}No spending log yet.${RESET}"
        return
    fi

    local count="${1:-20}"
    echo -e "${BOLD}Spending Log${RESET} ${DIM}(last $count entries)${RESET}"
    echo ""
    tail -"$count" "$SPENDING_LOG" | while IFS= read -r line; do
        local ts event
        ts="$(echo "$line" | jq -r '.ts' 2>/dev/null)"
        event="$(echo "$line" | jq -r '.event' 2>/dev/null)"
        case "$event" in
            switch)
                local from to
                from="$(echo "$line" | jq -r '.from' 2>/dev/null)"
                to="$(echo "$line" | jq -r '.to' 2>/dev/null)"
                echo -e "  ${DIM}$ts${RESET}  ${BLUE}switch${RESET}  $from -> ${BOLD}$to${RESET}"
                ;;
            session_end|session_update)
                local profile in_tok out_tok models
                profile="$(echo "$line" | jq -r '.profile' 2>/dev/null)"
                in_tok="$(echo "$line" | jq -r '.input_tokens' 2>/dev/null)"
                out_tok="$(echo "$line" | jq -r '.output_tokens' 2>/dev/null)"
                models="$(echo "$line" | jq -r '.models | keys | join(", ")' 2>/dev/null)"
                printf "  ${DIM}%s${RESET}  ${GREEN}session${RESET}  profile=${BOLD}%s${RESET}  in=%s  out=%s  ${DIM}[%s]${RESET}\n" \
                    "$ts" "$profile" "$in_tok" "$out_tok" "$models"
                ;;
            *)
                echo -e "  ${DIM}$ts${RESET}  $event  $(echo "$line" | jq -c 'del(.ts,.event)' 2>/dev/null)"
                ;;
        esac
    done
}

cmd_rename() {
    local old="${1:-}" new="${2:-}"
    if [[ -z "$old" || -z "$new" ]]; then
        echo -e "${RED}Usage: cctrl rename <old> <new>${RESET}"
        return 1
    fi

    if _profile_exists "$old"; then
        if _profile_exists "$new"; then
            echo -e "${RED}Profile '$new' already exists.${RESET}"
            return 1
        fi
        mv "$(_profile_path "$old")" "$(_profile_path "$new")"
        # Update active profile tracking if needed
        if [[ "$(_active_profile)" == "$old" ]]; then
            echo "$new" > "$ACTIVE_FILE"
        fi
    else
        echo -e "${YELLOW}Profile '$old' not found on disk; updating log references only.${RESET}"
    fi

    # Update spending log entries that reference the old profile name
    if [[ -f "$SPENDING_LOG" ]]; then
        local tmp
        tmp="$(mktemp)"
        python3 -c "
import json, sys
old, new = $(printf '%s' "$old" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))'), $(printf '%s' "$new" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')
with open('$SPENDING_LOG') as f:
    lines = f.readlines()
out = []
for line in lines:
    line = line.rstrip('\n')
    if not line:
        continue
    try:
        e = json.loads(line)
        if e.get('from') == old: e['from'] = new
        if e.get('to') == old: e['to'] = new
        if e.get('profile') == old: e['profile'] = new
        out.append(json.dumps(e))
    except Exception:
        out.append(line)
with open('$SPENDING_LOG', 'w') as f:
    f.write('\n'.join(out) + '\n')
"
        echo -e "${DIM}Updated spending log: '$old' -> '$new'${RESET}"
    fi

    echo -e "${GREEN}Renamed: ${BOLD}$old${RESET}${GREEN} -> ${BOLD}$new${RESET}"
}

_start_args_have_explicit_target() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --)
                return 1
                ;;
            -d|--detach|--foreground|--no-tmux|--tmux|--yolo|--dangerously-bypass-approvals-and-sandbox|--no-bridge)
                shift
                ;;
            --agent|--profile|--model|--permission-mode|--sandbox|-s|--ask-for-approval|-a|--remote|--remote-auth-token-env|--name|-n|--peer|--purpose|--message|--prompt|-m)
                [[ $# -ge 2 ]] || return 1
                shift 2
                ;;
            --resume|-r)
                shift
                if [[ $# -gt 0 && "$1" != -* && "$1" != @* ]]; then
                    shift
                fi
                ;;
            @*)
                return 0
                ;;
            -*)
                return 1
                ;;
            *)
                local candidate="$1"
                candidate="${candidate/#\~/$HOME}"
                [[ -d "$candidate" ]] && return 0
                shift
                ;;
        esac
    done
    return 1
}

cmd_start() {
    # Unified launch verb. Interactive starts are tmux-backed by default so
    # local and remote sessions are durable and addressable. Use
    # --foreground/--no-tmux for one-off direct launches.
    #   cctrl start                 tmux-backed, current dir
    #   cctrl start @name           tmux-backed via shortcut
    #   cctrl start --foreground    direct foreground, current dir
    #   cctrl start -d <dir|@name>  detached tmux session, do not auto-attach
    local detach=false arg
    local foreground=false
    [[ "${CCTRL_TMUX_CONTEXT:-}" == "1" ]] && foreground=true
    for arg in "$@"; do
        [[ "$arg" == "--" ]] && break   # rest is a literal prompt; stop scanning
        case "$arg" in
            -d|--detach) detach=true; break ;;
            --foreground|--no-tmux) foreground=true ;;
        esac
    done

    if $detach; then
        _launch_detached "$@"
        return
    fi

    if ! $foreground; then
        if _start_args_have_explicit_target "$@"; then
            CCTRL_ATTACH_AFTER_START=1 _launch_detached "$@"
        else
            CCTRL_ATTACH_AFTER_START=1 _launch_detached "$PWD" "$@"
        fi
        return
    fi

    # `cctrl start @<name> [...]` is an alias for `cctrl @<name> [...]`
    if [[ "${1:-}" == @* ]]; then
        local sc="${1#@}"; shift
        _shortcut_jump "$sc" "$@"
        return
    fi

    local resume=false
    local resume_val=""
    local no_bridge=false
    local profile=""
    local cli_model=""
    local cli_prompt=""
    local cli_prompt_set=false
    local agent=""
    local launch_name=""
    local peer_identity=""
    local full_bypass=false
    local access_explicit=false
    local permission_mode=""
    local passthrough=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)
                [[ $# -ge 2 ]] || { echo -e "${RED}--agent needs a value${RESET}"; return 1; }
                agent="$2"; shift 2
                ;;
            --profile)
                [[ $# -ge 2 ]] || { echo -e "${RED}--profile needs a value${RESET}"; return 1; }
                profile="$2"; shift 2
                ;;
            --model)
                [[ $# -ge 2 ]] || { echo -e "${RED}--model needs a value${RESET}"; return 1; }
                cli_model="$2"; shift 2
                ;;
            --resume|-r)
                resume=true
                # Check if next arg is a value (not another flag)
                if [[ $# -gt 1 && "$2" != -* ]]; then
                    resume_val="$2"
                    shift
                fi
                shift
                ;;
            --no-bridge)
                no_bridge=true
                shift
                ;;
            --foreground|--no-tmux|--tmux)
                shift
                ;;
            --message|--prompt|-m)
                [[ $# -ge 2 ]] || { echo -e "${RED}$1 needs a value${RESET}"; return 1; }
                cli_prompt="$2"
                cli_prompt_set=true
                shift 2
                ;;
            --purpose)
                [[ $# -ge 2 ]] || { echo -e "${RED}--purpose needs a value${RESET}"; return 1; }
                shift 2
                ;;
            --yolo|--dangerously-bypass-approvals-and-sandbox)
                full_bypass=true
                access_explicit=true
                shift
                ;;
            --permission-mode)
                [[ $# -ge 2 ]] || { echo -e "${RED}--permission-mode needs a value${RESET}"; return 1; }
                permission_mode="$2"
                access_explicit=true
                shift 2
                ;;
            --sandbox|-s|--ask-for-approval|-a)
                [[ $# -ge 2 ]] || { echo -e "${RED}$1 needs a value${RESET}"; return 1; }
                access_explicit=true
                passthrough+=("$1" "$2")
                shift 2
                ;;
            --remote|--remote-auth-token-env)
                [[ $# -ge 2 ]] || { echo -e "${RED}$1 needs a value${RESET}"; return 1; }
                passthrough+=("$1" "$2")
                shift 2
                ;;
            --name|-n)
                [[ $# -ge 2 ]] || { echo -e "${RED}--name needs a value${RESET}"; return 1; }
                launch_name="$2"; shift 2
                ;;
            --peer)
                [[ $# -ge 2 ]] || { echo -e "${RED}--peer needs a peer name${RESET}"; return 1; }
                peer_identity="$2"; shift 2
                ;;
            --)
                shift
                if [[ $# -gt 0 ]]; then
                    cli_prompt="$*"
                    cli_prompt_set=true
                fi
                break
                ;;
            *)
                passthrough+=("$1")
                shift
                ;;
        esac
    done

    # Resolve profile: explicit --profile wins; else fall back to the last
    # `cctrl use` profile if recorded. Empty = no overlay (agent's own default).
    # Explicit --profile is concurrency-safe: it never touches global state.
    if [[ -z "$profile" ]]; then
        profile="$(_active_profile)"
    fi
    agent="$(_resolve_agent_or_prompt "$agent" "Choose agent runtime" "$profile")" || return 1
    local pf=""
    if [[ -n "$profile" ]]; then
        if _profile_exists "$profile"; then
            pf="$(_profile_path "$profile")"
        else
            echo -e "${YELLOW}Profile '$profile' not found; launching without it.${RESET}"
        fi
    fi
    _apply_profile_overlay "$agent" "$pf"
    _peer_refresh_paths
    _session_refresh_paths
    if [[ -n "$peer_identity" ]]; then
        local peer_json="" peer_name="" allowed_session="" resolved_peer=false
        if peer_json="$(_peer_resolve_json "$peer_identity" 2>/dev/null)"; then
            peer_name="$(jq -r '.name' <<< "$peer_json")"
            resolved_peer=true
        elif [[ "${CCTRL_SESSION_KIND:-}" == "tmux" && -n "${CCTRL_SESSION_NAME:-}" && "${CCTRL_PEER:-}" == "$peer_identity" ]]; then
            _peer_validate_label "name" "$peer_identity" || return 64
            peer_name="$peer_identity"
        else
            _peer_resolve_json "$peer_identity" || return 66
        fi
        [[ "${CCTRL_SESSION_KIND:-}" == "tmux" ]] && allowed_session="${CCTRL_SESSION_NAME:-}"
        if $resolved_peer && _peer_live_identity_conflict_exists "$peer_json" "$allowed_session"; then
            echo -e "${RED}Peer '$peer_name' already has a live tmux session.${RESET}" >&2
            echo -e "${DIM}Close that session before launching another with the same --peer identity.${RESET}" >&2
            return 65
        fi
        export CCTRL_PEER
        CCTRL_PEER="$peer_name"
    fi

    local final_prompt=""
    $cli_prompt_set && final_prompt="$cli_prompt"

    LAUNCH_FULL_BYPASS=$full_bypass
    LAUNCH_ACCESS_EXPLICIT=$access_explicit
    LAUNCH_PERMISSION_MODE="$permission_mode"
    LAUNCH_PASSTHROUGH=()
    [[ ${#passthrough[@]} -gt 0 ]] && LAUNCH_PASSTHROUGH=("${passthrough[@]}")
    _launch_exec_agent "$agent" "$pf" "$cli_model" "$launch_name" "$no_bridge" "$resume" "$resume_val" "$final_prompt" "$PWD"
}

_session_metadata_file() {
    local safe
    safe="$(printf '%s' "$1" | tr '/:' '__')"
    printf '%s/%s.json' "$SESSION_METADATA_DIR" "$safe"
}

_session_metadata_field() {
    local session_name="$1" field="$2" file
    file="$(_session_metadata_file "$session_name")"
    [[ -f "$file" ]] || return 0
    jq -r --arg field "$field" '.[$field] // empty' "$file" 2>/dev/null
}

_session_write_metadata() {
    local session_name="$1" cwd="$2" target_kind="$3" target="$4" display_label="$5" purpose="$6" initial_prompt="$7" launch_command="$8" peer="${9:-}"
    mkdir -p "$SESSION_METADATA_DIR" || return 1
    local tmp created_at host_label
    tmp="$(mktemp)" || return 1
    created_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    host_label="${CCTRL_HOST_PREFIX:-local}"
    jq -n \
        --arg name "$session_name" \
        --arg created_at "$created_at" \
        --arg cwd "$cwd" \
        --arg target_kind "$target_kind" \
        --arg target "$target" \
        --arg display_label "$display_label" \
        --arg purpose "$purpose" \
        --arg initial_prompt "$initial_prompt" \
        --arg launch_command "$launch_command" \
        --arg peer "$peer" \
        --arg host "$host_label" \
        '{
            name: $name,
            created_at: $created_at,
            cwd: $cwd,
            target_kind: $target_kind,
            target: $target,
            display_label: $display_label,
            purpose: (if $purpose == "" then null else $purpose end),
            initial_prompt: (if $initial_prompt == "" then null else $initial_prompt end),
            peer: (if $peer == "" then null else $peer end),
            launch_command: $launch_command,
            host: $host,
            cctrl_managed: true
        }' > "$tmp" && mv "$tmp" "$(_session_metadata_file "$session_name")"
}

_prompt_tty_available() {
    { : < /dev/tty; } 2>/dev/null && { : > /dev/tty; } 2>/dev/null
}

_prompt_session_purpose() {
    local default_purpose="$1" answer
    case "${CCTRL_PURPOSE_PROMPT:-auto}" in
        never)
            printf '%s' "$default_purpose"
            return 0
            ;;
        always)
            ;;
        *)
            if ! _prompt_tty_available; then
                printf '%s' "$default_purpose"
                return 0
            fi
            ;;
    esac

    if ! _prompt_tty_available; then
        printf '%s' "$default_purpose"
        return 0
    fi

    if [[ -n "$default_purpose" ]]; then
        printf 'Session purpose? [%s]\n> ' "$default_purpose" > /dev/tty
    else
        printf 'Session purpose? [optional]\n> ' > /dev/tty
    fi
    IFS= read -r answer < /dev/tty || answer=""
    printf '%s' "${answer:-$default_purpose}"
}

_launch_detached() {
    # Launch a cctrl session in a detached tmux session (survives SSH
    # disconnect). Invoked by `cctrl start -d`. No GUI — just tmux.
    #
    # An explicit target is REQUIRED. Defaulting to $HOME would drop a
    # full-access agent into a folder with ~/.ssh, ~/.aws, browser data, etc.
    # Session management lives under `cctrl session`.

    local target="" target_kind=""   # kind: dir | shortcut
    local purpose="" purpose_set=false initial_prompt="" peer_identity="" peer_name=""
    local profile="" detach_agent="" agent_explicit=false
    local shortcut_canonical=""
    local passthrough_count=0
    local passthrough=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--detach)
                shift ;;
            --)
                shift
                [[ $# -gt 0 ]] && initial_prompt="$*"
                passthrough+=("--" "$@")
                passthrough_count=$((passthrough_count + 1 + $#))
                break
                ;;
            --purpose)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}--purpose needs a value${RESET}" >&2
                    return 1
                fi
                purpose="$2"
                purpose_set=true
                shift 2
                ;;
            --message|--prompt|-m)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}$1 needs a value${RESET}" >&2
                    return 1
                fi
                initial_prompt="$2"
                passthrough+=("$1" "$2")
                passthrough_count=$((passthrough_count + 2))
                shift 2
                ;;
            --agent)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}--agent needs a value${RESET}" >&2
                    return 1
                fi
                detach_agent="$2"
                agent_explicit=true
                passthrough+=("$1" "$2")
                passthrough_count=$((passthrough_count + 2))
                shift 2
                ;;
            --profile)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}--profile needs a value${RESET}" >&2
                    return 1
                fi
                profile="$2"
                passthrough+=("$1" "$2")
                passthrough_count=$((passthrough_count + 2))
                shift 2
                ;;
            --model|--permission-mode|--sandbox|-s|--ask-for-approval|-a|--remote|--remote-auth-token-env|--name|-n)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}$1 needs a value${RESET}" >&2
                    return 1
                fi
                passthrough+=("$1" "$2")
                passthrough_count=$((passthrough_count + 2))
                shift 2
                ;;
            --peer)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}--peer needs a peer name${RESET}" >&2
                    return 1
                fi
                peer_identity="$2"
                shift 2
                ;;
            --foreground|--no-tmux|--tmux)
                shift
                ;;
            --resume|-r)
                passthrough+=("$1")
                passthrough_count=$((passthrough_count + 1))
                if [[ $# -gt 1 && "$2" != -* && "$2" != @* ]]; then
                    passthrough+=("$2")
                    passthrough_count=$((passthrough_count + 1))
                    shift
                fi
                shift
                ;;
            @*)
                if [[ -n "$target" ]]; then
                    passthrough+=("$1")
                    passthrough_count=$((passthrough_count + 1))
                else
                    target="${1#@}"
                    target_kind="shortcut"
                fi
                shift
                ;;
            -*)
                passthrough+=("$1")
                passthrough_count=$((passthrough_count + 1))
                shift
                ;;
            *)
                if [[ -n "$target" ]]; then
                    passthrough+=("$1")
                    passthrough_count=$((passthrough_count + 1))
                else
                    target="$1"
                    target_kind="dir"
                fi
                shift
                ;;
        esac
    done

    if ! command -v tmux &>/dev/null; then
        echo -e "${RED}tmux not found.${RESET} Install with: brew install tmux" >&2
        return 1
    fi

    if [[ -z "$target" ]]; then
        echo -e "${RED}cctrl start -d requires a target.${RESET}" >&2
        echo "Usage: cctrl start -d <dir | @shortcut> [extra args]" >&2
        echo -e "${DIM}A detached session needs an explicit dir or shortcut — defaulting${RESET}" >&2
        echo -e "${DIM}to \$HOME would drop a full-access agent into ~/.ssh, ~/.aws, etc.${RESET}" >&2
        return 1
    fi
    if [[ "$target_kind" == "shortcut" ]]; then
        shortcut_canonical="$(_shortcut_lookup_key "$target")"
        if [[ -z "$shortcut_canonical" ]]; then
            echo -e "${RED}Shortcut not found: @$target${RESET}" >&2
            echo -e "${DIM}List with: cctrl @${RESET}" >&2
            return 1
        fi
        local shortcut_profile="" shortcut_agent=""
        { IFS= read -r shortcut_profile; IFS= read -r shortcut_agent; } < <(jq -r --arg k "$shortcut_canonical" '
            .[$k] | (.profile // ""), (.agent // "")
        ' "$SHORTCUTS_FILE")
        [[ -z "$profile" && -n "$shortcut_profile" ]] && profile="$shortcut_profile"
        if [[ "$agent_explicit" != "true" && -n "$shortcut_agent" ]]; then
            detach_agent="$shortcut_agent"
        fi
    fi
    local agent_profile="$profile"
    [[ -n "$agent_profile" ]] || agent_profile="$(_active_profile)"
    detach_agent="$(_resolve_agent_or_prompt "$detach_agent" "Choose agent runtime" "$agent_profile")" || return 1
    export CCTRL_AGENT="$detach_agent"
    if [[ -n "$peer_identity" ]]; then
        local effective_profile="$profile" profile_agent pf=""
        [[ -n "$effective_profile" ]] || effective_profile="$(_active_profile)"
        if [[ -n "$effective_profile" ]] && _profile_exists "$effective_profile"; then
            profile_agent="$(_normalize_agent "$detach_agent")" || return 1
            pf="$(_profile_path "$effective_profile")"
            _apply_profile_overlay "$profile_agent" "$pf"
            _peer_refresh_paths
            _session_refresh_paths
        fi
    fi
    if [[ -n "$peer_identity" ]]; then
        local peer_json
        if peer_json="$(_peer_resolve_json "$peer_identity" 2>/dev/null)"; then
            peer_name="$(jq -r '.name' <<< "$peer_json")"
            if _peer_live_identity_conflict_exists "$peer_json" ""; then
                echo -e "${RED}Peer '$peer_name' already has a live tmux session.${RESET}" >&2
                echo -e "${DIM}Close that session before launching another with the same --peer identity.${RESET}" >&2
                return 65
            fi
        else
            if _peer_derived_name_exists "$peer_identity"; then
                echo -e "${RED}Peer '$peer_identity' already has a live tmux session.${RESET}" >&2
                echo -e "${DIM}Close that session before launching another with the same --peer identity.${RESET}" >&2
                return 65
            fi
            _peer_validate_label "name" "$peer_identity" || return 64
            peer_name="$peer_identity"
        fi
    fi

    local cctrl_q extras_q="" env_q="" base_env_q="CCTRL_TMUX_CONTEXT=1" shell_cmd session_name display_label context_name
    local -a child_args=()
    local metadata_cwd="" metadata_target=""
    cctrl_q="$(printf '%q' "$SCRIPT_DIR/cctrl")"
    local env_name env_val
    for env_name in CCTRL_AGENT CCTRL_HOST_PREFIX CCTRL_DEVICE_TAG CCTRL_DATA_DIR CCTRL_SESSION_METADATA_DIR; do
        env_val="${!env_name:-}"
        [[ -n "$env_val" ]] && base_env_q+=" $env_name=$(printf '%q' "$env_val")"
    done
    [[ -n "$peer_name" ]] && base_env_q+=" CCTRL_PEER=$(printf '%q' "$peer_name")"
    if [[ -n "$peer_name" ]]; then
        if [[ "$passthrough_count" -gt 0 ]]; then
            local inserted_peer=false
            for a in "${passthrough[@]}"; do
                if [[ "$inserted_peer" == "false" && "$a" == "--" ]]; then
                    child_args+=("--peer" "$peer_name")
                    inserted_peer=true
                fi
                child_args+=("$a")
            done
            if [[ "$inserted_peer" == "false" ]]; then
                child_args+=("--peer" "$peer_name")
            fi
        else
            child_args+=("--peer" "$peer_name")
        fi
    else
        if [[ "$passthrough_count" -gt 0 ]]; then
            child_args=("${passthrough[@]}")
        fi
    fi
    if [[ "$peer_name" == "" && "$passthrough_count" -eq 0 ]]; then
        :
    else
        for a in "${child_args[@]}"; do
            extras_q+=" $(printf '%q' "$a")"
        done
    fi

    # Detached tmux sessions and agent display names share one visible context
    # slug: TMUX--<host>--<target>.
    if [[ "$target_kind" == "shortcut" ]]; then
        local canonical
        canonical="$shortcut_canonical"
        context_name="$(_tmux_session_slug "$canonical")"
        session_name="$context_name"
        display_label="@$canonical"
        metadata_target="@$canonical"
        metadata_cwd="$(jq -r --arg k "$canonical" '.[$k].dir // ""' "$SHORTCUTS_FILE" 2>/dev/null)"
        metadata_cwd="${metadata_cwd/#\~/$HOME}"
    else
        local dir="$target"
        dir="${dir/#\~/$HOME}"
        if [[ ! -d "$dir" ]]; then
            echo -e "${RED}Directory not found: $dir${RESET}" >&2
            return 1
        fi
        dir="$(cd "$dir" && pwd)"
        context_name="$(_tmux_session_slug "$dir")"
        session_name="$context_name"
        display_label="$dir"
        metadata_target="$dir"
        metadata_cwd="$dir"
    fi

    # Auto-increment if session name already exists (homelab, homelab--2, ...)
    local base_name="$session_name"
    if tmux has-session -t "$session_name" 2>/dev/null; then
        local n=2
        while tmux has-session -t "${base_name}--${n}" 2>/dev/null; do
            ((n++))
        done
        session_name="${base_name}--${n}"
    fi

    local default_purpose final_purpose
    if $purpose_set; then
        final_purpose="$purpose"
    else
        if [[ -n "$initial_prompt" ]]; then
            default_purpose="$initial_prompt"
        elif [[ "$target_kind" == "shortcut" ]]; then
            default_purpose="$metadata_target"
        else
            default_purpose="${metadata_cwd##*/}"
        fi
        final_purpose="$(_prompt_session_purpose "$default_purpose")"
    fi

    env_q="$base_env_q CCTRL_SESSION_KIND=tmux CCTRL_SESSION_NAME=$(printf '%q' "$session_name")"
    [[ -n "$metadata_target" ]] && env_q+=" CCTRL_SESSION_TARGET=$(printf '%q' "$metadata_target")"
    [[ -n "$final_purpose" ]] && env_q+=" CCTRL_SESSION_PURPOSE=$(printf '%q' "$final_purpose")"
    env_q="${env_q# } "

    local cc_name_q
    cc_name_q="$(printf '%q' "$session_name")"
    if [[ "$target_kind" == "shortcut" ]]; then
        local name_q
        name_q="$(printf '%q' "${metadata_target#@}")"
        shell_cmd="${env_q}$cctrl_q @$name_q --foreground --name $cc_name_q$extras_q"
    else
        local dir_q
        dir_q="$(printf '%q' "$metadata_cwd")"
        shell_cmd="cd $dir_q && ${env_q}$cctrl_q start --foreground --name $cc_name_q$extras_q"
    fi

    if ! _session_write_metadata "$session_name" "$metadata_cwd" "$target_kind" "$metadata_target" "$display_label" "$final_purpose" "$initial_prompt" "$shell_cmd" "$peer_name" 2>/dev/null; then
        if [[ -n "$peer_name" ]]; then
            echo -e "${RED}Failed to write session metadata for peer '$peer_name'.${RESET}" >&2
            echo -e "${DIM}Metadata path: $(_session_metadata_file "$session_name")${RESET}" >&2
            return 1
        fi
    fi
    if ! tmux new-session -d -s "$session_name" "$shell_cmd"; then
        rm -f "$(_session_metadata_file "$session_name")" 2>/dev/null || true
        return 1
    fi
    tmux set-option -t "$session_name" -q @cctrl_managed 1 2>/dev/null || true

    echo -e "${GREEN}✓${RESET} detached session started — ${BOLD}$display_label${RESET}"
    echo -e "${DIM}  Attach:  cctrl session attach $session_name${RESET}"
    echo -e "${DIM}  List:    cctrl session ls${RESET}"
    echo -e "${DIM}  Close:   cctrl session close $session_name  (or 'cctrl close' from inside)${RESET}"
    echo -e "${DIM}  Kill:    cctrl session kill $session_name${RESET}"

    # Machine-readable line so a remote launch can attach to the exact session
    # name (including any auto-increment suffix). See _remote_exec.
    if [[ -n "${CCTRL_EMIT_SESSION:-}" ]]; then
        printf 'CCTRL_SESSION=%s\n' "$session_name"
    fi

    local attach_default="no"
    [[ "${CCTRL_ATTACH_AFTER_START:-}" == "1" ]] && attach_default="yes"
    _prompt_attach_session "$session_name" "$attach_default"
}

_prompt_attach_session() {
    local session_name="$1" default="${2:-no}" answer prompt default_answer

    case "${CCTRL_ATTACH_PROMPT:-auto}" in
        never) return 0 ;;
        always) ;;
        *) [[ -t 0 && -t 1 ]] || return 0 ;;
    esac

    if [[ "$default" == "yes" ]]; then
        prompt="Connect to session $session_name now? [Y/n] "
        default_answer="yes"
    else
        prompt="Connect to session $session_name now? [y/N] "
        default_answer="no"
    fi

    printf '%s' "$prompt"
    IFS= read -r answer || return 0
    answer="$(printf '%s' "${answer:-$default_answer}" | tr '[:upper:]' '[:lower:]')"
    case "$answer" in
        y|yes) exec tmux attach-session -t "$session_name" ;;
        *)
            echo -e "${DIM}Not connected. Attach later: cctrl session attach $session_name${RESET}"
            ;;
    esac
}

# ── Peer registry ─────────────────────────────────────────────────────

_peer_init() {
    mkdir -p "$(dirname "$PEERS_FILE")"
    [[ -f "$PEERS_FILE" ]] || echo "{}" > "$PEERS_FILE"
}

_peer_now_utc() {
    if [[ -n "${CCTRL_NOW_UTC:-}" ]]; then
        printf '%s\n' "$CCTRL_NOW_UTC"
        return
    fi
    date -u +"%Y-%m-%dT%H:%M:%SZ"
}

_peer_validate_label() {
    local kind="$1" value="${2:-}"
    if [[ -z "$value" ]]; then
        echo -e "${RED}Peer $kind cannot be empty.${RESET}" >&2
        return 1
    fi
    if [[ "$value" == "user" ]]; then
        echo -e "${RED}Invalid peer $kind: 'user' is reserved for the human sender.${RESET}" >&2
        return 1
    fi
    if [[ ! "$value" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
        echo -e "${RED}Invalid peer $kind: '$value'.${RESET}" >&2
        echo -e "${DIM}Use letters, numbers, dot, underscore, or dash; no whitespace or shell metacharacters.${RESET}" >&2
        return 1
    fi
}

_peer_json_array() {
    if [[ $# -eq 0 ]]; then
        printf '[]\n'
        return
    fi
    printf '%s\n' "$@" | jq -R . | jq -s 'unique'
}

_peer_lookup_manual_key() {
    local name="$1"
    _peer_init
    jq -r --arg n "$name" '
        ([to_entries[]
          | select(.key == $n or ((.value.aliases // []) | index($n)))
          | .key][0]) // empty
    ' "$PEERS_FILE" 2>/dev/null
}

_peer_manual_collision_owner() {
    local label="$1" owner="${2:-}" found
    found="$(_peer_lookup_manual_key "$label")"
    if [[ -n "$found" && "$found" != "$owner" ]]; then
        printf '%s\n' "$found"
        return 0
    fi
    return 1
}

_peer_derived_name_exists() {
    local label="$1" doc
    doc="$(_peer_derived_json)" || return 1
    jq -e --arg n "$label" '.peers[]? | select(.name == $n or ((.aliases // []) | index($n)))' <<< "$doc" >/dev/null 2>&1
}

_peer_derived_identity_exists() {
    _peer_derived_identity_conflict_exists "${1:-}" ""
}

_peer_derived_identity_conflict_exists() {
    local name="$1" doc
    local allowed_session="${2:-}"
    doc="$(_peer_derived_json)" || return 1
    jq -e --arg n "$name" --arg allowed "$allowed_session" '
        .peers[]?
        | select(.name == $n)
        | select($allowed == "" or (.session // "") != $allowed)
    ' <<< "$doc" >/dev/null 2>&1
}

_peer_live_identity_conflict_exists() {
    local peer_json="$1" allowed_session="${2:-}" name session
    name="$(jq -r '.name // empty' <<< "$peer_json")"
    session="$(jq -r '.tmux_target // .session // empty' <<< "$peer_json")"
    if [[ -n "$session" && "$session" != "$allowed_session" ]] && command -v tmux >/dev/null 2>&1 && _tmux_run_with_timeout has-session -t "$session"; then
        return 0
    fi
    if [[ -n "$name" ]] && _peer_derived_identity_conflict_exists "$name" "$allowed_session"; then
        return 0
    fi
    return 1
}

_peer_derived_json() {
    local host_label="${CCTRL_HOST_PREFIX:-local}" sessions_json
    if ! command -v tmux >/dev/null 2>&1; then
        jq -n '{skipped:true, reason:"tmux unavailable", peers:[]}'
        return
    fi

    if ! sessions_json="$(_session_list --json 2>/dev/null)"; then
        jq -n '{skipped:true, reason:"tmux session discovery failed", peers:[]}'
        return
    fi
    if ! printf '%s\n' "$sessions_json" | jq empty >/dev/null 2>&1; then
        jq -n '{skipped:true, reason:"tmux session discovery returned invalid JSON", peers:[]}'
        return
    fi

    jq -n --argjson sessions "$sessions_json" --arg host "$host_label" '
        {
          skipped: false,
          reason: null,
          peers: [
            $sessions[]
            | select(.managed == true)
            | (.peer // .name) as $peer_name
            | {
                name: $peer_name,
                aliases: (if ((.peer // "") != "" and .peer != .name) then [.name] else [] end),
                host: $host,
                dir: .dir,
                agent: .agent,
                session: .name,
                purpose: .purpose,
                capabilities: ["mailbox", "tmux"],
                source: "derived",
                tmux_target: .name,
                created_at: .created_at
              }
            | with_entries(select(.value != null))
          ]
        }'
}

_peer_all_json() {
    _peer_init
    local manual_json derived_json
    manual_json="$(cat "$PEERS_FILE")"
    derived_json="$(_peer_derived_json)"
    jq -n --argjson manual "$manual_json" --argjson derived "$derived_json" '
        def clean: with_entries(select(.value != null));
        def with_tmux_target:
          if ((.session // "") != "") then . + {tmux_target: .session} else . end;

        ($derived.peers // []) as $derived_peers
        | ($manual | to_entries) as $manual_entries
        | ($manual_entries | (map(.key) + map((.value.aliases // [])[]))) as $manual_labels
        | ($manual_entries | map(
            .key as $k
            | .value as $v
            | ([ $derived_peers[] | select(.name == $k) ][0] // null) as $derived_name_match
            | ([ $derived_peers[] | select((.aliases // []) | index($k)) ][0] // null) as $derived_alias_match
            | ($derived_name_match // null) as $derived_merge
            | ($derived_name_match // $derived_alias_match // null) as $derived_shadow
            | (($derived_merge.aliases // []) | map(. as $alias | select(($manual_labels | index($alias)) | not))) as $derived_aliases
            | (($derived_shadow.session // $derived_shadow.name // "") // "") as $shadow
            | ({
                name: ($v.name // $k),
                aliases: ((($v.aliases // []) + $derived_aliases) | unique),
                host: ($v.host // "local"),
                dir: ($v.dir // $derived_merge.dir // null),
                agent: ($v.agent // $derived_merge.agent // null),
                session: ($derived_merge.session // $v.session // null),
                purpose: ($v.purpose // $derived_merge.purpose // null),
                capabilities: ((($v.capabilities // []) + ($derived_merge.capabilities // [])) | unique),
                registered_at: ($v.registered_at // null),
                source: "manual"
              }
              | with_tmux_target
              | if $shadow != "" then . + {shadows: $shadow} else . end
              | clean)
          )) as $manual_peers
        | {
            derived_skipped: ($derived.skipped // false),
            derived_skip_reason: ($derived.reason // null),
            peers: (
              $manual_peers
              + [
                  $derived_peers[]
                  | . as $p
                  | select(($manual_labels | index($p.name)) | not)
                  | .aliases = ((.aliases // []) | map(. as $alias | select(($manual_labels | index($alias)) | not)))
                ]
            )
          }'
}

_peer_resolve_json() {
    local name="$1" doc matches count skipped reason
    doc="$(_peer_all_json)" || return 1
    matches="$(jq -c --arg n "$name" '
        [ .peers[]
          | select(.name == $n or ((.aliases // []) | index($n)))
        ]
    ' <<< "$doc")"
    count="$(jq -r 'length' <<< "$matches")"
    if [[ "$count" == "0" ]]; then
        skipped="$(jq -r '.derived_skipped' <<< "$doc")"
        reason="$(jq -r '.derived_skip_reason // empty' <<< "$doc")"
        echo -e "${RED}Unknown peer: '$name'${RESET}" >&2
        if [[ "$skipped" == "true" && -n "$reason" ]]; then
            echo -e "${YELLOW}Derived tmux peer discovery skipped: $reason.${RESET}" >&2
        fi
        echo -e "${DIM}Register it with: cctrl peer register $name --dir <path> --agent <agent>${RESET}" >&2
        return 1
    fi
    if (( count > 1 )); then
        echo -e "${RED}Ambiguous peer identity: '$name'${RESET}" >&2
        jq -r '.[] | "  - " + .name + " (" + .source + ")"' <<< "$matches" >&2
        return 1
    fi
    jq '.[0]' <<< "$matches"
}

_peer_print_human() {
    jq -r '
        def value:
          if type == "array" then join(", ")
          else tostring
          end;
        to_entries[]
        | select(.value != null)
        | "  \(.key): \(.value | value)"
    '
}

_peer_cmd_register() {
    local name="${1:-}"
    [[ -n "$name" ]] || { echo -e "${RED}Usage: cctrl peer register <name> [flags]${RESET}" >&2; return 1; }
    shift
    _peer_validate_label "name" "$name" || return 1

    local host="local" dir="" agent="" session="" purpose=""
    local -a aliases=() capabilities=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --alias)
                [[ $# -ge 2 ]] || { echo -e "${RED}--alias needs a value${RESET}" >&2; return 1; }
                _peer_validate_label "alias" "$2" || return 1
                aliases+=("$2"); shift 2 ;;
            --host)
                [[ $# -ge 2 ]] || { echo -e "${RED}--host needs a value${RESET}" >&2; return 1; }
                host="$2"; shift 2 ;;
            --dir)
                [[ $# -ge 2 ]] || { echo -e "${RED}--dir needs a value${RESET}" >&2; return 1; }
                dir="${2/#\~/$HOME}"; shift 2 ;;
            --agent)
                [[ $# -ge 2 ]] || { echo -e "${RED}--agent needs a value${RESET}" >&2; return 1; }
                [[ -n "$2" ]] || { echo -e "${RED}--agent cannot be empty${RESET}" >&2; return 1; }
                agent="$2"; shift 2 ;;
            --session)
                [[ $# -ge 2 ]] || { echo -e "${RED}--session needs a value${RESET}" >&2; return 1; }
                session="$2"; shift 2 ;;
            --purpose)
                [[ $# -ge 2 ]] || { echo -e "${RED}--purpose needs a value${RESET}" >&2; return 1; }
                purpose="$2"; shift 2 ;;
            --capability)
                [[ $# -ge 2 ]] || { echo -e "${RED}--capability needs a value${RESET}" >&2; return 1; }
                _peer_validate_label "capability" "$2" || return 1
                capabilities+=("$2"); shift 2 ;;
            *)
                echo -e "${RED}Unknown peer register flag: $1${RESET}" >&2
                return 1 ;;
        esac
    done

    _peer_init
    local existing owner alias
    existing="$(_peer_lookup_manual_key "$name")"
    if [[ -n "$existing" && "$existing" != "$name" ]]; then
        echo -e "${RED}Peer name '$name' collides with alias on '$existing'.${RESET}" >&2
        return 1
    fi
    if [[ ${#aliases[@]} -gt 0 ]]; then
        for alias in "${aliases[@]}"; do
            if [[ "$alias" == "$name" ]]; then
                echo -e "${RED}Alias '$alias' matches the peer name.${RESET}" >&2
                return 1
            fi
            if owner="$(_peer_manual_collision_owner "$alias" "$name")"; then
                echo -e "${RED}Peer alias '$alias' collides with '$owner'.${RESET}" >&2
                return 1
            fi
            if _peer_derived_name_exists "$alias"; then
                echo -e "${RED}Peer alias '$alias' collides with a live tmux peer.${RESET}" >&2
                return 1
            fi
        done
    fi

    local aliases_json capabilities_json now tmp
    if [[ ${#capabilities[@]} -eq 0 ]]; then
        if [[ -n "$session" ]]; then
            capabilities=("mailbox" "tmux")
        else
            capabilities=("mailbox")
        fi
    else
        local has_mailbox=false capability
        for capability in "${capabilities[@]}"; do
            [[ "$capability" == "mailbox" ]] && has_mailbox=true
        done
        $has_mailbox || capabilities=("mailbox" "${capabilities[@]}")
    fi
    if [[ ${#aliases[@]} -gt 0 ]]; then
        aliases_json="$(_peer_json_array "${aliases[@]}")"
    else
        aliases_json="[]"
    fi
    capabilities_json="$(_peer_json_array "${capabilities[@]}")"
    now="$(_peer_now_utc)"
    tmp="$(mktemp)"
    jq --arg name "$name" \
       --arg host "$host" \
       --arg dir "$dir" \
       --arg agent "$agent" \
       --arg session "$session" \
       --arg purpose "$purpose" \
       --arg now "$now" \
       --argjson aliases "$aliases_json" \
       --argjson capabilities "$capabilities_json" '
        . + {
          ($name): (
            {
              name: $name,
              aliases: $aliases,
              host: $host,
              capabilities: $capabilities,
              registered_at: (.[$name].registered_at // $now)
            }
            + (if $dir != "" then {dir: $dir} else {} end)
            + (if $agent != "" then {agent: $agent} else {} end)
            + (if $session != "" then {session: $session} else {} end)
            + (if $purpose != "" then {purpose: $purpose} else {} end)
          )
        }' "$PEERS_FILE" > "$tmp" && mv "$tmp" "$PEERS_FILE"

    echo -e "${GREEN}Registered peer: ${BOLD}$name${RESET}"
}

_peer_cmd_alias() {
    local name="${1:-}" alias="${2:-}" key owner doc derived_count tmp
    if [[ -z "$name" || -z "$alias" ]]; then
        echo -e "${RED}Usage: cctrl peer alias <name> <alias>${RESET}" >&2
        return 1
    fi
    _peer_validate_label "alias" "$alias" || return 1
    key="$(_peer_lookup_manual_key "$name")"
    if [[ -z "$key" ]]; then
        doc="$(_peer_all_json)" || return 1
        derived_count="$(jq -r --arg n "$name" '[.peers[] | select(.source == "derived" and (.name == $n or ((.aliases // []) | index($n))))] | length' <<< "$doc")"
        if (( derived_count > 0 )); then
            echo -e "${RED}Peer '$name' is derived from tmux; register this peer first before adding aliases.${RESET}" >&2
        else
            echo -e "${RED}Unknown manual peer: '$name'${RESET}" >&2
        fi
        return 1
    fi
    if [[ "$alias" == "$key" ]]; then
        echo -e "${RED}Alias '$alias' matches the peer name.${RESET}" >&2
        return 1
    fi
    if owner="$(_peer_manual_collision_owner "$alias" "$key")"; then
        echo -e "${RED}Peer alias '$alias' collides with '$owner'.${RESET}" >&2
        return 1
    fi
    if _peer_derived_name_exists "$alias"; then
        echo -e "${RED}Peer alias '$alias' collides with a live tmux peer.${RESET}" >&2
        return 1
    fi

    tmp="$(mktemp)"
    jq --arg key "$key" --arg alias "$alias" '
        .[$key].aliases = ((.[$key].aliases // []) + [$alias] | unique)
    ' "$PEERS_FILE" > "$tmp" && mv "$tmp" "$PEERS_FILE"
    echo -e "${GREEN}Added alias: ${BOLD}$alias${RESET}${GREEN} → $key${RESET}"
}

_peer_cmd_unregister() {
    local name="${1:-}" key tmp
    [[ -n "$name" ]] || { echo -e "${RED}Usage: cctrl peer unregister <name>${RESET}" >&2; return 1; }
    key="$(_peer_lookup_manual_key "$name")"
    if [[ -z "$key" ]]; then
        echo -e "${RED}No manual peer registered as '$name'.${RESET}" >&2
        return 1
    fi
    tmp="$(mktemp)"
    jq --arg key "$key" 'del(.[$key])' "$PEERS_FILE" > "$tmp" && mv "$tmp" "$PEERS_FILE"
    echo -e "${GREEN}Unregistered peer: $key${RESET}"
}

_peer_cmd_ls() {
    local json=false a doc
    for a in "$@"; do
        case "$a" in
            --json) json=true ;;
            *)
                echo -e "${RED}Unknown peer ls flag: $a${RESET}" >&2
                return 1 ;;
        esac
    done
    doc="$(_peer_all_json)" || return 1
    if $json; then
        jq '.' <<< "$doc"
        return
    fi
    if [[ "$(jq -r '.derived_skipped' <<< "$doc")" == "true" ]]; then
        echo -e "${YELLOW}Derived tmux peer discovery skipped: $(jq -r '.derived_skip_reason' <<< "$doc").${RESET}" >&2
    fi
    if [[ "$(jq -r '.peers | length' <<< "$doc")" == "0" ]]; then
        echo -e "${DIM}No peers registered or discovered.${RESET}"
        return
    fi
    echo -e "${BOLD}Peers${RESET}"
    jq -r '
        .peers[]
        | [
            .name,
            .source,
            (.agent // "-"),
            (.dir // "-"),
            ((.capabilities // []) | join(",")),
            (.purpose // ""),
            (.shadows // "")
          ]
        | @tsv
    ' <<< "$doc" | while IFS=$'\t' read -r name source agent dir capabilities purpose shadows; do
        local shadow_text=""
        [[ -n "$shadows" ]] && shadow_text=" ${DIM}shadows=$shadows${RESET}"
        printf '  %b%-18s%b %-8s %-7s %-32s %-15s %s\n' "$GREEN" "$name" "$RESET" "$source" "$agent" "$dir" "$capabilities" "$purpose$shadow_text"
    done
}

_peer_cmd_resolve() {
    local target="${1:-}" json=false peer_json a
    [[ -n "$target" ]] || { echo -e "${RED}Usage: cctrl peer resolve <name-or-alias> [--json]${RESET}" >&2; return 1; }
    shift
    for a in "$@"; do
        case "$a" in
            --json) json=true ;;
            *)
                echo -e "${RED}Unknown peer resolve flag: $a${RESET}" >&2
                return 1 ;;
        esac
    done
    peer_json="$(_peer_resolve_json "$target")" || return 1
    if $json; then
        jq '.' <<< "$peer_json"
        return
    fi
    if [[ "$(jq -r '.shadows // empty' <<< "$peer_json")" != "" ]]; then
        echo -e "${YELLOW}Manual peer shadows live tmux session: $(jq -r '.shadows' <<< "$peer_json").${RESET}" >&2
    fi
    jq '.' <<< "$peer_json" | _peer_print_human
}

_peer_cmd_whoami() {
    local json=false identity="" a peer_json
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --as)
                [[ $# -ge 2 ]] || { echo -e "${RED}--as needs a peer name${RESET}" >&2; return 1; }
                identity="$2"; shift 2 ;;
            --json)
                json=true; shift ;;
            *)
                echo -e "${RED}Unknown peer whoami flag: $1${RESET}" >&2
                return 1 ;;
        esac
    done
    [[ -n "$identity" ]] || identity="${CCTRL_PEER:-}"
    if [[ -z "$identity" ]]; then
        echo -e "${RED}No peer identity provided.${RESET}" >&2
        echo -e "${DIM}Use: cctrl peer whoami --as <peer>  or set CCTRL_PEER.${RESET}" >&2
        return 1
    fi
    peer_json="$(_peer_resolve_json "$identity")" || return 1
    if $json; then
        jq '.' <<< "$peer_json"
    else
        echo -e "${BOLD}Peer Identity${RESET}"
        jq '.' <<< "$peer_json" | _peer_print_human
    fi
}

_mailbox_init() {
    mkdir -p "$(dirname "$MESSAGES_FILE")"
    [[ -f "$MESSAGES_FILE" ]] || : > "$MESSAGES_FILE"
}

_mailbox_lock_path() {
    printf '%s.lock' "$MESSAGES_FILE"
}

_pid_alive() {
    local pid="${1:-}"
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    kill -0 "$pid" 2>/dev/null
}

_mailbox_lock_acquire() {
    mkdir -p "$(dirname "$MESSAGES_FILE")"
    local lock_path start now timeout pid
    lock_path="$(_mailbox_lock_path)"
    timeout="${CCTRL_MAILBOX_LOCK_TIMEOUT:-10}"
    start="$(date +%s)"

    if command -v shlock >/dev/null 2>&1 && [[ "${CCTRL_MAILBOX_LOCK_KIND:-auto}" != "dir" ]]; then
        while ! shlock -p "$$" -f "$lock_path" 2>/dev/null; do
            now="$(date +%s)"
            if (( now - start >= timeout )); then
                echo -e "${RED}Timed out waiting for mailbox lock.${RESET}" >&2
                return 1
            fi
            sleep 0.1
        done
        MAILBOX_LOCK_HELD="$lock_path"
        MAILBOX_LOCK_KIND="file"
        return 0
    fi

    while ! mkdir "$lock_path" 2>/dev/null; do
        if [[ -f "$lock_path/pid" ]]; then
            pid="$(cat "$lock_path/pid" 2>/dev/null || true)"
            if ! _pid_alive "$pid"; then
                rm -rf "$lock_path" 2>/dev/null || true
                continue
            fi
        else
            rm -rf "$lock_path" 2>/dev/null || true
            continue
        fi
        now="$(date +%s)"
        if (( now - start >= timeout )); then
            echo -e "${RED}Timed out waiting for mailbox lock held by PID ${pid:-unknown}.${RESET}" >&2
            return 1
        fi
        sleep 0.1
    done
    printf '%s\n' "$$" > "$lock_path/pid"
    date -u +"%Y-%m-%dT%H:%M:%SZ" > "$lock_path/created_at" 2>/dev/null || true
    MAILBOX_LOCK_HELD="$lock_path"
    MAILBOX_LOCK_KIND="dir"
}

_mailbox_lock_release() {
    local lock_path="${MAILBOX_LOCK_HELD:-}"
    [[ -n "$lock_path" ]] || return 0
    case "${MAILBOX_LOCK_KIND:-}" in
        file) rm -f "$lock_path" ;;
        dir) rm -rf "$lock_path" ;;
    esac
    unset MAILBOX_LOCK_HELD MAILBOX_LOCK_KIND
}

_mailbox_read_json() {
    _mailbox_init
    if [[ ! -s "$MESSAGES_FILE" ]]; then
        printf '[]\n'
        return
    fi
    jq -s '.' "$MESSAGES_FILE"
}

_mailbox_rewrite_json_locked() {
    local messages_json="$1" tmp
    tmp="$(mktemp)"
    jq -c '.[]' <<< "$messages_json" > "$tmp" && mv "$tmp" "$MESSAGES_FILE"
}

_mailbox_generate_id_locked() {
    local stamp rand id
    while true; do
        stamp="$(date -u +"%Y%m%d_%H%M%S")"
        rand="$(od -An -N3 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
        [[ -n "$rand" ]] || rand="$(printf '%06x' "$((RANDOM % 16777216))")"
        id="msg_${stamp}_${rand}"
        if ! jq -e --arg id "$id" 'select(.id == $id)' "$MESSAGES_FILE" >/dev/null 2>&1; then
            printf '%s\n' "$id"
            return
        fi
    done
}

_mailbox_validate_label() {
    local kind="$1" value="${2:-}" allow_user="${3:-false}"
    if [[ "$allow_user" == "true" && "$value" == "user" ]]; then
        return 0
    fi
    _peer_validate_label "$kind" "$value"
}

_mailbox_peer_known() {
    local name="$1" allow_user="${2:-false}"
    [[ "$allow_user" == "true" && "$name" == "user" ]] && return 0
    _peer_resolve_json "$name" >/dev/null 2>&1
}

_mailbox_require_peer() {
    local role="$1" name="$2" allow_user="${3:-false}"
    _mailbox_validate_label "$role" "$name" "$allow_user" || return 1
    if ! _mailbox_peer_known "$name" "$allow_user"; then
        echo -e "${RED}Unknown $role: '$name'${RESET}" >&2
        echo -e "${DIM}Register it first, or use --allow-unknown for peer send.${RESET}" >&2
        return 1
    fi
}

_mailbox_resolve_identity() {
    local explicit="$1" env_identity="${CCTRL_PEER:-}" identity
    identity="$explicit"
    [[ -n "$identity" ]] || identity="$env_identity"
    if [[ -z "$identity" ]]; then
        echo -e "${RED}No peer identity provided.${RESET}" >&2
        echo -e "${DIM}Use --as <peer> or set CCTRL_PEER.${RESET}" >&2
        return 1
    fi
    _mailbox_require_peer "peer" "$identity" false || return 1
    _peer_resolve_json "$identity" | jq -r '.name'
}

_mailbox_status_filter_json() {
    local status_csv="${1:-}" default_csv="${2:-}" effective status
    effective="$status_csv"
    [[ -n "$effective" ]] || effective="$default_csv"
    if [[ -z "$effective" ]]; then
        printf '[]\n'
        return
    fi
    printf '%s\n' "$effective" | tr ',' '\n' | while IFS= read -r status; do
        status="${status//[[:space:]]/}"
        [[ -n "$status" ]] && printf '%s\n' "$status"
    done | jq -R . | jq -s 'unique'
}

_mailbox_print_messages_human() {
    jq -r '
        .[]
        | "\(.id)  \(.status)  \(.from) -> \(.to)  \(.subject // "")"
    '
}

_json_error() {
    local code="$1" message="$2"
    jq -n --arg code "$code" --arg message "$message" \
        '{ok:false,error:{code:$code,message:$message}}'
}

_arg_has_json() {
    local arg
    for arg in "$@"; do
        [[ "$arg" == "--json" ]] && return 0
    done
    return 1
}

_read_body_file() {
    local path="$1" body sentinel=$'\037'
    if [[ "$path" == "-" ]]; then
        body="$(cat; printf '%s' "$sentinel")"
    else
        body="$(cat "$path"; printf '%s' "$sentinel")"
    fi
    MAILBOX_BODY="${body%$sentinel}"
}

_mailbox_read_json_or_error() {
    local json="${1:-false}" messages
    if messages="$(_mailbox_read_json 2>/dev/null)"; then
        MAILBOX_MESSAGES="$messages"
        return 0
    fi
    if [[ "$json" == "true" ]]; then
        _json_error "mailbox-corrupt" "Mailbox data is not valid JSONL."
    else
        echo -e "${RED}Mailbox data is not valid JSONL: $MESSAGES_FILE${RESET}" >&2
    fi
    return 65
}

_mailbox_resolve_identity_for_mode() {
    local explicit="$1" json="${2:-false}" identity
    identity="$explicit"
    [[ -n "$identity" ]] || identity="${CCTRL_PEER:-}"
    if [[ -z "$identity" ]]; then
        if [[ "$json" == "true" ]]; then
            _json_error "missing-identity" "Use --as <peer> or set CCTRL_PEER."
            return 66
        fi
        echo -e "${RED}No peer identity provided.${RESET}" >&2
        echo -e "${DIM}Use --as <peer> or set CCTRL_PEER.${RESET}" >&2
        return 1
    fi
    if [[ ! "$identity" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ || "$identity" == "user" ]]; then
        if [[ "$json" == "true" ]]; then
            _json_error "validation" "Invalid peer identity: $identity"
            return 64
        fi
        _mailbox_validate_label "peer" "$identity" false
        return 1
    fi
    local peer_json
    if ! peer_json="$(_peer_resolve_json "$identity" 2>/dev/null)"; then
        if [[ "$json" == "true" ]]; then
            _json_error "unknown-peer" "Unknown peer: $identity"
            return 66
        fi
        _mailbox_require_peer "peer" "$identity" false
        return 1
    fi
    MAILBOX_RESOLVED_IDENTITY="$(jq -r '.name' <<< "$peer_json")"
}

_peer_cmd_send() {
    local to="${1:-}"
    [[ -n "$to" ]] || { echo -e "${RED}Usage: cctrl peer send <to> [--from NAME] [--subject TEXT] [--body-file PATH|-] [--allow-unknown] [--json] -- <body>${RESET}" >&2; return 64; }
    shift

    local from="" as_identity="" subject="" body="" body_file="" json=false allow_unknown=false saw_body=false
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--from needs a value" || echo -e "${RED}--from needs a value${RESET}" >&2; return 64; }
                from="$2"; shift 2 ;;
            --as)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--as needs a peer name" || echo -e "${RED}--as needs a peer name${RESET}" >&2; return 64; }
                as_identity="$2"; shift 2 ;;
            --subject)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--subject needs a value" || echo -e "${RED}--subject needs a value${RESET}" >&2; return 64; }
                subject="$2"; shift 2 ;;
            --body-file)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--body-file needs a value" || echo -e "${RED}--body-file needs a value${RESET}" >&2; return 64; }
                body_file="$2"; shift 2 ;;
            --allow-unknown)
                allow_unknown=true; shift ;;
            --json)
                json=true; shift ;;
            --)
                shift
                body="$*"
                saw_body=true
                break ;;
            *)
                $json && _json_error "validation" "Unknown peer send flag: $1" || echo -e "${RED}Unknown peer send flag: $1${RESET}" >&2
                return 64 ;;
        esac
    done
    if [[ -n "$body_file" ]]; then
        if $saw_body; then
            $json && _json_error "validation" "Use either --body-file or -- <body>, not both." || echo -e "${RED}Use either --body-file or -- <body>, not both.${RESET}" >&2
            return 64
        fi
        if [[ "$body_file" == "-" ]]; then
            _read_body_file -
            body="$MAILBOX_BODY"
        elif [[ -f "$body_file" ]]; then
            _read_body_file "$body_file"
            body="$MAILBOX_BODY"
        else
            $json && _json_error "validation" "Body file not found: $body_file" || echo -e "${RED}Body file not found: $body_file${RESET}" >&2
            return 64
        fi
        unset MAILBOX_BODY
        saw_body=true
    fi
    if ! $saw_body; then
        $json && _json_error "validation" "peer send needs --body-file or a body after --." || echo -e "${RED}peer send needs --body-file or a body after --.${RESET}" >&2
        return 64
    fi

    if [[ -z "$from" ]]; then
        if [[ -n "$as_identity" || -n "${CCTRL_PEER:-}" ]]; then
            _mailbox_resolve_identity_for_mode "$as_identity" "$json" || return $?
            from="$MAILBOX_RESOLVED_IDENTITY"
        elif $json; then
            _json_error "missing-identity" "Use --from NAME, --as NAME, CCTRL_PEER, or --allow-unknown."
            return 66
        elif [[ -t 0 && -t 1 ]]; then
            from="user"
        else
            echo -e "${RED}No sender identity provided.${RESET}" >&2
            echo -e "${DIM}Use --from NAME, --as NAME, or CCTRL_PEER.${RESET}" >&2
            return 1
        fi
    fi

    local unknown_peer=false to_peer_json="" from_peer_json=""
    if ! _mailbox_validate_label "recipient" "$to" false >/dev/null 2>&1; then
        $json && _json_error "validation" "Invalid recipient: $to" || _mailbox_validate_label "recipient" "$to" false
        return 64
    fi
    if ! _mailbox_validate_label "sender" "$from" true >/dev/null 2>&1; then
        $json && _json_error "validation" "Invalid sender: $from" || _mailbox_validate_label "sender" "$from" true
        return 64
    fi
    if ! $allow_unknown; then
        if ! to_peer_json="$(_peer_resolve_json "$to" 2>/dev/null)"; then
            $json && _json_error "unknown-peer" "Unknown recipient: $to" || _mailbox_require_peer "recipient" "$to" false
            return 66
        fi
        to="$(jq -r '.name' <<< "$to_peer_json")"
        if [[ "$from" == "user" ]]; then
            :
        elif ! from_peer_json="$(_peer_resolve_json "$from" 2>/dev/null)"; then
            $json && _json_error "unknown-peer" "Unknown sender: $from" || _mailbox_require_peer "sender" "$from" true
            return 66
        else
            from="$(jq -r '.name' <<< "$from_peer_json")"
        fi
    else
        to_peer_json="$(_peer_resolve_json "$to" 2>/dev/null || true)"
        if [[ "$from" == "user" ]]; then
            from_peer_json=""
        else
            from_peer_json="$(_peer_resolve_json "$from" 2>/dev/null || true)"
        fi
        if [[ -z "$to_peer_json" || ( "$from" != "user" && -z "$from_peer_json" ) ]]; then
            unknown_peer=true
        fi
        [[ -n "$to_peer_json" ]] && to="$(jq -r '.name' <<< "$to_peer_json")"
        if [[ "$from" != "user" && -n "$from_peer_json" ]]; then
            from="$(jq -r '.name' <<< "$from_peer_json")"
        fi
    fi

    _mailbox_lock_acquire || return 1
    local now id message rc=0
    if ! {
        _mailbox_init
        now="$(_peer_now_utc)"
        id="$(_mailbox_generate_id_locked)"
        message="$(jq -cn \
            --arg id "$id" \
            --arg from "$from" \
            --arg to "$to" \
            --arg subject "$subject" \
            --arg body "$body" \
            --arg now "$now" \
            --argjson unknown "$unknown_peer" \
            '{
              id: $id,
              from: $from,
              to: $to,
              status: "queued",
              subject: $subject,
              body: $body,
              created_at: $now,
              updated_at: $now,
              delivered_at: null,
              acked_at: null,
              nudge_count: 0,
              last_nudge_at: null,
              last_nudge_error: null,
              history: [{at: $now, status: "queued", by: $from}]
            } + (if $unknown then {unknown_peer: true} else {} end)')"
        printf '%s\n' "$message" >> "$MESSAGES_FILE"
    }; then
        rc=1
    fi
    _mailbox_lock_release
    [[ $rc -eq 0 ]] || return $rc

    if $json; then
        jq '.' <<< "$message"
    else
        echo -e "${GREEN}Queued message: ${BOLD}$id${RESET}"
    fi
}

_peer_cmd_inbox() {
    local as_identity="" status_csv="" json=false a identity messages statuses
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --as)
                [[ $# -ge 2 ]] || { echo -e "${RED}--as needs a peer name${RESET}" >&2; return 1; }
                as_identity="$2"; shift 2 ;;
            --status)
                [[ $# -ge 2 ]] || { echo -e "${RED}--status needs a value${RESET}" >&2; return 1; }
                status_csv="$2"; shift 2 ;;
            --json)
                json=true; shift ;;
            *)
                echo -e "${RED}Unknown peer inbox flag: $1${RESET}" >&2
                return 1 ;;
        esac
    done
    _mailbox_resolve_identity_for_mode "$as_identity" "$json" || return $?
    identity="$MAILBOX_RESOLVED_IDENTITY"
    _mailbox_read_json_or_error "$json" || return $?
    messages="$MAILBOX_MESSAGES"
    statuses="$(_mailbox_status_filter_json "$status_csv" "queued,delivered")"
    messages="$(jq --arg who "$identity" --argjson statuses "$statuses" '
        [ .[] | .status as $status | select(.to == $who and ($statuses | index($status))) ]
    ' <<< "$messages")"
    if $json; then
        jq '.' <<< "$messages"
    else
        jq '.' <<< "$messages" | _mailbox_print_messages_human
    fi
}

_peer_cmd_outbox() {
    local as_identity="" status_csv="" json=false identity messages statuses
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --as)
                [[ $# -ge 2 ]] || { echo -e "${RED}--as needs a peer name${RESET}" >&2; return 1; }
                as_identity="$2"; shift 2 ;;
            --status)
                [[ $# -ge 2 ]] || { echo -e "${RED}--status needs a value${RESET}" >&2; return 1; }
                status_csv="$2"; shift 2 ;;
            --json)
                json=true; shift ;;
            *)
                echo -e "${RED}Unknown peer outbox flag: $1${RESET}" >&2
                return 1 ;;
        esac
    done
    _mailbox_resolve_identity_for_mode "$as_identity" "$json" || return $?
    identity="$MAILBOX_RESOLVED_IDENTITY"
    _mailbox_read_json_or_error "$json" || return $?
    messages="$MAILBOX_MESSAGES"
    statuses="$(_mailbox_status_filter_json "$status_csv" "")"
    messages="$(jq --arg who "$identity" --argjson statuses "$statuses" '
        [ .[] | .status as $status | select(.from == $who and (($statuses | length) == 0 or ($statuses | index($status)))) ]
    ' <<< "$messages")"
    if $json; then
        jq '.' <<< "$messages"
    else
        jq '.' <<< "$messages" | _mailbox_print_messages_human
    fi
}

_peer_cmd_show() {
    local id="${1:-}" json=false message
    [[ -n "$id" ]] || { echo -e "${RED}Usage: cctrl peer show <message-id> [--json]${RESET}" >&2; return 1; }
    shift
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            *)
                echo -e "${RED}Unknown peer show flag: $1${RESET}" >&2
                return 1 ;;
        esac
    done
    local messages
    _mailbox_read_json_or_error "$json" || return $?
    messages="$MAILBOX_MESSAGES"
    message="$(jq --arg id "$id" '[.[] | select(.id == $id)][0] // empty' <<< "$messages")"
    if [[ -z "$message" ]]; then
        echo -e "${RED}Unknown message: '$id'${RESET}" >&2
        return 1
    fi
    if $json; then
        jq '.' <<< "$message"
    else
        jq '.' <<< "$message" | _peer_print_human
    fi
}

_peer_cmd_ack() {
    local id="${1:-}" as_identity="" json=false identity messages result updated now rc=0 updated_message=""
    [[ -n "$id" ]] || { echo -e "${RED}Usage: cctrl peer ack <message-id> [--as NAME] [--json]${RESET}" >&2; return 64; }
    shift
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --as)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--as needs a peer name" || echo -e "${RED}--as needs a peer name${RESET}" >&2; return 64; }
                as_identity="$2"; shift 2 ;;
            --json)
                json=true; shift ;;
            *)
                $json && _json_error "validation" "Unknown peer ack flag: $1" || echo -e "${RED}Unknown peer ack flag: $1${RESET}" >&2
                return 64 ;;
        esac
    done
    _mailbox_resolve_identity_for_mode "$as_identity" "$json" || return $?
    identity="$MAILBOX_RESOLVED_IDENTITY"

    _mailbox_lock_acquire || return 1
    if ! {
        _mailbox_init
        _mailbox_read_json_or_error "$json" || rc=$?
        if [[ $rc -ne 0 ]]; then
            :
        else
        messages="$MAILBOX_MESSAGES"
        result="$(jq -r --arg id "$id" --arg who "$identity" '
            ([.[] | select(.id == $id)][0]) as $m
            | if $m == null then "missing"
              elif $m.to != $who then "forbidden"
              elif $m.status == "acked" then "noop"
              elif $m.status == "queued" then "queued"
              elif $m.status == "delivered" then "ack"
              else "invalid:" + ($m.status // "unknown")
              end
        ' <<< "$messages")"
        case "$result" in
            missing)
                $json && _json_error "validation" "Unknown message: $id" || echo -e "${RED}Unknown message: '$id'${RESET}" >&2
                rc=64 ;;
            forbidden)
                $json && _json_error "validation" "Message '$id' is not addressed to '$identity'." || echo -e "${RED}Message '$id' is not addressed to '$identity'.${RESET}" >&2
                rc=64 ;;
            queued)
                $json && _json_error "validation" "Message '$id' is still queued; receive it first (cctrl peer recv)." || echo -e "${RED}Message '$id' is still queued; receive it first (cctrl peer recv).${RESET}" >&2
                rc=64 ;;
            invalid:*)
                $json && _json_error "validation" "Message '$id' cannot be acked from status '${result#invalid:}'." || echo -e "${RED}Message '$id' cannot be acked from status '${result#invalid:}'.${RESET}" >&2
                rc=64 ;;
            noop)
                updated_message="$(jq --arg id "$id" '[.[] | select(.id == $id)][0]' <<< "$messages")"
                rc=0 ;;
            ack)
                now="$(_peer_now_utc)"
                updated="$(jq --arg id "$id" --arg who "$identity" --arg now "$now" '
                    map(
                      if .id == $id then
                        .status = "acked"
                        | .updated_at = $now
                        | .acked_at = $now
                        | .history = ((.history // []) + [{at: $now, status: "acked", by: $who}])
                      else . end
                    )
                ' <<< "$messages")"
                _mailbox_rewrite_json_locked "$updated"
                updated_message="$(jq --arg id "$id" '[.[] | select(.id == $id)][0]' <<< "$updated")"
                rc=0 ;;
        esac
        fi
    }; then
        rc=1
    fi
    _mailbox_lock_release
    [[ $rc -eq 0 ]] || return $rc
    if $json; then
        jq -n --argjson message "$updated_message" '{message:$message,status:$message.status}'
    else
        echo -e "${GREEN}Acked message: $id${RESET}"
    fi
}

_peer_cmd_check() {
    local as_identity="" json=false exit_on_empty=false identity messages queued delivered oldest_age
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --as)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--as needs a peer name" || echo -e "${RED}--as needs a peer name${RESET}" >&2; return 64; }
                as_identity="$2"; shift 2 ;;
            --json)
                json=true; shift ;;
            --exit-on-empty)
                exit_on_empty=true; shift ;;
            *)
                $json && _json_error "validation" "Unknown peer check flag: $1" || echo -e "${RED}Unknown peer check flag: $1${RESET}" >&2
                return 64 ;;
        esac
    done
    _mailbox_resolve_identity_for_mode "$as_identity" "$json" || return $?
    identity="$MAILBOX_RESOLVED_IDENTITY"
    _mailbox_read_json_or_error "$json" || return $?
    messages="$MAILBOX_MESSAGES"
    queued="$(jq -r --arg who "$identity" '[.[] | select(.to == $who and .status == "queued")] | length' <<< "$messages")"
    delivered="$(jq -r --arg who "$identity" '[.[] | select(.to == $who and .status == "delivered")] | length' <<< "$messages")"
    oldest_age="$(jq -r --arg who "$identity" '
        [ .[] | select(.to == $who and .status == "queued") | .created_at ]
        | if length == 0 then null
          else ((now - (min | fromdateiso8601)) | floor)
          end
    ' <<< "$messages")"
    if $json; then
        jq -n --arg peer "$identity" --argjson queued "$queued" --argjson delivered "$delivered" --argjson age "$oldest_age" \
            '{peer:$peer,queued:$queued,delivered_unacked:$delivered,oldest_queued_age_seconds:$age}'
    else
        printf 'Peer: %s\nQueued: %s\nDelivered unacked: %s\nOldest queued age seconds: %s\n' "$identity" "$queued" "$delivered" "$oldest_age"
    fi
    if $exit_on_empty && (( queued == 0 && delivered == 0 )); then
        return 2
    fi
}

_peer_cmd_recv() {
    local as_identity="" status_csv="" json=false exit_on_empty=false identity statuses messages selected_id selected updated rc=0
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --as)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--as needs a peer name" || echo -e "${RED}--as needs a peer name${RESET}" >&2; return 64; }
                as_identity="$2"; shift 2 ;;
            --status)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--status needs a value" || echo -e "${RED}--status needs a value${RESET}" >&2; return 64; }
                status_csv="$2"; shift 2 ;;
            --json)
                json=true; shift ;;
            --exit-on-empty)
                exit_on_empty=true; shift ;;
            *)
                $json && _json_error "validation" "Unknown peer recv flag: $1" || echo -e "${RED}Unknown peer recv flag: $1${RESET}" >&2
                return 64 ;;
        esac
    done
    _mailbox_resolve_identity_for_mode "$as_identity" "$json" || return $?
    identity="$MAILBOX_RESOLVED_IDENTITY"
    statuses="$(_mailbox_status_filter_json "$status_csv" "queued,delivered")"

    _mailbox_lock_acquire || return 1
    if ! {
        _mailbox_read_json_or_error "$json" || rc=$?
        if [[ $rc -eq 0 ]]; then
            messages="$MAILBOX_MESSAGES"
            selected_id="$(jq -r --arg who "$identity" --argjson statuses "$statuses" '
                def allowed($s): ($statuses | index($s)) != null;
                ([.[] | select(.to == $who and .status == "queued" and allowed("queued"))][0].id)
                // ([.[] | select(.to == $who and .status == "delivered" and allowed("delivered"))][0].id)
                // empty
            ' <<< "$messages")"
            if [[ -z "$selected_id" ]]; then
                selected="null"
            else
                local current_status now
                current_status="$(jq -r --arg id "$selected_id" '[.[] | select(.id == $id)][0].status' <<< "$messages")"
                if [[ "$current_status" == "queued" ]]; then
                    now="$(_peer_now_utc)"
                    updated="$(jq --arg id "$selected_id" --arg who "$identity" --arg now "$now" '
                        map(
                          if .id == $id then
                            .status = "delivered"
                            | .updated_at = $now
                            | .delivered_at = $now
                            | .history = ((.history // []) + [{at: $now, status: "delivered", by: $who}])
                          else . end
                        )
                    ' <<< "$messages")"
                    _mailbox_rewrite_json_locked "$updated"
                    selected="$(jq --arg id "$selected_id" '[.[] | select(.id == $id)][0]' <<< "$updated")"
                else
                    selected="$(jq --arg id "$selected_id" '[.[] | select(.id == $id)][0]' <<< "$messages")"
                fi
            fi
        fi
    }; then
        rc=1
    fi
    _mailbox_lock_release
    [[ $rc -eq 0 ]] || return $rc

    if [[ "$selected" == "null" ]]; then
        if $json; then
            jq -n '{message:null,empty:true}'
        else
            echo "No messages."
        fi
        $exit_on_empty && return 2
        return 0
    fi
    if $json; then
        jq -n --argjson message "$selected" '{message:$message,empty:false}'
    else
        jq '.' <<< "$selected" | _peer_print_human
    fi
}

_peer_nudge_line() {
    local peer="$1" count="$2"
    printf '[cctrl] %s new peer message(s) for %s. Run: cctrl peer recv --as %s --json' "$count" "$peer" "$peer"
}

_peer_has_capability() {
    local peer_json="$1" capability="$2"
    jq -e --arg c "$capability" '(.capabilities // []) | index($c)' <<< "$peer_json" >/dev/null 2>&1
}

_tmux_run_with_timeout() {
    local timeout="${CCTRL_TMUX_TIMEOUT_SECONDS:-5}" pid start now rc tmpout tmperr
    tmpout="$(mktemp)"
    tmperr="$(mktemp)"
    tmux "$@" >"$tmpout" 2>"$tmperr" &
    pid=$!
    start="$(date +%s)"
    while kill -0 "$pid" 2>/dev/null; do
        now="$(date +%s)"
        if (( now - start >= timeout )); then
            kill "$pid" 2>/dev/null || true
            sleep 0.05
            kill -9 "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            TMUX_RUN_OUTPUT="$(cat "$tmpout" 2>/dev/null || true)"
            TMUX_RUN_ERROR="tmux command timed out after ${timeout}s: tmux $*"
            rm -f "$tmpout" "$tmperr"
            return 124
        fi
        sleep 0.05
    done
    wait "$pid"; rc=$?
    TMUX_RUN_OUTPUT="$(cat "$tmpout" 2>/dev/null || true)"
    TMUX_RUN_ERROR="$(cat "$tmperr" 2>/dev/null || true)"
    rm -f "$tmpout" "$tmperr"
    return $rc
}

_tmux_run_stdin_with_timeout() {
    local input="$1" timeout="${CCTRL_TMUX_TIMEOUT_SECONDS:-5}" pid start now rc tmpin tmpout tmperr
    shift
    tmpin="$(mktemp)"
    tmpout="$(mktemp)"
    tmperr="$(mktemp)"
    printf '%s' "$input" > "$tmpin"
    tmux "$@" <"$tmpin" >"$tmpout" 2>"$tmperr" &
    pid=$!
    start="$(date +%s)"
    while kill -0 "$pid" 2>/dev/null; do
        now="$(date +%s)"
        if (( now - start >= timeout )); then
            kill "$pid" 2>/dev/null || true
            sleep 0.05
            kill -9 "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            TMUX_RUN_OUTPUT="$(cat "$tmpout" 2>/dev/null || true)"
            TMUX_RUN_ERROR="tmux command timed out after ${timeout}s: tmux $*"
            rm -f "$tmpin" "$tmpout" "$tmperr"
            return 124
        fi
        sleep 0.05
    done
    wait "$pid"; rc=$?
    TMUX_RUN_OUTPUT="$(cat "$tmpout" 2>/dev/null || true)"
    TMUX_RUN_ERROR="$(cat "$tmperr" 2>/dev/null || true)"
    rm -f "$tmpin" "$tmpout" "$tmperr"
    return $rc
}

_peer_tmux_target_for_delivery() {
    local peer_json="$1" peer target
    peer="$(jq -r '.name' <<< "$peer_json")"
    if ! _peer_has_capability "$peer_json" "tmux"; then
        PEER_DELIVER_STATUS="skipped"
        PEER_DELIVER_REASON="no-tmux-capability"
        return 1
    fi
    target="$(jq -r '.tmux_target // .session // empty' <<< "$peer_json")"
    if [[ -z "$target" ]]; then
        PEER_DELIVER_STATUS="failed"
        PEER_DELIVER_REASON="missing tmux session for $peer"
        return 1
    fi
    if ! command -v tmux >/dev/null 2>&1; then
        PEER_DELIVER_STATUS="failed"
        PEER_DELIVER_REASON="tmux unavailable"
        return 1
    fi
    if ! _tmux_run_with_timeout has-session -t "$target"; then
        PEER_DELIVER_STATUS="failed"
        PEER_DELIVER_REASON="${TMUX_RUN_ERROR:-tmux session not found: $target}"
        [[ -n "$PEER_DELIVER_REASON" ]] || PEER_DELIVER_REASON="tmux session not found: $target"
        return 1
    fi
    PEER_DELIVER_STATUS="ok"
    PEER_DELIVER_REASON=""
    PEER_DELIVER_TARGET="$target"
    return 0
}

_peer_pane_ready_for_delivery() {
    local target="$1" agent="${2:-}" force_busy="${3:-false}" capture
    if ! _tmux_run_with_timeout capture-pane -p -S -15 -t "$target"; then
        PEER_DELIVER_READY_REASON="${TMUX_RUN_ERROR:-capture-pane failed}"
        [[ -n "$PEER_DELIVER_READY_REASON" ]] || PEER_DELIVER_READY_REASON="capture-pane failed"
        return 2
    fi
    capture="$TMUX_RUN_OUTPUT"
    case "$agent" in
        claude)
            if printf '%s\n' "$capture" | grep -E 'Do you want|Do you trust|. 1\.' >/dev/null 2>&1; then
                PEER_DELIVER_READY_REASON="modal prompt visible"
                return 1
            fi
            ;;
        codex)
            if printf '%s\n' "$capture" | grep -E 'Allow command|Approve|y/N' >/dev/null 2>&1; then
                PEER_DELIVER_READY_REASON="modal prompt visible"
                return 1
            fi
            ;;
        *)
            if [[ "$force_busy" != "true" ]]; then
                PEER_DELIVER_READY_REASON="unknown agent readiness"
                return 1
            fi
            ;;
    esac
    PEER_DELIVER_READY_REASON=""
    return 0
}

_peer_tmux_paste() {
    local target="$1" buffer="$2" payload="$3" submit="${4:-true}"
    if ! _tmux_run_stdin_with_timeout "$payload" load-buffer -b "$buffer" -; then
        PEER_DELIVER_REASON="${TMUX_RUN_ERROR:-tmux load-buffer failed}"
        [[ -n "$PEER_DELIVER_REASON" ]] || PEER_DELIVER_REASON="tmux load-buffer failed"
        return 1
    fi
    if ! _tmux_run_with_timeout paste-buffer -b "$buffer" -t "$target"; then
        PEER_DELIVER_REASON="${TMUX_RUN_ERROR:-tmux paste-buffer failed}"
        [[ -n "$PEER_DELIVER_REASON" ]] || PEER_DELIVER_REASON="tmux paste-buffer failed"
        _tmux_run_with_timeout delete-buffer -b "$buffer" >/dev/null 2>&1 || true
        return 1
    fi
    if [[ "$submit" == "true" ]]; then
        if ! _tmux_run_with_timeout send-keys -t "$target" Enter; then
            PEER_DELIVER_REASON="${TMUX_RUN_ERROR:-tmux send-keys failed}"
            [[ -n "$PEER_DELIVER_REASON" ]] || PEER_DELIVER_REASON="tmux send-keys failed"
            _tmux_run_with_timeout delete-buffer -b "$buffer" >/dev/null 2>&1 || true
            return 1
        fi
    fi
    _tmux_run_with_timeout delete-buffer -b "$buffer" >/dev/null 2>&1 || true
    PEER_DELIVER_REASON=""
    return 0
}

_peer_record_nudge_json() {
    local messages="$1" peer="$2" ok="$3" error="$4" now="$5" count_it="${6:-true}"
    jq --arg peer "$peer" --arg now "$now" --arg error "$error" --argjson ok "$ok" --argjson countit "$count_it" '
        map(
          if .to == $peer and .status == "queued" then
            (if $countit then .nudge_count = ((.nudge_count // 0) + 1) else . end)
            | .updated_at = $now
            | (if $countit then .last_nudge_at = $now else . end)
            | .last_nudge_error = (if $error == "" then null else $error end)
            | .history = ((.history // []) + [
                ({at: $now, event: "nudge", ok: $ok, by: "cctrl", adapter: "tmux"}
                 + (if $error == "" then {} else {error: $error} end))
              ])
          else . end
        )
    ' <<< "$messages"
}

_peer_record_inline_json() {
    local messages="$1" id="$2" ok="$3" error="$4" now="$5"
    jq --arg id "$id" --arg now "$now" --arg error "$error" --argjson ok "$ok" '
        map(
          if .id == $id then
            .updated_at = $now
            | .last_nudge_error = (if $error == "" then null else $error end)
            | .history = ((.history // []) + [
                ({at: $now, event: "inline", ok: $ok, by: "cctrl", adapter: "tmux"}
                 + (if $error == "" then {} else {error: $error} end))
              ])
          else . end
        )
    ' <<< "$messages"
}

_peer_message_body_from_json() {
    local messages="$1" id="$2" body sentinel=$'\037'
    body="$(jq -j --arg id "$id" '[.[] | select(.id == $id)][0].body // ""' <<< "$messages"; printf '%s' "$sentinel")"
    PEER_MESSAGE_BODY="${body%$sentinel}"
}

_peer_delivery_result_json() {
    jq -n \
      --arg peer "$PEER_DELIVER_PEER" \
      --arg status "$PEER_DELIVER_STATUS" \
      --arg reason "${PEER_DELIVER_REASON:-}" \
      --arg target "${PEER_DELIVER_TARGET:-}" \
      --arg nudge "${PEER_DELIVER_NUDGE:-}" \
      --arg message_id "${PEER_DELIVER_MESSAGE_ID:-}" \
      --argjson queued "${PEER_DELIVER_QUEUED:-0}" \
      --argjson submitted "${PEER_DELIVER_SUBMITTED:-false}" \
      --argjson dry_run "${PEER_DELIVER_DRY_RUN:-false}" \
      --argjson inline "${PEER_DELIVER_INLINE:-false}" \
      '{
        peer: $peer,
        status: $status,
        queued: $queued,
        submitted: $submitted,
        dry_run: $dry_run,
        inline: $inline
      }
      + (if $reason != "" then {reason: $reason} else {} end)
      + (if $target != "" then {target: $target} else {} end)
      + (if $nudge != "" then {nudge: $nudge} else {} end)
      + (if $message_id != "" then {message_id: $message_id} else {} end)'
}

_peer_print_delivery_human() {
    local result="$1" peer status queued reason
    peer="$(jq -r '.peer' <<< "$result")"
    status="$(jq -r '.status' <<< "$result")"
    queued="$(jq -r '.queued' <<< "$result")"
    reason="$(jq -r '.reason // empty' <<< "$result")"
    case "$status" in
        nudged) echo -e "${GREEN}Nudged $peer${RESET} (${queued} queued)" ;;
        dry-run)
            echo "$(jq -r '.nudge' <<< "$result")"
            ;;
        deferred) echo -e "${YELLOW}Deferred $peer${RESET}: $reason" ;;
        skipped) echo -e "${DIM}Skipped $peer: $reason${RESET}" ;;
        no_messages) echo -e "${DIM}No queued messages for $peer.${RESET}" ;;
        inline) echo -e "${GREEN}Pasted inline message for $peer${RESET}" ;;
        failed) echo -e "${RED}Failed $peer:${RESET} $reason" ;;
        *) echo "$status $peer $reason" ;;
    esac
}

_peer_deliver_one_locked() {
    local peer_json="$1" messages="$2" dry_run="$3" json="$4" no_submit="$5" force_busy="$6" inline_id="$7"
    local peer agent target queued now nudge buffer submit payload result message_body message_to updated recent
    peer="$(jq -r '.name' <<< "$peer_json")"
    agent="$(jq -r '.agent // empty' <<< "$peer_json")"
    PEER_DELIVER_PEER="$peer"
    PEER_DELIVER_TARGET=""
    PEER_DELIVER_REASON=""
    PEER_DELIVER_NUDGE=""
    PEER_DELIVER_MESSAGE_ID="$inline_id"
    PEER_DELIVER_DRY_RUN="$dry_run"
    PEER_DELIVER_INLINE=false
    PEER_DELIVER_SUBMITTED=false

    if [[ -n "$inline_id" ]]; then
        PEER_DELIVER_INLINE=true
        message_to="$(jq -r --arg id "$inline_id" '[.[] | select(.id == $id)][0].to // empty' <<< "$messages")"
        if [[ -z "$message_to" ]]; then
            PEER_DELIVER_STATUS="failed"
            PEER_DELIVER_REASON="unknown message: $inline_id"
            PEER_DELIVER_QUEUED=0
            _peer_delivery_result_json
            return 1
        fi
        if [[ "$message_to" != "$peer" ]]; then
            PEER_DELIVER_STATUS="failed"
            PEER_DELIVER_REASON="message $inline_id is addressed to $message_to"
            PEER_DELIVER_QUEUED=0
            _peer_delivery_result_json
            return 1
        fi
        _peer_message_body_from_json "$messages" "$inline_id"
        message_body="$PEER_MESSAGE_BODY"
        unset PEER_MESSAGE_BODY
        queued="$(jq -r --arg peer "$peer" '[.[] | select(.to == $peer and .status == "queued")] | length' <<< "$messages")"
        PEER_DELIVER_QUEUED="$queued"
        payload="$message_body"
        submit=false
    else
        queued="$(jq -r --arg peer "$peer" '[.[] | select(.to == $peer and .status == "queued")] | length' <<< "$messages")"
        PEER_DELIVER_QUEUED="$queued"
        if (( queued == 0 )); then
            PEER_DELIVER_STATUS="no_messages"
            _peer_delivery_result_json
            return 0
        fi
        nudge="$(_peer_nudge_line "$peer" "$queued")"
        PEER_DELIVER_NUDGE="$nudge"
        payload="$nudge"
        submit=true
        [[ "$no_submit" == "true" ]] && submit=false
    fi

    if [[ "$dry_run" == "true" ]]; then
        PEER_DELIVER_STATUS="dry-run"
        PEER_DELIVER_SUBMITTED="$submit"
        _peer_delivery_result_json
        return 0
    fi

    if ! _peer_tmux_target_for_delivery "$peer_json"; then
        if [[ "$PEER_DELIVER_STATUS" == "failed" ]]; then
            now="$(_peer_now_utc)"
            if [[ -n "$inline_id" ]]; then
                updated="$(_peer_record_inline_json "$messages" "$inline_id" false "$PEER_DELIVER_REASON" "$now")"
            else
                updated="$(_peer_record_nudge_json "$messages" "$peer" false "$PEER_DELIVER_REASON" "$now" false)"
            fi
            _mailbox_rewrite_json_locked "$updated"
            PEER_DELIVER_QUEUED="$queued"
        fi
        _peer_delivery_result_json
        [[ "$PEER_DELIVER_STATUS" == "skipped" ]] && return 0
        return 1
    fi
    target="$PEER_DELIVER_TARGET"

    _peer_pane_ready_for_delivery "$target" "$agent" "$force_busy"
    case "$?" in
        1)
            PEER_DELIVER_STATUS="deferred"
            PEER_DELIVER_REASON="$PEER_DELIVER_READY_REASON"
            _peer_delivery_result_json
            return 0 ;;
        2)
            PEER_DELIVER_STATUS="failed"
            PEER_DELIVER_REASON="$PEER_DELIVER_READY_REASON"
            now="$(_peer_now_utc)"
            if [[ -n "$inline_id" ]]; then
                updated="$(_peer_record_inline_json "$messages" "$inline_id" false "$PEER_DELIVER_REASON" "$now")"
            else
                updated="$(_peer_record_nudge_json "$messages" "$peer" false "$PEER_DELIVER_REASON" "$now" false)"
            fi
            _mailbox_rewrite_json_locked "$updated"
            _peer_delivery_result_json
            return 1 ;;
    esac

    if [[ -z "$inline_id" ]]; then
        recent="$(jq -r --arg peer "$peer" --arg now "$(_peer_now_utc)" '
            [ .[] | select(.to == $peer and .status == "queued") ] as $queued
            | if ($queued | length) == 0 then 0
              elif all($queued[]; (.last_nudge_at // "") == $now) then 1
              else 0
              end
        ' <<< "$messages")"
        if (( recent > 0 )); then
            PEER_DELIVER_STATUS="skipped"
            PEER_DELIVER_REASON="recently nudged"
            _peer_delivery_result_json
            return 0
        fi
    fi

    if [[ -n "$inline_id" ]]; then
        buffer="cctrl-inline-${peer}-$(date +%s)"
    else
        buffer="cctrl-nudge-${peer}-$(date +%s)"
    fi
    if ! _peer_tmux_paste "$target" "$buffer" "$payload" "$submit"; then
        PEER_DELIVER_STATUS="failed"
        now="$(_peer_now_utc)"
        if [[ -n "$inline_id" ]]; then
            updated="$(_peer_record_inline_json "$messages" "$inline_id" false "$PEER_DELIVER_REASON" "$now")"
        else
            updated="$(_peer_record_nudge_json "$messages" "$peer" false "$PEER_DELIVER_REASON" "$now" true)"
        fi
        _mailbox_rewrite_json_locked "$updated"
        _peer_delivery_result_json
        return 1
    fi

    now="$(_peer_now_utc)"
    if [[ -n "$inline_id" ]]; then
        PEER_DELIVER_STATUS="inline"
        updated="$(_peer_record_inline_json "$messages" "$inline_id" true "" "$now")"
    else
        PEER_DELIVER_STATUS="nudged"
        updated="$(_peer_record_nudge_json "$messages" "$peer" true "" "$now" true)"
        PEER_DELIVER_SUBMITTED="$submit"
    fi
    _mailbox_rewrite_json_locked "$updated"
    _peer_delivery_result_json
}

_peer_cmd_deliver() {
    local target="" all=false dry_run=false json=false no_submit=false force_busy=false inline_id="" a
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)
                all=true; shift ;;
            --dry-run)
                dry_run=true; shift ;;
            --json)
                json=true; shift ;;
            --no-submit)
                no_submit=true; shift ;;
            --force-busy)
                force_busy=true; shift ;;
            --inline)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--inline needs a message id" || echo -e "${RED}--inline needs a message id${RESET}" >&2; return 64; }
                inline_id="$2"; shift 2 ;;
            -*)
                $json && _json_error "validation" "Unknown peer deliver flag: $1" || echo -e "${RED}Unknown peer deliver flag: $1${RESET}" >&2
                return 64 ;;
            *)
                if [[ -n "$target" ]]; then
                    $json && _json_error "validation" "Only one peer target is allowed" || echo -e "${RED}Only one peer target is allowed.${RESET}" >&2
                    return 64
                fi
                target="$1"; shift ;;
        esac
    done
    if $all && [[ -n "$target" ]]; then
        $json && _json_error "validation" "Use either --all or a peer target, not both." || echo -e "${RED}Use either --all or a peer target, not both.${RESET}" >&2
        return 64
    fi
    if $all && [[ -n "$inline_id" ]]; then
        $json && _json_error "validation" "--inline cannot be combined with --all" || echo -e "${RED}--inline cannot be combined with --all.${RESET}" >&2
        return 64
    fi
    if [[ -z "$target" && "$all" != "true" && -z "$inline_id" ]]; then
        $json && _json_error "validation" "Usage: cctrl peer deliver <peer|--all> [--dry-run] [--json] [--no-submit] [--inline ID] [--force-busy]" || echo -e "${RED}Usage: cctrl peer deliver <peer|--all> [--dry-run] [--json] [--no-submit] [--inline ID] [--force-busy]${RESET}" >&2
        return 64
    fi

    local messages peer_json results="[]" result rc=0 lock_rc=0 recipients inline_to json_ok=true
    _mailbox_lock_acquire || return 1
    if ! {
        _mailbox_read_json_or_error "$json" || lock_rc=$?
        if [[ $lock_rc -eq 0 ]]; then
            messages="$MAILBOX_MESSAGES"
            if [[ -n "$inline_id" && -z "$target" ]]; then
                inline_to="$(jq -r --arg id "$inline_id" '[.[] | select(.id == $id)][0].to // empty' <<< "$messages")"
                if [[ -z "$inline_to" ]]; then
                    PEER_DELIVER_PEER=""
                    PEER_DELIVER_STATUS="failed"
                    PEER_DELIVER_REASON="unknown message: $inline_id"
                    PEER_DELIVER_TARGET=""
                    PEER_DELIVER_NUDGE=""
                    PEER_DELIVER_MESSAGE_ID="$inline_id"
                    PEER_DELIVER_QUEUED=0
                    PEER_DELIVER_SUBMITTED=false
                    PEER_DELIVER_DRY_RUN="$dry_run"
                    PEER_DELIVER_INLINE=true
                    result="$(_peer_delivery_result_json)"
                    results="$(jq --argjson r "$result" '. + [$r]' <<< "$results")"
                    rc=1
                else
                    target="$inline_to"
                fi
            fi
            if [[ $rc -eq 0 ]]; then
                if $all; then
                    recipients="$(jq -r '[.[] | select(.status == "queued") | .to] | unique[]' <<< "$messages")"
                    if [[ -z "$recipients" ]]; then
                        results="[]"
                    else
                        while IFS= read -r target; do
                            [[ -n "$target" ]] || continue
                            if ! peer_json="$(_peer_resolve_json "$target" 2>/dev/null)"; then
                                PEER_DELIVER_PEER="$target"
                                PEER_DELIVER_STATUS="skipped"
                                PEER_DELIVER_REASON="unknown-peer"
                                PEER_DELIVER_TARGET=""
                                PEER_DELIVER_NUDGE=""
                                PEER_DELIVER_MESSAGE_ID=""
                                PEER_DELIVER_QUEUED="$(jq -r --arg peer "$target" '[.[] | select(.to == $peer and .status == "queued")] | length' <<< "$messages")"
                                PEER_DELIVER_SUBMITTED=false
                                PEER_DELIVER_DRY_RUN="$dry_run"
                                PEER_DELIVER_INLINE=false
                                result="$(_peer_delivery_result_json)"
                            else
                                result="$(_peer_deliver_one_locked "$peer_json" "$messages" "$dry_run" "$json" "$no_submit" "$force_busy" "")" || rc=1
                                messages="$(_mailbox_read_json)"
                            fi
                            results="$(jq --argjson r "$result" '. + [$r]' <<< "$results")"
                        done <<< "$recipients"
                    fi
                elif [[ $rc -eq 0 ]]; then
                    if ! peer_json="$(_peer_resolve_json "$target" 2>/dev/null)"; then
                        $json && _json_error "unknown-peer" "Unknown peer: $target" || _mailbox_require_peer "peer" "$target" false
                        rc=66
                    else
                        result="$(_peer_deliver_one_locked "$peer_json" "$messages" "$dry_run" "$json" "$no_submit" "$force_busy" "$inline_id")" || rc=1
                        results="$(jq --argjson r "$result" '. + [$r]' <<< "$results")"
                    fi
                fi
            fi
        else
            rc=$lock_rc
        fi
    }; then
        rc=1
    fi
    _mailbox_lock_release
    [[ $rc -eq 66 ]] && return 66
    [[ $rc -eq 65 ]] && return 65
    [[ $rc -ne 0 ]] && json_ok=false
    if $json; then
        jq -n --argjson ok "$json_ok" --argjson results "$results" '{ok:$ok,results:$results}'
    else
        jq -c '.[]' <<< "$results" | while IFS= read -r result; do
            _peer_print_delivery_human "$result"
        done
    fi
    return $rc
}

_duration_to_seconds() {
    local value="$1" number unit
    if [[ "$value" =~ ^([0-9]+)([smhd]?)$ ]]; then
        number="${BASH_REMATCH[1]}"
        unit="${BASH_REMATCH[2]:-s}"
        case "$unit" in
            s|"") DURATION_SECONDS="$number" ;;
            m) DURATION_SECONDS=$((number * 60)) ;;
            h) DURATION_SECONDS=$((number * 60 * 60)) ;;
            d) DURATION_SECONDS=$((number * 24 * 60 * 60)) ;;
            *) return 1 ;;
        esac
        return 0
    fi
    return 1
}

_peer_now_epoch() {
    jq -nr --arg ts "$(_peer_now_utc)" '$ts | fromdateiso8601 | floor'
}

_peer_json_bool() {
    [[ "${1:-false}" == "true" ]] && printf 'true' || printf 'false'
}

_peer_backoff_state_json() {
    local messages="$1" peer="$2" fail_threshold="$3" backoff_seconds="$4" now_epoch="$5"
    jq -n \
      --argjson messages "$messages" \
      --arg peer "$peer" \
      --argjson threshold "$fail_threshold" \
      --argjson backoff "$backoff_seconds" \
      --argjson now "$now_epoch" '
        def epoch($ts): if $ts == null or $ts == "" then null else try ($ts | fromdateiso8601 | floor) catch null end;
        ([ $messages[]
          | select(.to == $peer and .status == "queued")
          | (.history // [])[]?
          | select(.event == "nudge")
          | {at, ok}
        ] | sort_by(.at) | reverse) as $events
        | ($events | reduce .[] as $event (
            {count: 0, last_failed_at: null, stopped: false};
            if .stopped then .
            elif $event.ok == false then
              .count = (.count + 1)
              | .last_failed_at = (.last_failed_at // $event.at)
            elif $event.ok == true then
              .stopped = true
            else .
            end
          )) as $state
        | (epoch($state.last_failed_at)) as $last_failed_epoch
        | {
            consecutive_failed_nudges: $state.count,
            last_failed_nudge_at: $state.last_failed_at,
            backoff_active: (
              $state.count >= $threshold
              and $last_failed_epoch != null
              and (($now - $last_failed_epoch) < $backoff)
            )
          }'
}

_peer_status_summary_json() {
    local peers_doc="$1" messages="$2" fail_threshold="$3" backoff_seconds="$4" now_epoch="$5"
    jq -n \
      --argjson doc "$peers_doc" \
      --argjson messages "$messages" \
      --argjson threshold "$fail_threshold" \
      --argjson backoff "$backoff_seconds" \
      --argjson now "$now_epoch" \
      --arg mailbox "$MESSAGES_FILE" '
        def epoch($ts): if $ts == null or $ts == "" then null else try ($ts | fromdateiso8601 | floor) catch null end;
        def transports($peer):
          ([ if (($peer.capabilities // []) | index("tmux")) then "tmux" else empty end,
             if (($peer.capabilities // []) | index("polling")) then "polling" else empty end,
             "mcp"
          ] | unique);
        def fail_state($name):
          ([ $messages[]
            | select(.to == $name and .status == "queued")
            | (.history // [])[]?
            | select(.event == "nudge")
            | {at, ok}
          ] | sort_by(.at) | reverse) as $events
          | ($events | reduce .[] as $event (
              {count: 0, last_failed_at: null, stopped: false};
              if .stopped then .
              elif $event.ok == false then
                .count = (.count + 1)
                | .last_failed_at = (.last_failed_at // $event.at)
              elif $event.ok == true then
                .stopped = true
              else .
              end
            )) as $state
          | (epoch($state.last_failed_at)) as $last_failed_epoch
          | {
              consecutive_failed_nudges: $state.count,
              last_failed_nudge_at: $state.last_failed_at,
              backoff_active: (
                $state.count >= $threshold
                and $last_failed_epoch != null
                and (($now - $last_failed_epoch) < $backoff)
              )
            };
        def peer_summary($peer):
          ($peer.name) as $name
          | ([ $messages[] | select(.to == $name and .status == "queued") ]) as $queued
          | ([ $messages[] | select(.to == $name and .status == "delivered") ]) as $delivered
          | (fail_state($name)) as $fail
          | {
              name: $name,
              source: ($peer.source // null),
              agent: ($peer.agent // null),
              host: ($peer.host // null),
              dir: ($peer.dir // null),
              session: ($peer.session // null),
              tmux_target: ($peer.tmux_target // null),
              capabilities: ($peer.capabilities // []),
              transports: transports($peer),
              queued: ($queued | length),
              delivered_unacked: ($delivered | length),
              oldest_queued_age_seconds: (
                [ $queued[] | epoch(.created_at) | select(. != null) ]
                | if length == 0 then null else ($now - min) end
              ),
              last_nudge_at: ([ $queued[] | .last_nudge_at // empty ] | max // null),
              last_nudge_error: ([ $queued[] | .last_nudge_error // empty ] | last // null),
              consecutive_failed_nudges: $fail.consecutive_failed_nudges,
              last_failed_nudge_at: $fail.last_failed_nudge_at,
              nudge_failing: $fail.backoff_active
            };
        ([ ($doc.peers // [])[] | peer_summary(.) ]) as $peers
        | {
            checked_at: (now | todateiso8601),
            mailbox: $mailbox,
            totals: {
              queued: ([ $messages[] | select(.status == "queued") ] | length),
              delivered_unacked: ([ $messages[] | select(.status == "delivered") ] | length)
            },
            transports: {
              tmux: ([ $peers[] | select((.transports | index("tmux")) != null) ] | length),
              polling: ([ $peers[] | select((.transports | index("polling")) != null) ] | length),
              mcp: ($peers | length)
            },
            nudge_failing: [ $peers[] | select(.nudge_failing) | .name ],
            peers: $peers
          }'
}

_peer_cmd_status() {
    local json=false fail_threshold=3 backoff_seconds=600 backoff_arg="10m" peers_doc messages now_epoch summary
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)
                json=true; shift ;;
            --fail-threshold)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--fail-threshold needs a value" || echo -e "${RED}--fail-threshold needs a value${RESET}" >&2; return 64; }
                fail_threshold="$2"; shift 2 ;;
            --backoff)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--backoff needs a duration" || echo -e "${RED}--backoff needs a duration${RESET}" >&2; return 64; }
                backoff_arg="$2"; shift 2 ;;
            *)
                $json && _json_error "validation" "Unknown peer status flag: $1" || echo -e "${RED}Unknown peer status flag: $1${RESET}" >&2
                return 64 ;;
        esac
    done
    [[ "$fail_threshold" =~ ^[0-9]+$ ]] || { $json && _json_error "validation" "fail threshold must be a number" || echo -e "${RED}fail threshold must be a number${RESET}" >&2; return 64; }
    _duration_to_seconds "$backoff_arg" || { $json && _json_error "validation" "Invalid duration: $backoff_arg" || echo -e "${RED}Invalid duration: $backoff_arg${RESET}" >&2; return 64; }
    backoff_seconds="$DURATION_SECONDS"
    unset DURATION_SECONDS
    peers_doc="$(_peer_all_json)" || return 1
    _mailbox_read_json_or_error "$json" || return $?
    messages="$MAILBOX_MESSAGES"
    now_epoch="$(_peer_now_epoch)"
    summary="$(_peer_status_summary_json "$peers_doc" "$messages" "$fail_threshold" "$backoff_seconds" "$now_epoch")"
    if $json; then
        jq '.' <<< "$summary"
    else
        jq -r '
          "Queued: \(.totals.queued)",
          "Delivered unacked: \(.totals.delivered_unacked)",
          "Transports: tmux=\(.transports.tmux) polling=\(.transports.polling) mcp=\(.transports.mcp)",
          "Nudge failing: \((.nudge_failing | join(", ")) // "")",
          "",
          (.peers[] | "\(.name): queued=\(.queued) delivered=\(.delivered_unacked) transports=\(.transports | join(","))")
        ' <<< "$summary"
    fi
}

_peer_stale_recipients_json() {
    local messages="$1" older_seconds="$2" now_epoch="$3"
    jq -c --argjson older "$older_seconds" --argjson now "$now_epoch" '
        [ .[]
          | select(.status == "queued")
          | select(
              (.last_nudge_at // "") == ""
              or ((try ((.last_nudge_at | fromdateiso8601 | floor)) catch 0) as $last | ($now - $last) >= $older)
            )
          | .to
        ] | unique
    ' <<< "$messages"
}

_peer_delivered_stale_json() {
    local messages="$1" older_seconds="$2" now_epoch="$3"
    jq -c --argjson older "$older_seconds" --argjson now "$now_epoch" '
        [ .[]
          | select(.status == "delivered")
          | ((.delivered_at // .updated_at // .created_at // "") | try fromdateiso8601 catch null) as $seen
          | select($seen != null and (($now - ($seen | floor)) >= $older))
        ]
    ' <<< "$messages"
}

_peer_manual_result_json() {
    jq -n \
      --arg peer "${PEER_DELIVER_PEER:-}" \
      --arg status "${PEER_DELIVER_STATUS:-skipped}" \
      --arg reason "${PEER_DELIVER_REASON:-}" \
      --argjson queued "${PEER_DELIVER_QUEUED:-0}" \
      --argjson dry_run "${PEER_DELIVER_DRY_RUN:-false}" \
      '{peer:$peer,status:$status,queued:$queued,dry_run:$dry_run}
       + (if $reason != "" then {reason:$reason} else {} end)'
}

_peer_orchestrate_recipients_locked() {
    local messages="$1" recipients_json="$2" dry_run="$3" no_submit="$4" force_busy="$5" respect_backoff="$6" fail_threshold="$7" backoff_seconds="$8" polling_skip="$9"
    local results="[]" result target peer_json state now_epoch queued rc=0
    now_epoch="$(_peer_now_epoch)"
    while IFS= read -r target; do
        [[ -n "$target" ]] || continue
        if ! peer_json="$(_peer_resolve_json "$target" 2>/dev/null)"; then
            PEER_DELIVER_PEER="$target"
            PEER_DELIVER_STATUS="skipped"
            PEER_DELIVER_REASON="unknown-peer"
            PEER_DELIVER_QUEUED="$(jq -r --arg peer "$target" '[.[] | select(.to == $peer and .status == "queued")] | length' <<< "$messages")"
            PEER_DELIVER_DRY_RUN="$dry_run"
            result="$(_peer_manual_result_json)"
        else
            target="$(jq -r '.name' <<< "$peer_json")"
            queued="$(jq -r --arg peer "$target" '[.[] | select(.to == $peer and .status == "queued")] | length' <<< "$messages")"
            if [[ "$polling_skip" == "true" ]] && ! _peer_has_capability "$peer_json" "tmux"; then
                PEER_DELIVER_PEER="$target"
                PEER_DELIVER_STATUS="polling"
                PEER_DELIVER_REASON="no-tmux-capability"
                PEER_DELIVER_QUEUED="$queued"
                PEER_DELIVER_DRY_RUN="$dry_run"
                result="$(_peer_manual_result_json)"
            elif [[ "$respect_backoff" == "true" ]]; then
                state="$(_peer_backoff_state_json "$messages" "$target" "$fail_threshold" "$backoff_seconds" "$now_epoch")"
                if [[ "$(jq -r '.backoff_active' <<< "$state")" == "true" ]]; then
                    PEER_DELIVER_PEER="$target"
                    PEER_DELIVER_STATUS="backoff"
                    PEER_DELIVER_REASON="consecutive nudge failures: $(jq -r '.consecutive_failed_nudges' <<< "$state")"
                    PEER_DELIVER_QUEUED="$queued"
                    PEER_DELIVER_DRY_RUN="$dry_run"
                    result="$(_peer_manual_result_json)"
                else
                    result="$(_peer_deliver_one_locked "$peer_json" "$messages" "$dry_run" true "$no_submit" "$force_busy" "")" || rc=1
                    messages="$(_mailbox_read_json)"
                fi
            else
                result="$(_peer_deliver_one_locked "$peer_json" "$messages" "$dry_run" true "$no_submit" "$force_busy" "")" || rc=1
                messages="$(_mailbox_read_json)"
            fi
        fi
        results="$(jq --argjson r "$result" '. + [$r]' <<< "$results")"
    done < <(jq -r '.[]' <<< "$recipients_json")
    PEER_ORCH_RESULTS="$results"
    PEER_ORCH_MESSAGES="$messages"
    PEER_ORCH_RC="$rc"
}

_peer_cmd_nudge() {
    local target="" stale=false older_arg="15m" older_seconds=900 dry_run=false json=false no_submit=false force_busy=false target_peer_json=""
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stale)
                stale=true; shift ;;
            --older-than)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--older-than needs a duration" || echo -e "${RED}--older-than needs a duration${RESET}" >&2; return 64; }
                older_arg="$2"; shift 2 ;;
            --dry-run)
                dry_run=true; shift ;;
            --json)
                json=true; shift ;;
            --no-submit)
                no_submit=true; shift ;;
            --force-busy)
                force_busy=true; shift ;;
            -*)
                $json && _json_error "validation" "Unknown peer nudge flag: $1" || echo -e "${RED}Unknown peer nudge flag: $1${RESET}" >&2
                return 64 ;;
            *)
                if [[ -n "$target" ]]; then
                    $json && _json_error "validation" "Only one peer target is allowed" || echo -e "${RED}Only one peer target is allowed.${RESET}" >&2
                    return 64
                fi
                target="$1"; shift ;;
        esac
    done
    if [[ -z "$target" && "$stale" != "true" ]]; then
        $json && _json_error "validation" "Usage: cctrl peer nudge <peer>|--stale [--older-than 15m]" || echo -e "${RED}Usage: cctrl peer nudge <peer>|--stale [--older-than 15m]${RESET}" >&2
        return 64
    fi
    _duration_to_seconds "$older_arg" || { $json && _json_error "validation" "Invalid duration: $older_arg" || echo -e "${RED}Invalid duration: $older_arg${RESET}" >&2; return 64; }
    older_seconds="$DURATION_SECONDS"
    unset DURATION_SECONDS
    if [[ -n "$target" ]]; then
        if ! target_peer_json="$(_peer_resolve_json "$target" 2>/dev/null)"; then
            $json && _json_error "unknown-peer" "Unknown peer: $target" || _mailbox_require_peer "peer" "$target" false
            return 66
        fi
        target="$(jq -r '.name' <<< "$target_peer_json")"
    fi

    local messages recipients delivered results rc=0 lock_rc=0 now_epoch json_ok=true
    now_epoch="$(_peer_now_epoch)"
    _mailbox_lock_acquire || return 1
    if ! {
        _mailbox_read_json_or_error "$json" || lock_rc=$?
        if [[ $lock_rc -eq 0 ]]; then
            messages="$MAILBOX_MESSAGES"
            if [[ "$stale" == "true" ]]; then
                recipients="$(_peer_stale_recipients_json "$messages" "$older_seconds" "$now_epoch")"
                if [[ -n "$target" ]]; then
                    recipients="$(jq -c --arg t "$target" '[ .[] | select(. == $t) ]' <<< "$recipients")"
                fi
            else
                recipients="$(jq -cn --arg t "$target" '[$t]')"
            fi
            delivered="$(_peer_delivered_stale_json "$messages" "$older_seconds" "$now_epoch")"
            _peer_orchestrate_recipients_locked "$messages" "$recipients" "$dry_run" "$no_submit" "$force_busy" false 3 600 false
            results="$PEER_ORCH_RESULTS"
            messages="$PEER_ORCH_MESSAGES"
            rc="$PEER_ORCH_RC"
            unset PEER_ORCH_RESULTS PEER_ORCH_MESSAGES PEER_ORCH_RC
        else
            rc=$lock_rc
        fi
    }; then
        rc=1
    fi
    _mailbox_lock_release
    [[ $rc -eq 66 ]] && return 66
    [[ $rc -eq 65 ]] && return 65
    [[ $rc -ne 0 ]] && json_ok=false
    if $json; then
        jq -n --argjson ok "$json_ok" --argjson results "${results:-[]}" --argjson delivered "${delivered:-[]}" --argjson older "$older_seconds" \
            '{ok:$ok,older_than_seconds:$older,results:$results,delivered_unacked_stale:$delivered}'
    else
        jq -c '.[]' <<< "${results:-[]}" | while IFS= read -r result; do
            _peer_print_delivery_human "$result"
        done
        if [[ "$(jq -r 'length' <<< "${delivered:-[]}")" != "0" ]]; then
            echo -e "${YELLOW}Delivered but unacked messages past threshold:${RESET}"
            jq '.' <<< "$delivered" | _mailbox_print_messages_human
        fi
    fi
    return $rc
}

_watch_lock_path() {
    printf '%s/watch.lock.d' "$PEER_DATA_DIR"
}

_watch_lock_acquire() {
    mkdir -p "$PEER_DATA_DIR"
    local lock_path pid
    lock_path="$(_watch_lock_path)"
    if mkdir "$lock_path" 2>/dev/null; then
        printf '%s\n' "$$" > "$lock_path/pid"
        date -u +"%Y-%m-%dT%H:%M:%SZ" > "$lock_path/created_at" 2>/dev/null || true
        WATCH_LOCK_HELD="$lock_path"
        return 0
    fi
    if [[ -f "$lock_path/pid" ]]; then
        pid="$(cat "$lock_path/pid" 2>/dev/null || true)"
        if _pid_alive "$pid"; then
            WATCH_LOCK_PID="$pid"
            return 2
        fi
    fi
    rm -rf "$lock_path" 2>/dev/null || true
    if mkdir "$lock_path" 2>/dev/null; then
        printf '%s\n' "$$" > "$lock_path/pid"
        date -u +"%Y-%m-%dT%H:%M:%SZ" > "$lock_path/created_at" 2>/dev/null || true
        WATCH_LOCK_HELD="$lock_path"
        return 0
    fi
    WATCH_LOCK_PID="unknown"
    return 2
}

_watch_lock_release() {
    [[ -n "${WATCH_LOCK_HELD:-}" ]] || return 0
    rm -rf "$WATCH_LOCK_HELD" 2>/dev/null || true
    unset WATCH_LOCK_HELD
}

_peer_watch_pass() {
    local pass="$1" renudge_seconds="$2" backoff_seconds="$3" fail_threshold="$4" dry_run="$5" force_busy="$6"
    local messages recipients delivered results rc=0 lock_rc=0 now_epoch summary
    now_epoch="$(_peer_now_epoch)"
    _mailbox_lock_acquire || return 1
    if ! {
        _mailbox_read_json_or_error true || lock_rc=$?
        if [[ $lock_rc -eq 0 ]]; then
            messages="$MAILBOX_MESSAGES"
            recipients="$(_peer_stale_recipients_json "$messages" "$renudge_seconds" "$now_epoch")"
            delivered="$(_peer_delivered_stale_json "$messages" "$renudge_seconds" "$now_epoch")"
            _peer_orchestrate_recipients_locked "$messages" "$recipients" "$dry_run" false "$force_busy" true "$fail_threshold" "$backoff_seconds" true
            results="$PEER_ORCH_RESULTS"
            messages="$PEER_ORCH_MESSAGES"
            rc="$PEER_ORCH_RC"
            unset PEER_ORCH_RESULTS PEER_ORCH_MESSAGES PEER_ORCH_RC
        else
            rc=$lock_rc
        fi
    }; then
        rc=1
    fi
    _mailbox_lock_release
    [[ $rc -ne 0 ]] && PEER_WATCH_OK=false || PEER_WATCH_OK=true
    summary="$(jq -n \
        --argjson pass "$pass" \
        --arg checked_at "$(_peer_now_utc)" \
        --argjson ok "$(_peer_json_bool "$PEER_WATCH_OK")" \
        --argjson dry_run "$(_peer_json_bool "$dry_run")" \
        --argjson results "${results:-[]}" \
        --argjson delivered "${delivered:-[]}" \
        '{ok:$ok,pass:$pass,checked_at:$checked_at,dry_run:$dry_run,results:$results,delivered_unacked_stale:$delivered}')"
    PEER_WATCH_PASS="$summary"
    return $rc
}

_peer_cmd_watch() {
    local once=false force=false interval="" max_passes="" renudge_arg="15m" backoff_arg="10m" dry_run=false json=false force_busy=false fail_threshold=3
    local renudge_seconds=900 backoff_seconds=600 pass=0 lock_rc rc=0 summary
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --once)
                once=true; shift ;;
            --force)
                force=true; shift ;;
            --interval)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--interval needs seconds" || echo -e "${RED}--interval needs seconds${RESET}" >&2; return 64; }
                interval="$2"; shift 2 ;;
            --max-passes)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--max-passes needs a number" || echo -e "${RED}--max-passes needs a number${RESET}" >&2; return 64; }
                max_passes="$2"; shift 2 ;;
            --renudge-after)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--renudge-after needs a duration" || echo -e "${RED}--renudge-after needs a duration${RESET}" >&2; return 64; }
                renudge_arg="$2"; shift 2 ;;
            --backoff)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--backoff needs a duration" || echo -e "${RED}--backoff needs a duration${RESET}" >&2; return 64; }
                backoff_arg="$2"; shift 2 ;;
            --fail-threshold)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--fail-threshold needs a number" || echo -e "${RED}--fail-threshold needs a number${RESET}" >&2; return 64; }
                fail_threshold="$2"; shift 2 ;;
            --dry-run)
                dry_run=true; shift ;;
            --json)
                json=true; shift ;;
            --force-busy)
                force_busy=true; shift ;;
            *)
                $json && _json_error "validation" "Unknown peer watch flag: $1" || echo -e "${RED}Unknown peer watch flag: $1${RESET}" >&2
                return 64 ;;
        esac
    done
    [[ -z "$interval" || "$interval" =~ ^[0-9]+$ ]] || { $json && _json_error "validation" "interval must be seconds" || echo -e "${RED}interval must be seconds${RESET}" >&2; return 64; }
    [[ -z "$interval" || "$interval" -gt 0 ]] || { $json && _json_error "validation" "interval must be positive" || echo -e "${RED}interval must be positive${RESET}" >&2; return 64; }
    [[ -z "$max_passes" || "$max_passes" =~ ^[0-9]+$ ]] || { $json && _json_error "validation" "max-passes must be a number" || echo -e "${RED}max-passes must be a number${RESET}" >&2; return 64; }
    [[ "$fail_threshold" =~ ^[0-9]+$ ]] || { $json && _json_error "validation" "fail threshold must be a number" || echo -e "${RED}fail threshold must be a number${RESET}" >&2; return 64; }
    _duration_to_seconds "$renudge_arg" || { $json && _json_error "validation" "Invalid duration: $renudge_arg" || echo -e "${RED}Invalid duration: $renudge_arg${RESET}" >&2; return 64; }
    renudge_seconds="$DURATION_SECONDS"
    _duration_to_seconds "$backoff_arg" || { $json && _json_error "validation" "Invalid duration: $backoff_arg" || echo -e "${RED}Invalid duration: $backoff_arg${RESET}" >&2; return 64; }
    backoff_seconds="$DURATION_SECONDS"
    unset DURATION_SECONDS
    if [[ "$once" != "true" && -z "$interval" ]]; then
        once=true
    fi
    if [[ "$force" == "true" && "$once" != "true" ]]; then
        $json && _json_error "validation" "--force is only valid with --once" || echo -e "${RED}--force is only valid with --once${RESET}" >&2
        return 64
    fi
    if [[ ! ( "$force" == "true" && "$once" == "true" ) ]]; then
        if _watch_lock_acquire; then
            lock_rc=0
        else
            lock_rc=$?
        fi
        if [[ $lock_rc -eq 2 ]]; then
            echo "already running (pid ${WATCH_LOCK_PID:-unknown})" >&2
            return 1
        elif [[ $lock_rc -ne 0 ]]; then
            echo "could not acquire watch lock" >&2
            return 1
        fi
        trap '_watch_lock_release' INT TERM EXIT
    fi
    while true; do
        pass=$((pass + 1))
        _peer_watch_pass "$pass" "$renudge_seconds" "$backoff_seconds" "$fail_threshold" "$dry_run" "$force_busy" || rc=1
        summary="$PEER_WATCH_PASS"
        unset PEER_WATCH_PASS
        if $json; then
            if $once; then jq '.' <<< "$summary"; else jq -c '.' <<< "$summary"; fi
        else
            jq -c '.results[]?' <<< "$summary" | while IFS= read -r result; do
                _peer_print_delivery_human "$result"
            done
        fi
        if $once; then
            break
        fi
        if [[ -n "$max_passes" && "$pass" -ge "$max_passes" ]]; then
            break
        fi
        sleep "$interval"
    done
    _watch_lock_release
    trap - INT TERM EXIT
    return $rc
}

_peer_cmd_gc() {
    local older_arg="" older_seconds=0 status_csv="acked" dry_run=false json=false archive_file="$PEER_DATA_DIR/messages-archive.jsonl"
    _arg_has_json "$@" && json=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --older-than)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--older-than needs a duration" || echo -e "${RED}--older-than needs a duration${RESET}" >&2; return 64; }
                older_arg="$2"; shift 2 ;;
            --status)
                [[ $# -ge 2 ]] || { $json && _json_error "validation" "--status needs a value" || echo -e "${RED}--status needs a value${RESET}" >&2; return 64; }
                status_csv="$2"; shift 2 ;;
            --dry-run)
                dry_run=true; shift ;;
            --json)
                json=true; shift ;;
            *)
                $json && _json_error "validation" "Unknown peer gc flag: $1" || echo -e "${RED}Unknown peer gc flag: $1${RESET}" >&2
                return 64 ;;
        esac
    done
    [[ -n "$older_arg" ]] || { $json && _json_error "validation" "--older-than is required" || echo -e "${RED}--older-than is required${RESET}" >&2; return 64; }
    _duration_to_seconds "$older_arg" || { $json && _json_error "validation" "Invalid duration: $older_arg" || echo -e "${RED}Invalid duration: $older_arg${RESET}" >&2; return 64; }
    older_seconds="$DURATION_SECONDS"
    unset DURATION_SECONDS
    local statuses messages eligible remaining now_epoch count rc=0 lock_rc=0 error=""
    statuses="$(_mailbox_status_filter_json "$status_csv" "")"
    now_epoch="$(_peer_now_epoch)"
    _mailbox_lock_acquire || return 1
    if ! {
        _mailbox_read_json_or_error "$json" || lock_rc=$?
        if [[ $lock_rc -eq 0 ]]; then
            messages="$MAILBOX_MESSAGES"
            eligible="$(jq -c --argjson statuses "$statuses" --argjson now "$now_epoch" --argjson older "$older_seconds" '
                [ .[]
                  | .status as $status
                  | ((.acked_at // .delivered_at // .updated_at // .created_at // "") | try fromdateiso8601 catch null) as $seen
                  | select(($statuses | index($status)) and $seen != null and (($now - ($seen | floor)) >= $older))
                ]
            ' <<< "$messages")"
            count="$(jq -r 'length' <<< "$eligible")"
            if [[ "$dry_run" != "true" && "$count" -gt 0 ]]; then
                mkdir -p "$(dirname "$archive_file")"
                if ! { jq -c '.[]' <<< "$eligible" >> "$archive_file"; } 2>/dev/null; then
                    error="failed to append archive: $archive_file"
                    rc=1
                else
                    remaining="$(jq -c --argjson statuses "$statuses" --argjson now "$now_epoch" --argjson older "$older_seconds" '
                        [ .[]
                          | .status as $status
                          | ((.acked_at // .delivered_at // .updated_at // .created_at // "") | try fromdateiso8601 catch null) as $seen
                          | select((($statuses | index($status)) and $seen != null and (($now - ($seen | floor)) >= $older)) | not)
                        ]
                    ' <<< "$messages")"
                    if ! _mailbox_rewrite_json_locked "$remaining"; then
                        error="failed to rewrite mailbox: $MESSAGES_FILE"
                        rc=1
                    fi
                fi
            fi
        else
            rc=$lock_rc
        fi
    }; then
        rc=1
    fi
    _mailbox_lock_release
    [[ $rc -eq 65 ]] && return 65
    if $json; then
        jq -n --argjson ok "$(_peer_json_bool "$([[ $rc -eq 0 ]] && echo true || echo false)")" --arg error "$error" --argjson dry_run "$(_peer_json_bool "$dry_run")" --argjson older "$older_seconds" --argjson statuses "$statuses" --arg archive "$archive_file" --argjson eligible "${eligible:-[]}" \
            '{ok:$ok,dry_run:$dry_run,older_than_seconds:$older,statuses:$statuses,archive:$archive,eligible_count:($eligible|length),eligible:$eligible}
             + (if $ok then {} else {error:$error} end)'
    else
        if [[ $rc -ne 0 ]]; then
            echo -e "${RED}${error:-peer gc failed}${RESET}" >&2
        else
            echo "Eligible messages: ${count:-0}"
        fi
        if [[ "$dry_run" != "true" && $rc -eq 0 ]]; then
            echo "Archive: $archive_file"
        fi
    fi
    return $rc
}

_peer_doctor_mcp_check() {
    local peer="$1" out
    out="$(printf '%s\n' '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}' | "$SCRIPT_DIR/cctrl" peer mcp --as "$peer" 2>/dev/null || true)"
    if jq -e 'select(.id == 1 and .result.capabilities.tools != null)' <<< "$out" >/dev/null 2>&1; then
