cmd_usage() {
    local weeks="${1:-2}"
    # Strip leading -- if passed as flag
    weeks="${weeks#--}"
    # If it's a named flag, map it; otherwise treat as number
    case "$weeks" in
        [0-9]*) ;;  # already a number
        *)     weeks=2 ;;
    esac

    python3 "$SCRIPT_DIR/lib/usage_costs.py" usage \
        "$SCRIPT_DIR/data/rate-limits.json" \
        "$SCRIPT_DIR/data/rate-limits-history.jsonl" \
        "$PROJECTS_DIR" \
        "$CODEX_SESSIONS_DIR" \
        "$CODEX_ARCHIVED_SESSIONS_DIR" \
        "$weeks"
}

cmd_statusline() {
    local agent="${1:-}" action="${2:-install}"

    case "$agent" in
        claude|claude-code|codex|openai)
            agent="$(_normalize_agent "$agent")" || return 1
            ;;
        install|show|-h|--help|help|"")
            action="${agent:-help}"
            agent="$(_default_agent)"
            agent="$(_normalize_agent "$agent")" || return 1
            ;;
        *)
            echo -e "${RED}Unknown statusline target: $agent${RESET}" >&2
            echo "Usage: cctrl statusline <claude|codex> [install|show]" >&2
            return 1
            ;;
    esac

    case "$action" in
        install)
            if [[ "$agent" == "claude" ]]; then
                mkdir -p "$CLAUDE_DIR"
                [[ -f "$SETTINGS" ]] || echo "{}" > "$SETTINGS"
                local tmp status_cmd
                tmp="$(mktemp)"
                status_cmd="$SCRIPT_DIR/hooks/statusline.sh"
                jq --arg cmd "$status_cmd" '.statusLine = {type: "command", command: $cmd}' "$SETTINGS" > "$tmp" && mv "$tmp" "$SETTINGS"
                echo -e "${GREEN}Installed Claude statusline:${RESET} $status_cmd"
                return 0
            fi

            mkdir -p "$CODEX_DIR"
            local config="$CODEX_DIR/config.toml"
            [[ -f "$config" ]] || touch "$config"
            python3 - "$config" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
line = 'status_line = ["model-with-reasoning", "context-remaining", "context-used", "git-branch", "current-dir", "run-state"]'
text = path.read_text() if path.exists() else ""
lines = text.splitlines()
out = []
in_tui = False
found_tui = False
set_line = False

for raw in lines:
    stripped = raw.strip()
    if stripped.startswith("[") and stripped.endswith("]"):
        if in_tui and not set_line:
            out.append(line)
            set_line = True
        in_tui = stripped == "[tui]"
        found_tui = found_tui or in_tui
        out.append(raw)
        continue
    if in_tui and stripped.startswith("status_line"):
        if not set_line:
            out.append(line)
            set_line = True
        continue
    out.append(raw)

if found_tui:
    if in_tui and not set_line:
        out.append(line)
else:
    if out and out[-1].strip():
        out.append("")
    out.extend(["[tui]", line])

path.write_text("\n".join(out).rstrip() + "\n")
PY
            echo -e "${GREEN}Installed Codex statusline:${RESET} $config"
            echo -e "${DIM}Restart Codex or run /statusline inside Codex to review it.${RESET}"
            ;;
        show)
            if [[ "$agent" == "claude" ]]; then
                if [[ -f "$SETTINGS" ]]; then
                    jq '.statusLine // "not configured"' "$SETTINGS"
                else
                    echo "not configured"
                fi
            else
                if [[ -f "$CODEX_DIR/config.toml" ]]; then
                    awk '
                        /^\[tui\]$/ {in_tui=1; next}
                        /^\[/ && in_tui {exit}
                        in_tui && /^status_line[[:space:]]*=/ {print; found=1}
                        END {if (!found) print "not configured"}
                    ' "$CODEX_DIR/config.toml"
                else
                    echo "not configured"
                fi
            fi
            ;;
        help|-h|--help)
            echo "Usage: cctrl statusline <claude|codex> [install|show]"
            echo ""
            echo "  claude install   Configure ~/.claude/settings.json statusLine command"
            echo "  codex install    Configure ~/.codex/config.toml tui.status_line"
            ;;
        *)
            echo -e "${RED}Unknown statusline action: $action${RESET}" >&2
            return 1
            ;;
    esac
}

# ── Chrome CDP ────────────────────────────────────────────────────────

CHROME_DATA_DIR="$HOME/.chrome-debug"
CHROME_DEFAULT_PORT=9222

_chrome_bin() {
    local candidates=(
        "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
        "/Applications/Google Chrome Canary.app/Contents/MacOS/Google Chrome Canary"
        "/Applications/Chromium.app/Contents/MacOS/Chromium"
    )
    for bin in "${candidates[@]}"; do
        [[ -x "$bin" ]] && { echo "$bin"; return 0; }
    done
    return 1
}

_chrome_cdp_ready() {
    local port="${1:-$CHROME_DEFAULT_PORT}"
    curl -s --max-time 1 "http://localhost:$port/json/version" &>/dev/null
}

cmd_chrome() {
    local port="$CHROME_DEFAULT_PORT"
    local data_dir="$CHROME_DATA_DIR"
    local connect=false
    local kill_first=false
    local status_only=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port|-p) port="$2"; shift 2 ;;
            --data-dir|-d) data_dir="$2"; shift 2 ;;
            --connect|-c) connect=true; shift ;;
            --kill|-k) kill_first=true; shift ;;
            --status|-s) status_only=true; shift ;;
            --help|-h)
                echo -e "${BOLD}cctrl chrome${RESET} — Launch Chrome with CDP remote debugging"
                echo ""
                echo "  cctrl chrome              Kill existing Chrome, launch with CDP on :9222"
                echo "  cctrl chrome --status     Check if CDP is active"
                echo "  cctrl chrome --port 9333  Use a different port"
                echo "  cctrl chrome --connect    Also connect gstack browse to the CDP session"
                echo "  cctrl chrome --kill       Kill Chrome without relaunching"
                echo ""
                echo -e "${DIM}Data dir: $data_dir${RESET}"
                return 0
                ;;
            *) echo -e "${RED}Unknown flag: $1${RESET}"; return 1 ;;
        esac
    done

    if $status_only; then
        if _chrome_cdp_ready "$port"; then
            local version
            version="$(curl -s "http://localhost:$port/json/version" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("Browser","unknown"))' 2>/dev/null)"
            echo -e "${GREEN}CDP active${RESET} on :$port — $version"
            local tabs
            tabs="$(curl -s "http://localhost:$port/json/list" | python3 -c 'import sys,json; print(len(json.load(sys.stdin)))' 2>/dev/null || echo '?')"
            echo -e "${DIM}$tabs tab(s) open${RESET}"
        else
            echo -e "${YELLOW}CDP not active${RESET} on :$port"
        fi
        return 0
    fi

    local chrome_bin
    chrome_bin="$(_chrome_bin)" || {
        echo -e "${RED}No Chrome installation found${RESET}"
        return 1
    }

    if $kill_first && ! $status_only; then
        echo -e "${DIM}Killing Chrome...${RESET}"
        killall "Google Chrome" "Google Chrome Helper" 2>/dev/null || true
        if [[ $# -eq 0 ]] && $kill_first; then
            # --kill alone means just kill, don't relaunch
            sleep 1
            if pgrep -q "Google Chrome"; then
                echo -e "${YELLOW}Chrome still running (force kill may be needed)${RESET}"
            else
                echo -e "${GREEN}Chrome stopped${RESET}"
            fi
            return 0
        fi
    fi

    # Kill existing Chrome (CDP requires being the first instance)
    if pgrep -q "Google Chrome"; then
        echo -e "${DIM}Stopping existing Chrome (CDP needs a fresh launch)...${RESET}"
        killall "Google Chrome" 2>/dev/null || true
        local waited=0
        while pgrep -q "Google Chrome" && [[ $waited -lt 5 ]]; do
            sleep 1
            ((waited++))
        done
        if pgrep -q "Google Chrome"; then
            echo -e "${RED}Chrome didn't stop cleanly. Run: killall -9 'Google Chrome'${RESET}"
            return 1
        fi
    fi

    mkdir -p "$data_dir"

    echo -e "${DIM}Launching Chrome with CDP on :$port${RESET}"
    echo -e "${DIM}Data dir: $data_dir${RESET}"

    nohup "$chrome_bin" \
        --remote-debugging-port="$port" \
        --user-data-dir="$data_dir" \
        '--remote-allow-origins=*' \
        &>/dev/null &

    # Wait for CDP to come up
    local attempts=0
    while ! _chrome_cdp_ready "$port" && [[ $attempts -lt 10 ]]; do
        sleep 1
        ((attempts++))
    done

    if _chrome_cdp_ready "$port"; then
        local version
        version="$(curl -s "http://localhost:$port/json/version" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("Browser","unknown"))' 2>/dev/null)"
        echo -e "${GREEN}CDP ready${RESET} on :$port — $version"

        if $connect; then
            local browse_bin="$HOME/.claude/skills/gstack/browse/dist/browse"
            if [[ -x "$browse_bin" ]]; then
                echo -e "${DIM}Connecting browse...${RESET}"
                "$browse_bin" connect "http://localhost:$port" 2>/dev/null && \
                    echo -e "${GREEN}browse connected${RESET}" || \
                    echo -e "${YELLOW}browse connect failed (try manually: \$B connect http://localhost:$port)${RESET}"
            else
                echo -e "${DIM}browse not found — connect manually in Claude Code${RESET}"
            fi
        fi

        echo -e "\n${DIM}Connect from Claude Code:${RESET}"
        echo -e "  \$B connect http://localhost:$port"
    else
        echo -e "${RED}CDP failed to start after 10s${RESET}"
        echo -e "${DIM}Check: is another Chrome instance still running?${RESET}"
        return 1
    fi
}

# ── Host Registry ────────────────────────────────────────────────────
# Named remote hosts for transparent SSH execution.
# Configured in data/hosts.json. Each entry maps an alias to a hostname.

_hosts_init() {
    mkdir -p "$(dirname "$HOSTS_FILE")"
    [[ -f "$HOSTS_FILE" ]] || echo "{}" > "$HOSTS_FILE"
}

_local_names() {
    # Names that identify THIS machine, used to short-circuit --host to local.
    printf '%s\n' localhost 127.0.0.1 ::1
    local h
    h="$(hostname 2>/dev/null)"; [[ -n "$h" ]] && printf '%s\n%s\n' "$h" "${h%.local}"
    h="$(hostname -s 2>/dev/null)"; [[ -n "$h" ]] && printf '%s\n' "$h"
}

_host_is_local() {
    # True if the given SSH target points at the current machine.
    local target="$1" n
    [[ -z "$target" ]] && return 1
    target="$(printf '%s' "${target%.local}" | tr '[:upper:]' '[:lower:]')"
    while IFS= read -r n; do
        [[ -z "$n" ]] && continue
        n="$(printf '%s' "${n%.local}" | tr '[:upper:]' '[:lower:]')"
        [[ "$target" == "$n" ]] && return 0
    done < <(_local_names)
    return 1
}

_host_lookup() {
    # Look up a host alias; echoes "hostname user" or empty.
    # `local`/`self` are built-in aliases that always resolve to this machine.
    case "$1" in
        local|self) echo "$(hostname) "; return 0 ;;
    esac
    [[ -f "$HOSTS_FILE" ]] || return 0
    local hostname user
    hostname="$(jq -r --arg n "$1" '.[$n].hostname // empty' "$HOSTS_FILE" 2>/dev/null)"
    user="$(jq -r --arg n "$1" '.[$n].user // ""' "$HOSTS_FILE" 2>/dev/null)"
    if [[ -n "$hostname" ]]; then
        echo "$hostname $user"
    fi
    return 0
}

_remote_exec() {
    # Execute a cctrl command on a remote host over SSH.
    # Usage: _remote_exec <host-alias> <args...>
    local host_alias="$1"; shift
    local lookup
    lookup="$(_host_lookup "$host_alias")"
    if [[ -z "$lookup" ]]; then
        echo -e "${RED}Unknown host: '$host_alias'${RESET}" >&2
        echo -e "${DIM}List hosts with: cctrl host list${RESET}" >&2
        return 1
    fi

    local hostname user
    hostname="${lookup%% *}"
    user="${lookup#* }"

    local ssh_target
    if [[ -n "$user" ]]; then
        ssh_target="${user}@${hostname}"
    else
        ssh_target="$hostname"
    fi

    # Decide TTY (-t) and auto-attach behavior based on the command.
    local use_tty=false
    local detach_and_attach=false
    local first_arg="${1:-}"
    case "$first_arg" in
        edit) use_tty=true ;;
        @*)   use_tty=true ;;
        session)
            # `session attach` is interactive; ls/kill are not.
            case "${2:-}" in
                attach|a) use_tty=true ;;
            esac
            ;;
        start|s)
            # Detached start (-d) launches on the remote, then auto-attaches over
            # a second connection. Foreground start is plain interactive.
            local is_detach=false
            for a in "$@"; do
                [[ "$a" == "--" ]] && break
                case "$a" in
                    -d|--detach) is_detach=true; break ;;
                esac
            done
            if $is_detach; then
                detach_and_attach=true
            else
                use_tty=true
            fi
            ;;
    esac

    # Quote each argument for safe SSH transport
    local quoted_args=""
    for arg in "$@"; do
        quoted_args+=" $(printf '%q' "$arg")"
    done

    local ssh_opts=()
    if $use_tty; then
        ssh_opts+=("-t")
    fi

    local env_prefix="CCTRL_HOST_PREFIX=$(printf '%q' "$host_alias")"
    if [[ -n "${CCTRL_AGENT:-}" ]]; then
        env_prefix+=" CCTRL_AGENT=$(printf '%q' "$CCTRL_AGENT")"
    fi

    if $detach_and_attach; then
        # Launch detached on the remote, capture the resolved session name, then
        # attach to that exact session over a TTY connection. Capturing the
        # name (rather than reconstructing the slug) handles auto-increment
        # suffixes and git-root basenames without guessing.
        local launch_out rc
        launch_out="$(ssh "$ssh_target" "source ~/.zprofile 2>/dev/null; CCTRL_EMIT_SESSION=1 $env_prefix cctrl$quoted_args")"
        rc=$?
        # Echo the launch output, minus the machine-readable marker line.
        printf '%s\n' "$launch_out" | grep -v '^CCTRL_SESSION=' || true
        [[ $rc -eq 0 ]] || return $rc
        local remote_session
        remote_session="$(printf '%s\n' "$launch_out" | sed -n 's/^CCTRL_SESSION=//p' | tail -1)"
        if [[ -z "$remote_session" ]]; then
            echo -e "${RED}Could not determine the remote session name; not attaching.${RESET}" >&2
            echo -e "${DIM}List remote sessions with: cctrl --host $host_alias session ls${RESET}" >&2
            return 1
        fi
        echo -e "${DIM}Attaching to remote session: $remote_session${RESET}" >&2
        local sess_q
        sess_q="$(printf '%q' "$remote_session")"
        exec ssh -t "$ssh_target" "source ~/.zprofile 2>/dev/null; tmux attach-session -t $sess_q"
    fi

    echo -e "${DIM}ssh ${ssh_opts[*]+${ssh_opts[*]}} $ssh_target cctrl$quoted_args${RESET}" >&2
    exec ssh ${ssh_opts[@]+"${ssh_opts[@]}"} "$ssh_target" "source ~/.zprofile 2>/dev/null; $env_prefix cctrl$quoted_args"
}

cmd_whoami() {
    # Report this machine's identity and which host aliases resolve to it.
    local cn hn
    cn="$(scutil --get ComputerName 2>/dev/null || true)"
    hn="$(hostname 2>/dev/null)"
    echo -e "${BOLD}This machine${RESET}"
    [[ -n "$cn" ]] && echo -e "  Name:       $cn"
    echo -e "  Hostname:   $hn"
    echo -e "  OS:         $(uname -sr)"

    local -a matches=()
    if [[ -f "$HOSTS_FILE" ]]; then
        local a h
        while IFS=$'\t' read -r a h; do
            [[ -n "$a" ]] && _host_is_local "$h" && matches+=("$a")
        done < <(jq -r 'to_entries[] | "\(.key)\t\(.value.hostname)"' "$HOSTS_FILE" 2>/dev/null)
    fi
    if [[ ${#matches[@]} -gt 0 ]]; then
        echo -e "  Host alias: ${GREEN}${matches[*]}${RESET} ${DIM}(also built-in: local, self)${RESET}"
    else
        echo -e "  Host alias: ${DIM}local, self (built-in)${RESET}"
    fi
    echo -e "${DIM}'cctrl --host <any-of-these> ...' runs locally — no SSH.${RESET}"
}

cmd_host() {
    local action="${1:-list}"
    shift 2>/dev/null || true

    case "$action" in
        add)
            local name="${1:-}" hostname="${2:-}" user="${3:-}"
            if [[ -z "$name" || -z "$hostname" ]]; then
                echo -e "${RED}Usage: cctrl host add <alias> <hostname> [user]${RESET}"
                return 1
            fi
            _hosts_init
            local tmp
            tmp=$(mktemp)
            jq --arg name "$name" --arg hostname "$hostname" --arg user "$user" \
                '. + {($name): {hostname: $hostname, user: $user}}' \
                "$HOSTS_FILE" > "$tmp" && mv "$tmp" "$HOSTS_FILE"
            echo -e "${GREEN}Added host: ${BOLD}$name${RESET}${GREEN} → $hostname${RESET}"
            [[ -n "$user" ]] && echo -e "${DIM}  user=$user${RESET}" || true
            ;;
        list|ls)
            if [[ ! -f "$HOSTS_FILE" ]] || ! jq -e 'length > 0' "$HOSTS_FILE" &>/dev/null; then
                echo -e "${DIM}No hosts registered.${RESET}"
                echo -e "${DIM}Add one with: cctrl host add <alias> <hostname> [user]${RESET}"
                return
            fi
            echo -e "${BOLD}Registered Hosts${RESET}"
            local _name _hostname _user
            while IFS= read -r _name && IFS= read -r _hostname && IFS= read -r _user; do
                local label="$_hostname"
                [[ -n "$_user" ]] && label="${_user}@${_hostname}"
                if _host_is_local "$_hostname"; then
                    echo -e "  ${GREEN}$_name${RESET}  ${DIM}→${RESET}  $label  ${DIM}(this machine — runs locally)${RESET}"
                else
                    echo -e "  ${GREEN}$_name${RESET}  ${DIM}→${RESET}  $label"
                fi
            done < <(jq -r 'to_entries[] | .key, .value.hostname, (.value.user // "")' "$HOSTS_FILE" 2>/dev/null)
            echo -e "  ${DIM}local, self${RESET}  ${DIM}→  this machine (built-in)${RESET}"
            ;;
        rm|remove|delete)
            local name="${1:-}"
            if [[ -z "$name" ]]; then
                echo -e "${RED}Usage: cctrl host rm <alias>${RESET}"
                return 1
            fi
            if [[ ! -f "$HOSTS_FILE" ]] || ! jq -e --arg n "$name" 'has($n)' "$HOSTS_FILE" &>/dev/null; then
                echo -e "${RED}Host '$name' not found.${RESET}"
                return 1
            fi
            local tmp
            tmp=$(mktemp)
            jq --arg n "$name" 'del(.[$n])' "$HOSTS_FILE" > "$tmp" && mv "$tmp" "$HOSTS_FILE"
            echo -e "${GREEN}Removed host: $name${RESET}"
            ;;
        doctor)
            local name="${1:-}"
            if [[ -z "$name" ]]; then
                echo -e "${RED}Usage: cctrl host doctor <alias> [--agent claude|codex]${RESET}"
                return 1
            fi
            shift 2>/dev/null || true
            local doctor_agent="$(_default_agent)"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --agent)
                        [[ $# -ge 2 ]] || { echo -e "${RED}--agent needs a value${RESET}"; return 1; }
                        doctor_agent="$(_normalize_agent "$2")" || return 1
                        shift 2 ;;
                    *)
                        echo -e "${RED}Unknown host doctor flag: $1${RESET}"
                        return 1 ;;
                esac
            done
            local lookup
            lookup="$(_host_lookup "$name")"
            if [[ -z "$lookup" ]]; then
                echo -e "${RED}Host '$name' not found.${RESET}"
                return 1
            fi

            local hostname user ssh_target
            hostname="${lookup%% *}"
            user="${lookup#* }"
            if [[ -n "$user" ]]; then
                ssh_target="${user}@${hostname}"
            else
                ssh_target="$hostname"
            fi

            local doctor_bin doctor_install_hint
            doctor_bin="$(_agent_bin "$doctor_agent")"
            case "$doctor_agent" in
                codex) doctor_install_hint="brew install codex" ;;
                *)     doctor_install_hint="brew install claude-code" ;;
            esac

            echo -e "${BOLD}Host Doctor: $name${RESET} ($ssh_target, agent=$doctor_agent)"
            echo ""

            local all_ok=true
            # Tool checks must source ~/.zprofile, exactly like _remote_exec does
            # before running cctrl — otherwise brew-installed tools (tmux, claude,
            # cctrl) look MISSING under the bare non-interactive SSH PATH.
            local renv='source ~/.zprofile 2>/dev/null; '

            # 1. SSH connectivity
            echo -n "  SSH connectivity... "
            if ssh -o ConnectTimeout=5 -o BatchMode=yes "$ssh_target" "echo ok" &>/dev/null; then
                echo -e "${GREEN}OK${RESET}"
            else
                echo -e "${RED}FAIL${RESET}"
                echo -e "    ${DIM}Cannot connect. Check SSH keys and ~/.ssh/config.${RESET}"
                all_ok=false
                # Can't continue if SSH fails
                echo ""
                echo -e "${RED}Cannot continue without SSH connectivity.${RESET}"
                return 1
            fi

            # 2. brew in PATH (after sourcing ~/.zprofile)
            echo -n "  brew in PATH... "
            if ssh "$ssh_target" "${renv}command -v brew" &>/dev/null; then
                echo -e "${GREEN}OK${RESET}"
            else
                echo -e "${YELLOW}MISSING${RESET}"
                all_ok=false
                echo -n "    Fix: add brew to ~/.zprofile? [y/N] "
                read -r confirm
                if [[ "$confirm" =~ ^[yY]$ ]]; then
                    ssh "$ssh_target" 'echo "eval \"\$(/opt/homebrew/bin/brew shellenv)\"" >> ~/.zprofile'
                    echo -e "    ${GREEN}Added to ~/.zprofile (reconnect to take effect)${RESET}"
                fi
            fi

            # 3. tmux installed
            echo -n "  tmux installed... "
            if ssh "$ssh_target" "${renv}command -v tmux" &>/dev/null; then
                echo -e "${GREEN}OK${RESET}"
            else
                echo -e "${YELLOW}MISSING${RESET}"
                all_ok=false
                echo -n "    Fix: brew install tmux? [y/N] "
                read -r confirm
                if [[ "$confirm" =~ ^[yY]$ ]]; then
                    ssh "$ssh_target" "${renv}brew install tmux"
                    echo -e "    ${GREEN}Installed tmux${RESET}"
                fi
            fi

            # 4. selected agent installed
            echo -n "  $doctor_bin installed... "
            if ssh "$ssh_target" "${renv}command -v $doctor_bin" &>/dev/null; then
                echo -e "${GREEN}OK${RESET}"
            else
                echo -e "${YELLOW}MISSING${RESET}"
                all_ok=false
                echo -n "    Fix: $doctor_install_hint? [y/N] "
                read -r confirm
                if [[ "$confirm" =~ ^[yY]$ ]]; then
                    ssh "$ssh_target" "${renv}$doctor_install_hint"
                    echo -e "    ${GREEN}Installed $doctor_bin${RESET}"
                fi
            fi

            # 5. cctrl available
            echo -n "  cctrl available... "
            if ssh "$ssh_target" "${renv}command -v cctrl" &>/dev/null; then
                echo -e "${GREEN}OK${RESET}"
            else
                echo -e "${YELLOW}MISSING${RESET}"
                all_ok=false
                echo -e "    ${DIM}Fix: clone the repo and symlink cctrl into PATH${RESET}"
                echo -e "    ${DIM}  git clone https://github.com/aberhamm/cctrl.git${RESET}"
                echo -e "    ${DIM}  ln -s \$(pwd)/cctrl/cctrl ~/.local/bin/cctrl${RESET}"
            fi

            # 6. ~/.tmux.conf exists
            echo -n "  ~/.tmux.conf exists... "
            if ssh "$ssh_target" "test -f ~/.tmux.conf" &>/dev/null; then
                echo -e "${GREEN}OK${RESET}"
            else
                echo -e "${YELLOW}MISSING${RESET}"
                all_ok=false
                if [[ -f "$HOME/.tmux.conf" ]]; then
                    echo -n "    Fix: scp your local ~/.tmux.conf? [y/N] "
                    read -r confirm
                    if [[ "$confirm" =~ ^[yY]$ ]]; then
                        scp "$HOME/.tmux.conf" "$ssh_target:~/.tmux.conf"
                        echo -e "    ${GREEN}Copied ~/.tmux.conf${RESET}"
                    fi
                else
                    echo -e "    ${DIM}No local ~/.tmux.conf to copy.${RESET}"
                fi
            fi

            echo ""
            if $all_ok; then
                echo -e "${GREEN}All checks passed.${RESET}"
            else
                echo -e "${YELLOW}Some checks failed. Fix issues above for full remote support.${RESET}"
            fi
            ;;
        help|-h|--help)
            echo -e "${BOLD}cctrl host${RESET} — Manage remote hosts"
            echo ""
            echo "  cctrl host add <alias> <hostname> [user]"
            echo "  cctrl host list"
            echo "  cctrl host rm <alias>"
            echo "  cctrl host doctor <alias> [--agent claude|codex]"
            echo ""
            echo "Use with --host flag:"
            echo "  cctrl --host <alias> <command> [args...]"
            ;;
        *)
            echo -e "${RED}Unknown host subcommand: $action${RESET}"
            echo "Available: add, list, rm, doctor, help"
            return 1
            ;;
    esac
}

# ── Shortcuts ─────────────────────────────────────────────────────────
# Named jump targets: cd into a directory and launch an agent there, optionally
# switching profile and resuming a session. Configured in data/shortcuts.json.
# Example: cctrl @HomeLab    cctrl @add HomeLab ~/homelab --profile max --resume

_shortcuts_init() {
    mkdir -p "$(dirname "$SHORTCUTS_FILE")"
    [[ -f "$SHORTCUTS_FILE" ]] || echo "{}" > "$SHORTCUTS_FILE"
}

_shortcut_lookup_key() {
    # Case-insensitive lookup; echoes the canonical key (or empty)
    [[ -f "$SHORTCUTS_FILE" ]] || return 0
    jq -r --arg n "$1" '
        to_entries
        | map(select(.key | ascii_downcase == ($n | ascii_downcase)))[0].key // empty
    ' "$SHORTCUTS_FILE" 2>/dev/null
}

_shortcut_help() {
    echo -e "${BOLD}Shortcut commands${RESET}"
    echo "  cctrl @<name>                     Jump: cd, switch profile, launch selected agent"
    echo "  cctrl @<name> -m \"TEXT\"            Launch with an initial prompt"
    echo "  cctrl @<name> -- TEXT...          Same; everything after -- is the prompt"
    echo "  cctrl @<name> --resume [id]       Resume picker, or a specific session"
    echo "  cctrl @<name> --no-bridge         Disable the phone-control bridge for this launch"
    echo "  cctrl @add <name> <dir> [--profile X] [--agent claude|codex] [--resume [id]] [--message TEXT]"
    echo "  cctrl @rm <name>                  Remove a shortcut"
    echo "  cctrl @ ls                        List shortcuts (no helper)"
    echo "  cctrl @ edit                      Open ${SHORTCUTS_FILE/#$HOME/~} in \$EDITOR"
}

_shortcut_list() {
    if [[ ! -f "$SHORTCUTS_FILE" ]] || ! jq -e 'length > 0' "$SHORTCUTS_FILE" &>/dev/null; then
        echo -e "${DIM}No shortcuts yet.${RESET}"
        echo
        _shortcut_help
        return
    fi

    echo -e "${BOLD}Shortcuts${RESET}"
    # Emit one field per line to avoid IFS-whitespace field collapsing.
    local _name _dir _profile _agent _resume _prompt
    while IFS= read -r _name \
       && IFS= read -r _dir \
       && IFS= read -r _profile \
       && IFS= read -r _agent \
       && IFS= read -r _resume \
       && IFS= read -r _prompt; do
        local extras=""
        [[ -n "$_profile" ]] && extras+="  ${DIM}profile=${_profile}${RESET}"
        [[ -n "$_agent" ]] && extras+="  ${DIM}agent=${_agent}${RESET}"
        [[ "$_resume" != "false" ]] && extras+="  ${DIM}resume=${_resume}${RESET}"
        echo -e "  ${GREEN}@${_name}${RESET}  ${DIM}→${RESET}  $_dir$extras"
        if [[ -n "$_prompt" ]]; then
            local short="$_prompt"
            [[ ${#short} -gt 70 ]] && short="${short:0:67}..."
            echo -e "      ${DIM}prompt: \"$short\"${RESET}"
        fi
    done < <(jq -r 'to_entries[] | .key, (.value.dir // ""), (.value.profile // ""), (.value.agent // ""), (.value.resume // false | tostring), (.value.prompt // "")' "$SHORTCUTS_FILE")
}

_shortcut_add() {
    local name="${1:-}" dir="${2:-}"
    if [[ -z "$name" || -z "$dir" ]]; then
        echo -e "${RED}Usage: cctrl @add <name> <dir> [--profile X] [--agent claude|codex] [--resume [id]] [--message TEXT]${RESET}"
        return 1
    fi
    shift 2

    local profile=""
    local agent=""
    local resume="false"
    local prompt=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile|-p)
                [[ $# -ge 2 ]] || { echo -e "${RED}--profile needs a value${RESET}"; return 1; }
                profile="$2"; shift 2 ;;
            --agent)
                [[ $# -ge 2 ]] || { echo -e "${RED}--agent needs a value${RESET}"; return 1; }
                agent="$(_normalize_agent "$2")" || return 1
                shift 2 ;;
            --resume|-r)
                if [[ $# -gt 1 && "$2" != -* ]]; then
                    resume="$2"; shift 2
                else
                    resume="true"; shift
                fi ;;
            --message|--prompt|-m)
                [[ $# -ge 2 ]] || { echo -e "${RED}--message needs a value${RESET}"; return 1; }
                prompt="$2"; shift 2 ;;
            *)
                echo -e "${RED}Unknown flag: $1${RESET}"; return 1 ;;
        esac
    done

    if [[ -n "$profile" ]] && ! _profile_exists "$profile"; then
        echo -e "${YELLOW}Warning: profile '$profile' does not exist (saving anyway).${RESET}"
    fi

    _shortcuts_init

    local existing
    existing=$(_shortcut_lookup_key "$name")
    if [[ -n "$existing" && "$existing" != "$name" ]]; then
        echo -e "${YELLOW}A shortcut '$existing' already exists with different casing. Overwriting under new name '$name'.${RESET}"
    fi

    local tmp
    tmp=$(mktemp)
    jq --arg name "$name" \
       --arg dir "$dir" \
       --arg profile "$profile" \
       --arg agent "$agent" \
       --arg resume "$resume" \
       --arg prompt "$prompt" \
       --arg existing "$existing" '
        (if $existing != "" and $existing != $name then del(.[$existing]) else . end)
        + {
            ($name): (
                {dir: $dir}
                + (if $profile != "" then {profile: $profile} else {} end)
                + (if $agent != "" then {agent: $agent} else {} end)
                + (if $resume == "true" then {resume: true}
                   elif $resume == "false" then {}
                   else {resume: $resume} end)
                + (if $prompt != "" then {prompt: $prompt} else {} end)
            )
        }
    ' "$SHORTCUTS_FILE" > "$tmp" && mv "$tmp" "$SHORTCUTS_FILE"

    echo -e "${GREEN}Saved ${BOLD}@$name${RESET}${GREEN} → $dir${RESET}"
    [[ -n "$profile" ]] && echo -e "${DIM}  profile=$profile${RESET}"
    [[ -n "$agent" ]] && echo -e "${DIM}  agent=$agent${RESET}"
    [[ "$resume" != "false" ]] && echo -e "${DIM}  resume=$resume${RESET}"
    [[ -n "$prompt" ]] && echo -e "${DIM}  prompt=\"$prompt\"${RESET}"
    return 0
}

_shortcut_rm() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl @rm <name>${RESET}"
        return 1
    fi
    [[ -f "$SHORTCUTS_FILE" ]] || { echo -e "${DIM}No shortcuts file.${RESET}"; return 1; }

    local key
    key=$(_shortcut_lookup_key "$name")
    if [[ -z "$key" ]]; then
        echo -e "${RED}Shortcut '$name' not found.${RESET}"
        return 1
    fi

    local tmp
    tmp=$(mktemp)
    jq --arg key "$key" 'del(.[$key])' "$SHORTCUTS_FILE" > "$tmp" && mv "$tmp" "$SHORTCUTS_FILE"
    echo -e "${GREEN}Removed @$key${RESET}"
}

_shortcut_jump() {
    local name="$1"; shift

    if [[ ! -f "$SHORTCUTS_FILE" ]]; then
        echo -e "${RED}No shortcuts configured.${RESET} Add one with: cctrl @add <name> <dir>"
        return 1
    fi

    local key
    key=$(_shortcut_lookup_key "$name")
    if [[ -z "$key" ]]; then
        echo -e "${RED}Shortcut '@$name' not found.${RESET}"
        echo
        # Search common project directories for a matching folder name
        local -a candidates=()
        local search_dirs=("$HOME/_projects" "$HOME/Documents/Obsidian Vault" "$HOME/Projects" "$HOME/projects" "$HOME/src")
        for sdir in "${search_dirs[@]}"; do
            [[ -d "$sdir" ]] || continue
            while IFS= read -r match; do
                candidates+=("$match")
            done < <(find "$sdir" -maxdepth 3 -type d -iname "*$name*" 2>/dev/null | head -10)
        done

        if [[ ${#candidates[@]} -gt 0 ]]; then
            echo -e "${BOLD}Found directories matching '$name':${RESET}"
            local i=1
            for c in "${candidates[@]}"; do
                echo -e "  ${GREEN}[$i]${RESET} $c"
                ((i++))
            done
            echo
            echo -n "Add as shortcut? Enter number (or n to skip): "
            read -r choice
            if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#candidates[@]} )); then
                local chosen="${candidates[$((choice-1))]}"
                _shortcut_add "$name" "$chosen"
                echo
                echo -e "${DIM}Run ${BOLD}cctrl @$name${RESET}${DIM} again to launch.${RESET}"
                return 0
            fi
        else
            echo -e "${DIM}Add it with:${RESET} cctrl @add $name <dir> [--profile X] [--agent claude|codex] [--resume [id]] [--message TEXT]"
        fi
        echo
        _shortcut_list
        return 1
    fi

    local dir profile shortcut_agent resume prompt
    { IFS= read -r dir; IFS= read -r profile; IFS= read -r shortcut_agent; IFS= read -r resume; IFS= read -r prompt; } < <(jq -r --arg k "$key" '
        .[$k] | (.dir // ""), (.profile // ""), (.agent // ""), (.resume // false | tostring), (.prompt // "")
    ' "$SHORTCUTS_FILE")

    # Expand leading ~
    dir="${dir/#\~/$HOME}"

    if [[ -z "$dir" || ! -d "$dir" ]]; then
        echo -e "${RED}Directory does not exist: $dir${RESET}"
        echo
        # Try to find where the folder moved to
        local basename="${dir##*/}"
        local -a candidates=()
        local search_dirs=("$HOME/_projects" "$HOME/Documents/Obsidian Vault" "$HOME/Projects" "$HOME/projects" "$HOME/src")
        for sdir in "${search_dirs[@]}"; do
            [[ -d "$sdir" ]] || continue
            while IFS= read -r match; do
                [[ "$match" != "$dir" ]] && candidates+=("$match")
            done < <(find "$sdir" -maxdepth 4 -type d -name "$basename" 2>/dev/null | head -10)
        done

        if [[ ${#candidates[@]} -gt 0 ]]; then
            echo -e "${BOLD}Found possible new location(s) for '$basename':${RESET}"
            local i=1
            for c in "${candidates[@]}"; do
                echo -e "  ${GREEN}[$i]${RESET} $c"
                ((i++))
            done
            echo
            echo -n "Update @$key to new path? Enter number (or n to skip): "
            read -r choice
            if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#candidates[@]} )); then
                local chosen="${candidates[$((choice-1))]}"
                local tmp
                tmp=$(mktemp)
                jq --arg k "$key" --arg d "$chosen" '.[$k].dir = $d' "$SHORTCUTS_FILE" > "$tmp" && mv "$tmp" "$SHORTCUTS_FILE"
                echo -e "${GREEN}Updated @$key → $chosen${RESET}"
                echo
                echo -e "${DIM}Run ${BOLD}cctrl @$key${RESET}${DIM} again to launch.${RESET}"
                return 0
            fi
        fi
        return 1
    fi

    # Build selected-agent flags. CLI args override shortcut resume/prompt/agent settings.
    local cli_resume=false
    local cli_resume_val=""
    local cli_prompt=""
    local cli_prompt_set=false
    local no_bridge=false
    local cli_model=""
    local agent="${shortcut_agent:-$(_default_agent)}"
    local launch_name=""
    local full_bypass=false
    local access_explicit=false
    local permission_mode=""
    local passthrough=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)
                [[ $# -ge 2 ]] || { echo -e "${RED}--agent needs a value${RESET}"; return 1; }
                agent="$2"; shift 2 ;;
            --resume|-r)
                cli_resume=true
                if [[ $# -gt 1 && "$2" != -* ]]; then
                    cli_resume_val="$2"; shift
                fi
                shift ;;
            --message|--prompt|-m)
                [[ $# -ge 2 ]] || { echo -e "${RED}--message needs a value${RESET}"; return 1; }
                cli_prompt="$2"; cli_prompt_set=true; shift 2 ;;
            --no-bridge)
                no_bridge=true; shift ;;
            --yolo|--dangerously-bypass-approvals-and-sandbox)
                full_bypass=true; access_explicit=true; shift ;;
            --permission-mode)
                [[ $# -ge 2 ]] || { echo -e "${RED}--permission-mode needs a value${RESET}"; return 1; }
                permission_mode="$2"; access_explicit=true; shift 2 ;;
            --sandbox|-s|--ask-for-approval|-a)
                [[ $# -ge 2 ]] || { echo -e "${RED}$1 needs a value${RESET}"; return 1; }
                access_explicit=true
                passthrough+=("$1" "$2"); shift 2 ;;
            --name|-n)
                [[ $# -ge 2 ]] || { echo -e "${RED}--name needs a value${RESET}"; return 1; }
                launch_name="$2"; shift 2 ;;
            --model)
                [[ $# -ge 2 ]] || { echo -e "${RED}--model needs a value${RESET}"; return 1; }
                cli_model="$2"; shift 2 ;;
            --)
                shift
                # Everything after -- is a literal prompt (joined by space)
                if [[ $# -gt 0 ]]; then
                    cli_prompt="$*"; cli_prompt_set=true
                fi
                break ;;
            *)
                passthrough+=("$1"); shift ;;
        esac
    done
    agent="$(_normalize_agent "$agent")" || return 1

    # Apply the shortcut's profile as a per-process overlay (env + model). No
    # global-settings mutation: concurrent shortcuts with different profiles stay
    # independent and there's no launch race on global agent config.
    local pf=""
    if [[ -n "$profile" ]]; then
        if _profile_exists "$profile"; then
            pf="$(_profile_path "$profile")"
        else
            echo -e "${YELLOW}Profile '$profile' not found; launching without it.${RESET}"
        fi
    fi
    _apply_profile_overlay "$agent" "$pf"

    # Prompt: CLI overrides config. Goes last (claude treats final positional as prompt).
    local final_prompt=""
    if $cli_prompt_set; then
        final_prompt="$cli_prompt"
    elif [[ -n "$prompt" ]]; then
        final_prompt="$prompt"
    fi

    cd "$dir"
    echo -e "${DIM}→ @${key}  ($dir)${RESET}"

    local launch_resume=false launch_resume_val=""
    if $cli_resume; then
        launch_resume=true
        launch_resume_val="$cli_resume_val"
    elif [[ "$resume" == "true" ]]; then
        launch_resume=true
    elif [[ -n "$resume" && "$resume" != "false" ]]; then
        launch_resume=true
        launch_resume_val="$resume"
    fi

    LAUNCH_FULL_BYPASS=$full_bypass
    LAUNCH_ACCESS_EXPLICIT=$access_explicit
    LAUNCH_PERMISSION_MODE="$permission_mode"
    LAUNCH_PASSTHROUGH=()
    [[ ${#passthrough[@]} -gt 0 ]] && LAUNCH_PASSTHROUGH=("${passthrough[@]}")
    _launch_exec_agent "$agent" "$pf" "$cli_model" "$launch_name" "$no_bridge" "$launch_resume" "$launch_resume_val" "$final_prompt" "$dir"
}

cmd_shortcut() {
    local action="${1:-}"
    case "$action" in
        "")                _shortcut_list; echo; _shortcut_help ;;
        help|-h|--help)    _shortcut_help ;;
        ls|list)           _shortcut_list ;;
        add)               shift; _shortcut_add "$@" ;;
        rm|remove|delete)  shift; _shortcut_rm "$@" ;;
        edit)              _shortcuts_init; "${EDITOR:-vim}" "$SHORTCUTS_FILE" ;;
        *)                 shift; _shortcut_jump "$action" "$@" ;;
    esac
}

# ── Plugin discovery ──────────────────────────────────────────────────

_try_plugin() {
    local cmd="$1"
    shift

    if [[ -x "$PLUGINS_DIR/cctrl-$cmd" ]]; then
        "$PLUGINS_DIR/cctrl-$cmd" "$@"
        return 0
    fi

    if command -v "cctrl-$cmd" &>/dev/null; then
        "cctrl-$cmd" "$@"
        return 0
    fi

    return 1
}

# ── Main dispatch ─────────────────────────────────────────────────────

main() {
    # Parse global flags before subcommand routing. Subcommands may also accept
    # --agent locally; this form is useful when combined with --host.
    local _host_alias="" _agent=""
    while [[ $# -gt 0 ]]; do
        case "${1:-}" in
            --host)
                shift
                _host_alias="${1:-}"
                if [[ -z "$_host_alias" ]]; then
                    echo -e "${RED}--host requires a host alias${RESET}" >&2
                    echo -e "${DIM}List hosts with: cctrl host list${RESET}" >&2
                    return 1
                fi
                shift
                ;;
            --agent)
                shift
                _agent="${1:-}"
                if [[ -z "$_agent" ]]; then
                    echo -e "${RED}--agent requires a value${RESET}" >&2
                    echo -e "${DIM}Supported agents: claude, codex${RESET}" >&2
                    return 1
                fi
                _agent="$(_normalize_agent "$_agent")" || return 1
                export CCTRL_AGENT="$_agent"
                shift
                ;;
            *)
                break
                ;;
        esac
    done

    if [[ -n "$_host_alias" ]]; then
        local _lookup
        _lookup="$(_host_lookup "$_host_alias")"
        if [[ -z "$_lookup" ]]; then
            echo -e "${RED}Unknown host: '$_host_alias'${RESET}" >&2
            echo -e "${DIM}List hosts with: cctrl host list${RESET}" >&2
            return 1
        fi
        # If the alias points at this machine, run locally — no SSH-to-self.
        if _host_is_local "${_lookup%% *}"; then
            _dispatch "$@"
            return $?
        fi
        _remote_exec "$_host_alias" "$@"
        return $?
    fi

    _dispatch "$@"
}

_dispatch() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        @*)
            local name="${cmd#@}"
            # Support both `cctrl @HomeLab` and `cctrl @ HomeLab` / `cctrl @ add ...`
            if [[ -z "$name" && $# -gt 0 ]]; then
                name="$1"; shift
            fi
            cmd_shortcut "$name" "$@"
            ;;
        shortcuts) cmd_shortcut "$@" ;;
        host) cmd_host "$@" ;;
        whoami) cmd_whoami "$@" ;;
        use|switch) cmd_use "$@" ;;
        ls|list) cmd_ls "$@" ;;
        current) cmd_current "$@" ;;
        save)    cmd_save "$@" ;;
        rename)  cmd_rename "$@" ;;
        diff)    cmd_diff "$@" ;;
        edit)    cmd_edit "$@" ;;
        start|s) cmd_start "$@" ;;
        session|sess) cmd_session "$@" ;;
        costs|cost) cmd_costs "$@" ;;
        usage) cmd_usage "$@" ;;
        statusline|status-line) cmd_statusline "$@" ;;
        log)     cmd_log "$@" ;;
        chrome|cdp) cmd_chrome "$@" ;;
        help|-h|--help) cmd_help "$@" ;;
        *)
            if ! _try_plugin "$cmd" "$@"; then
                echo -e "${RED}Unknown command: $cmd${RESET}"
                echo ""
                cmd_help
                return 1
            fi
            ;;
    esac
}

main "$@"
