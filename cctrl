#!/usr/bin/env bash
set -euo pipefail

# cctrl — Coding Agent Controller
# Manages settings profiles, tracks token usage locally, extensible via plugins.

# Resolve real path (works through symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"
PROFILES_DIR="$SCRIPT_DIR/profiles"
PLUGINS_DIR="$SCRIPT_DIR/plugins"
COSTS_DIR="$SCRIPT_DIR/costs"
SPENDING_LOG="$COSTS_DIR/spending.jsonl"
SHORTCUTS_FILE="$SCRIPT_DIR/data/shortcuts.json"
HOSTS_FILE="$SCRIPT_DIR/data/hosts.json"
CONFIG_FILE="$SCRIPT_DIR/data/config.json"

CLAUDE_DIR="$HOME/.claude"
SETTINGS="$CLAUDE_DIR/settings.json"
PROJECTS_DIR="$CLAUDE_DIR/projects"
ACTIVE_FILE="$SCRIPT_DIR/.active-profile"
CODEX_DIR="${CODEX_HOME:-$HOME/.codex}"
CODEX_SESSIONS_DIR="$CODEX_DIR/sessions"
CODEX_ARCHIVED_SESSIONS_DIR="$CODEX_DIR/archived_sessions"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

_active_profile() {
    if [[ -f "$ACTIVE_FILE" ]]; then
        cat "$ACTIVE_FILE"
    else
        echo "personal"
    fi
}

_profile_path() {
    echo "$PROFILES_DIR/${1}.json"
}

_profile_exists() {
    [[ -f "$(_profile_path "$1")" ]]
}

_default_agent() {
    if [[ -n "${CCTRL_AGENT:-}" ]]; then
        printf '%s' "$CCTRL_AGENT"
        return
    fi

    if [[ -f "$CONFIG_FILE" ]] && command -v jq >/dev/null 2>&1; then
        local configured
        configured="$(jq -r '.defaultAgent // .default_agent // empty' "$CONFIG_FILE" 2>/dev/null || true)"
        case "$(printf '%s' "$configured" | tr '[:upper:]' '[:lower:]')" in
            claude|claude-code) printf 'claude'; return ;;
            codex|openai)       printf 'codex'; return ;;
        esac
    fi

    printf 'claude'
}

_normalize_agent() {
    local agent
    agent="$(printf '%s' "${1:-claude}" | tr '[:upper:]' '[:lower:]')"
    case "$agent" in
        claude|claude-code) printf 'claude' ;;
        codex|openai) printf 'codex' ;;
        *)
            echo -e "${RED}Unknown agent: $1${RESET}" >&2
            echo -e "${DIM}Supported agents: claude, codex${RESET}" >&2
            return 1
            ;;
    esac
}

_agent_bin() {
    case "$1" in
        codex) printf 'codex' ;;
        *)     printf 'claude' ;;
    esac
}

_profile_model_for_agent() {
    local agent="$1" pf="$2" model
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0

    model="$(jq -r --arg agent "$agent" '
        (.agents[$agent].model // .model // empty)
    ' "$pf" 2>/dev/null)"
    [[ -n "$model" ]] || return 0

    # Existing profiles are Claude-oriented. Avoid accidentally passing a Claude
    # model alias such as "sonnet" into Codex when the active default is reused.
    if [[ "$agent" == "codex" ]]; then
        case "$(printf '%s' "$model" | tr '[:upper:]' '[:lower:]')" in
            *claude*|*sonnet*|*opus*|*haiku*|anthropic/*) return 0 ;;
        esac
    fi
    printf '%s' "$model"
}

_profile_args_for_agent() {
    local agent="$1" pf="$2"
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0
    jq -r --arg agent "$agent" '
        (.agents[$agent].args // [])
        | if type == "array" then .[] else empty end
        | tostring
    ' "$pf" 2>/dev/null
}

_profile_env_entries_for_agent() {
    local agent="$1" pf="$2"
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0
    jq -r --arg agent "$agent" '
        (has("agents")) as $has_agents
        | (
            if $has_agents then
                ((.env // {}) + (.agents[$agent].env // {}))
            elif $agent == "claude" then
                (.env // {})
            else
                {}
            end
          )
        | to_entries[]
        | "\(.key)\t\(.value|tostring|@base64)"
    ' "$pf" 2>/dev/null
}

# Export a profile's shared env plus agent-specific env into the current process
# so the selected agent inherits it. Legacy profiles with no `agents` block keep
# applying their top-level env to Claude only.
_apply_profile_overlay() {
    local agent="${1:-claude}" pf="${2:-}"
    [[ -n "$pf" && -f "$pf" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0
    local key valb64 val
    while IFS=$'\t' read -r key valb64; do
        [[ -n "$key" ]] || continue
        # base64 -d (GNU/newer macOS) with -D fallback (older BSD/macOS).
        val="$(printf '%s' "$valb64" | base64 -d 2>/dev/null || printf '%s' "$valb64" | base64 -D 2>/dev/null)"
        export "$key=$val"
    done < <(_profile_env_entries_for_agent "$agent" "$pf")
}

# Resolve the launch model. Precedence: explicit CLI --model > profile model >
# empty (omit --model entirely and let the selected agent use its own default).
#   $1 = agent, $2 = cli_model (may be empty), $3 = profile_file (may be empty)
_resolve_model() {
    local agent="${1:-claude}" cli="${2:-}" pf="${3:-}"
    if [[ -n "$cli" ]]; then printf '%s' "$cli"; return; fi
    _profile_model_for_agent "$agent" "$pf"
}

_profile_overlay_json_for_agent() {
    local agent="$1" pf="$2"
    [[ -n "$pf" && -f "$pf" ]] || { echo '{"model":null,"env":{}}'; return 0; }
    command -v jq >/dev/null 2>&1 || { echo '{"model":null,"env":{}}'; return 0; }
    jq --arg agent "$agent" '
        if has("agents") then
            {
                model: (.agents[$agent].model // null),
                env: ((.env // {}) + (.agents[$agent].env // {}))
            }
        elif $agent == "claude" then
            {model: (.model // null), env: (.env // {})}
        else
            {model: null, env: {}}
        end
    ' "$pf" 2>/dev/null
}

_profile_summary() {
    local pf="$1"
    command -v jq >/dev/null 2>&1 || { printf 'model=unknown'; return; }
    jq -r '
        def model_for($a):
            if has("agents") then
                (.agents[$a].env.ANTHROPIC_MODEL // .agents[$a].model // empty)
            elif $a == "claude" then
                (.env.ANTHROPIC_MODEL // .model // empty)
            else
                empty
            end;
        def provider_for($a):
            if has("agents") then
                if (.agents[$a].env.CLAUDE_CODE_USE_BEDROCK // false) then "bedrock" else "direct" end
            elif $a == "claude" then
                if (.env.CLAUDE_CODE_USE_BEDROCK // false) then "bedrock" else "direct" end
            else
                "direct"
            end;
        [
            (model_for("claude") as $m | if $m != "" then "claude=\($m) via=\(provider_for("claude"))" else empty end),
            (model_for("codex") as $m | if $m != "" then "codex=\($m)" else empty end)
        ] | if length > 0 then join("  ") else "model=default" end
    ' "$pf" 2>/dev/null
}

_launch_apply_profile_args() {
    local agent="$1" pf="$2" parg
    while IFS= read -r parg; do
        [[ -n "$parg" ]] && LAUNCH_PROFILE_ARGS+=("$parg")
    done < <(_profile_args_for_agent "$agent" "$pf")

    if [[ ${#LAUNCH_PROFILE_ARGS[@]} -eq 0 ]]; then
        return 0
    fi

    local i=0 next
    while (( i < ${#LAUNCH_PROFILE_ARGS[@]} )); do
        parg="${LAUNCH_PROFILE_ARGS[$i]}"
        case "$parg" in
            --yolo|--dangerously-bypass-approvals-and-sandbox)
                LAUNCH_FULL_BYPASS=true
                LAUNCH_ACCESS_EXPLICIT=true
                ((i++))
                ;;
            --permission-mode)
                if (( i + 1 >= ${#LAUNCH_PROFILE_ARGS[@]} )); then
                    echo -e "${RED}Profile arg --permission-mode needs a value${RESET}" >&2
                    return 1
                fi
                next="${LAUNCH_PROFILE_ARGS[$((i + 1))]}"
                LAUNCH_PERMISSION_MODE="$next"
                LAUNCH_ACCESS_EXPLICIT=true
                ((i+=2))
                ;;
            --sandbox|-s|--ask-for-approval|-a)
                if (( i + 1 >= ${#LAUNCH_PROFILE_ARGS[@]} )); then
                    echo -e "${RED}Profile arg $parg needs a value${RESET}" >&2
                    return 1
                fi
                next="${LAUNCH_PROFILE_ARGS[$((i + 1))]}"
                LAUNCH_ACCESS_EXPLICIT=true
                LAUNCH_FLAGS+=("$parg" "$next")
                ((i+=2))
                ;;
            *)
                LAUNCH_FLAGS+=("$parg")
                ((i++))
                ;;
        esac
    done
}

_launch_exec_agent() {
    local agent="$1" pf="$2" cli_model="$3" launch_name="$4" no_bridge="$5"
    local resume="$6" resume_val="$7" final_prompt="$8" bridge_dir="${9:-$PWD}"

    LAUNCH_FLAGS=()
    LAUNCH_PROFILE_ARGS=()
    _launch_apply_profile_args "$agent" "$pf" || return 1

    local mdl
    mdl="$(_resolve_model "$agent" "$cli_model" "$pf")"
    [[ -n "$mdl" ]] && LAUNCH_FLAGS+=("--model" "$mdl")

    if [[ "$agent" == "claude" ]]; then
        if $LAUNCH_FULL_BYPASS; then
            LAUNCH_PERMISSION_MODE="bypassPermissions"
        fi
        if [[ ${#LAUNCH_FLAGS[@]} -gt 0 ]]; then
            LAUNCH_FLAGS=("--permission-mode" "${LAUNCH_PERMISSION_MODE:-bypassPermissions}" "${LAUNCH_FLAGS[@]}")
        else
            LAUNCH_FLAGS=("--permission-mode" "${LAUNCH_PERMISSION_MODE:-bypassPermissions}")
        fi
        [[ -n "$launch_name" ]] && LAUNCH_FLAGS+=("--name" "$launch_name")
        if [[ "$no_bridge" != "true" ]]; then
            LAUNCH_FLAGS+=("--remote-control" "--remote-control-session-name-prefix" "$(_remote_prefix "$bridge_dir")")
        fi

        if [[ "$resume" == "true" ]]; then
            if [[ -n "$resume_val" ]]; then
                LAUNCH_FLAGS+=("--resume" "$resume_val")
            else
                LAUNCH_FLAGS+=("--resume")
            fi
        fi
        [[ ${#LAUNCH_PASSTHROUGH[@]} -gt 0 ]] && LAUNCH_FLAGS+=("${LAUNCH_PASSTHROUGH[@]}")
        [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("$final_prompt")

        echo -e "${DIM}claude ${LAUNCH_FLAGS[*]}${RESET}"
        exec claude "${LAUNCH_FLAGS[@]}"
    fi

    if [[ -n "$LAUNCH_PERMISSION_MODE" && "$LAUNCH_PERMISSION_MODE" != "bypassPermissions" ]]; then
        echo -e "${RED}Codex can only translate --permission-mode bypassPermissions.${RESET}" >&2
        echo -e "${DIM}Use Codex-native flags like --sandbox and --ask-for-approval for other modes.${RESET}" >&2
        return 1
    fi

    [[ "$LAUNCH_PERMISSION_MODE" == "bypassPermissions" ]] && LAUNCH_FULL_BYPASS=true
    if $LAUNCH_FULL_BYPASS || ! $LAUNCH_ACCESS_EXPLICIT; then
        if [[ ${#LAUNCH_FLAGS[@]} -gt 0 ]]; then
            LAUNCH_FLAGS=("--yolo" "${LAUNCH_FLAGS[@]}")
        else
            LAUNCH_FLAGS=("--yolo")
        fi
    fi
    [[ ${#LAUNCH_PASSTHROUGH[@]} -gt 0 ]] && LAUNCH_FLAGS+=("${LAUNCH_PASSTHROUGH[@]}")

    if [[ "$resume" == "true" ]]; then
        if [[ -n "$resume_val" ]]; then
            [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("$resume_val" "$final_prompt") || LAUNCH_FLAGS+=("$resume_val")
        else
            [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("--last" "$final_prompt")
        fi
        echo -e "${DIM}codex resume ${LAUNCH_FLAGS[*]}${RESET}"
        exec codex resume "${LAUNCH_FLAGS[@]}"
    fi

    [[ -n "$final_prompt" ]] && LAUNCH_FLAGS+=("$final_prompt")
    echo -e "${DIM}codex ${LAUNCH_FLAGS[*]}${RESET}"
    exec codex "${LAUNCH_FLAGS[@]}"
}

_log_event() {
    mkdir -p "$COSTS_DIR"
    local json="$1"
    echo "$json" >> "$SPENDING_LOG"
}

_log_switch() {
    _log_event "$(printf '{"ts":"%s","event":"switch","from":"%s","to":"%s"}' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$1" "$2")"
}

_session_slug() {
    # Canonical slug for a directory or shortcut name. Used by both tmux
    # session naming and the bridge session-name prefix. Single source of truth.
    # Usage: _session_slug <name_or_dir>
    #   _session_slug homelab        → "homelab"
    #   _session_slug ~/projects/foo → "foo" (git root basename)
    local input="${1:-$PWD}"
    local name
    if [[ -d "$input" ]]; then
        local root
        root="$(git -C "$input" rev-parse --show-toplevel 2>/dev/null || echo "$input")"
        name="$(basename "$root")"
    else
        name="$input"
    fi
    name="$(echo "$name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g')"
    [[ -z "$name" ]] && name="agent"
    if [[ -n "${CCTRL_HOST_PREFIX:-}" ]]; then
        printf '%s--%s' "$CCTRL_HOST_PREFIX" "$name"
    else
        printf '%s' "$name"
    fi
}

_remote_prefix() {
    # Trailing dash so Claude appends --adjective-noun (double-dash separator).
    printf '%s-' "$(_session_slug "${1:-$PWD}")"
}

_detect_active() {
    # Profiles are overlays (model + env), not full settings snapshots, so a
    # whole-file match against the intentionally-richer global settings.json is
    # no longer meaningful. The active profile is whatever `cctrl use` recorded.
    if [[ -f "$ACTIVE_FILE" ]]; then
        cat "$ACTIVE_FILE"
    else
        echo "none"
    fi
}

# ── Commands ──────────────────────────────────────────────────────────

cmd_use() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl use <profile>${RESET}"
        echo "Available profiles:"
        cmd_ls
        return 1
    fi

    if ! _profile_exists "$name"; then
        echo -e "${RED}Profile '$name' not found.${RESET}"
        echo "Available profiles:"
        cmd_ls
        return 1
    fi

    local prev
    prev="$(_active_profile)"

    if [[ "$prev" == "$name" ]]; then
        echo -e "${DIM}Already on profile: ${BOLD}$name${RESET}"
        return 0
    fi

    # Overlay the profile's Claude model + env onto the existing global settings.json
    # (non-destructive: hooks, permissions, mcpServers, etc. are preserved).
    # Note: env is merged, so switching profiles cannot UNSET a key a prior
    # profile added. For clean per-session auth, prefer `cctrl start --profile`.
    local pf tmp
    pf="$(_profile_path "$name")"
    tmp="$(mktemp)"
    if [[ -f "$SETTINGS" ]]; then
        jq -s '.[0] as $g | .[1] as $p
               | $g + {model: ($p.model // $g.model),
                       env: (($g.env // {}) + ($p.env // {}))}' \
            "$SETTINGS" <(_profile_overlay_json_for_agent claude "$pf") > "$tmp"
    else
        mkdir -p "$(dirname "$SETTINGS")"
        _profile_overlay_json_for_agent claude "$pf" | jq '{model, env}' > "$tmp"
    fi
    if [[ -s "$tmp" ]]; then
        mv "$tmp" "$SETTINGS"
    else
        rm -f "$tmp"
        echo -e "${RED}Failed to merge profile into settings.${RESET}"; return 1
    fi
    echo "$name" > "$ACTIVE_FILE"
    _log_switch "$prev" "$name"

    echo -e "${GREEN}Switched to profile: ${BOLD}$name${RESET}"
    echo -e "${DIM}Default CCTRL profile is now '$name'.${RESET}"
    echo -e "${DIM}Merged Claude model + env into $SETTINGS for Claude Code compatibility.${RESET}"
    echo -e "${YELLOW}Prefer per-session launches with: cctrl start --profile $name${RESET}"
}

cmd_ls() {
    local active
    active="$(_detect_active)"

    if [[ ! -d "$PROFILES_DIR" ]] || [[ -z "$(ls "$PROFILES_DIR"/*.json 2>/dev/null)" ]]; then
        echo -e "${DIM}No profiles found. Use 'cctrl save <name>' to create one.${RESET}"
        return
    fi

    for f in "$PROFILES_DIR"/*.json; do
        local name
        name="$(basename "$f" .json)"
        local summary
        summary="$(_profile_summary "$f")"

        if [[ "$name" == "$active" ]]; then
            echo -e "  ${GREEN}* ${BOLD}$name${RESET}  ${DIM}$summary${RESET}"
        else
            echo -e "    $name  ${DIM}$summary${RESET}"
        fi
    done
}

cmd_current() {
    local active
    active="$(_detect_active)"
    echo -e "${BOLD}$active${RESET}"

    if _profile_exists "$active"; then
        local pf summary
        pf="$(_profile_path "$active")"
        summary="$(_profile_summary "$pf")"
        echo -e "${DIM}$summary${RESET}"

        if [[ -f "$SETTINGS" ]]; then
            local sub='{model: (.model // null), env: (.env // {})}'
            if ! diff -q <(jq -S "$sub" "$SETTINGS" 2>/dev/null) <(_profile_overlay_json_for_agent claude "$pf" | jq -S "$sub" 2>/dev/null) &>/dev/null; then
                echo -e "${YELLOW}Note: live Claude model/env differ from profile '${active}'${RESET}"
            fi
        fi
    fi
}

cmd_save() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl save <name>${RESET}"
        return 1
    fi

    if [[ ! -f "$SETTINGS" ]]; then
        echo -e "${RED}No settings.json found at $SETTINGS${RESET}"
        return 1
    fi

    if _profile_exists "$name"; then
        echo -en "${YELLOW}Profile '$name' already exists. Overwrite? [y/N] ${RESET}"
        read -r confirm
        [[ "$confirm" =~ ^[yY]$ ]] || return 1
    fi

    # Capture only the overlay-relevant Claude keys, not the whole
    # settings.json — profiles are auth/model overlays, not full snapshots.
    jq '{agents: {claude: {model: (.model // null), env: (.env // {})}}}' "$SETTINGS" > "$(_profile_path "$name")"
    echo "$name" > "$ACTIVE_FILE"
    echo -e "${GREEN}Saved current Claude model + env as profile: ${BOLD}$name${RESET}"
}

cmd_diff() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl diff <profile>${RESET}"
        return 1
    fi

    if ! _profile_exists "$name"; then
        echo -e "${RED}Profile '$name' not found.${RESET}"
        return 1
    fi

    # Compare only the Claude overlay subset (model + env); global settings.json
    # carries hooks/permissions/mcpServers a profile intentionally does not.
    local sub='{model: (.model // null), env: (.env // {})}'
    if command -v delta &>/dev/null; then
        delta <(jq -S "$sub" "$SETTINGS" 2>/dev/null) <(_profile_overlay_json_for_agent claude "$(_profile_path "$name")" | jq -S "$sub" 2>/dev/null) || true
    else
        diff --color=auto <(jq -S "$sub" "$SETTINGS" 2>/dev/null) <(_profile_overlay_json_for_agent claude "$(_profile_path "$name")" | jq -S "$sub" 2>/dev/null) || true
    fi
}

cmd_edit() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: cctrl edit <profile>${RESET}"
        return 1
    fi

    if ! _profile_exists "$name"; then
        echo -e "${RED}Profile '$name' not found.${RESET}"
        return 1
    fi

    "${EDITOR:-vim}" "$(_profile_path "$name")"
}

cmd_costs() {
    local range="${1:---month}"
    local project_filter="${2:-}"

    local num_periods
    case "$range" in
        --today|--current)  num_periods=1 ;;
        --week)             num_periods=1 ;;
        --month)            num_periods=4 ;;
        --all)              num_periods=9999 ;;
        *)                  num_periods=4 ;;
    esac

    python3 "$SCRIPT_DIR/lib/usage_costs.py" costs \
        "$PROJECTS_DIR" \
        "$CODEX_SESSIONS_DIR" \
        "$CODEX_ARCHIVED_SESSIONS_DIR" \
        "$num_periods" \
        "$project_filter" \
        "$SPENDING_LOG"
}

cmd_log() {
    if [[ ! -f "$SPENDING_LOG" ]]; then
        echo -e "${DIM}No spending log yet.${RESET}"
        return
    fi

    local count="${1:-20}"
    echo -e "${BOLD}Spending Log${RESET} ${DIM}(last $count entries)${RESET}"
    echo ""
    tail -"$count" "$SPENDING_LOG" | while IFS= read -r line; do
        local ts event
        ts="$(echo "$line" | jq -r '.ts' 2>/dev/null)"
        event="$(echo "$line" | jq -r '.event' 2>/dev/null)"
        case "$event" in
            switch)
                local from to
                from="$(echo "$line" | jq -r '.from' 2>/dev/null)"
                to="$(echo "$line" | jq -r '.to' 2>/dev/null)"
                echo -e "  ${DIM}$ts${RESET}  ${BLUE}switch${RESET}  $from -> ${BOLD}$to${RESET}"
                ;;
            session_end|session_update)
                local profile in_tok out_tok models
                profile="$(echo "$line" | jq -r '.profile' 2>/dev/null)"
                in_tok="$(echo "$line" | jq -r '.input_tokens' 2>/dev/null)"
                out_tok="$(echo "$line" | jq -r '.output_tokens' 2>/dev/null)"
                models="$(echo "$line" | jq -r '.models | keys | join(", ")' 2>/dev/null)"
                printf "  ${DIM}%s${RESET}  ${GREEN}session${RESET}  profile=${BOLD}%s${RESET}  in=%s  out=%s  ${DIM}[%s]${RESET}\n" \
                    "$ts" "$profile" "$in_tok" "$out_tok" "$models"
                ;;
            *)
                echo -e "  ${DIM}$ts${RESET}  $event  $(echo "$line" | jq -c 'del(.ts,.event)' 2>/dev/null)"
                ;;
        esac
    done
}

cmd_rename() {
    local old="${1:-}" new="${2:-}"
    if [[ -z "$old" || -z "$new" ]]; then
        echo -e "${RED}Usage: cctrl rename <old> <new>${RESET}"
        return 1
    fi

    if _profile_exists "$old"; then
        if _profile_exists "$new"; then
            echo -e "${RED}Profile '$new' already exists.${RESET}"
            return 1
        fi
        mv "$(_profile_path "$old")" "$(_profile_path "$new")"
        # Update active profile tracking if needed
        if [[ "$(_active_profile)" == "$old" ]]; then
            echo "$new" > "$ACTIVE_FILE"
        fi
    else
        echo -e "${YELLOW}Profile '$old' not found on disk; updating log references only.${RESET}"
    fi

    # Update spending log entries that reference the old profile name
    if [[ -f "$SPENDING_LOG" ]]; then
        local tmp
        tmp="$(mktemp)"
        python3 -c "
import json, sys
old, new = $(printf '%s' "$old" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))'), $(printf '%s' "$new" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')
with open('$SPENDING_LOG') as f:
    lines = f.readlines()
out = []
for line in lines:
    line = line.rstrip('\n')
    if not line:
        continue
    try:
        e = json.loads(line)
        if e.get('from') == old: e['from'] = new
        if e.get('to') == old: e['to'] = new
        if e.get('profile') == old: e['profile'] = new
        out.append(json.dumps(e))
    except Exception:
        out.append(line)
with open('$SPENDING_LOG', 'w') as f:
    f.write('\n'.join(out) + '\n')
"
        echo -e "${DIM}Updated spending log: '$old' -> '$new'${RESET}"
    fi

    echo -e "${GREEN}Renamed: ${BOLD}$old${RESET}${GREEN} -> ${BOLD}$new${RESET}"
}

cmd_start() {
    # Unified launch verb. Foreground in the current dir by default; -d/--detach
    # runs the session in a persistent tmux session that survives SSH disconnect.
    #   cctrl start                 foreground, current dir
    #   cctrl start @name           foreground via shortcut
    #   cctrl start -d <dir|@name>  detached tmux session
    local detach=false arg
    for arg in "$@"; do
        [[ "$arg" == "--" ]] && break   # rest is a literal prompt; stop scanning
        case "$arg" in
            -d|--detach) detach=true; break ;;
        esac
    done

    if $detach; then
        _launch_detached "$@"
        return
    fi

    # `cctrl start @<name> [...]` is an alias for `cctrl @<name> [...]`
    if [[ "${1:-}" == @* ]]; then
        local sc="${1#@}"; shift
        _shortcut_jump "$sc" "$@"
        return
    fi

    local resume=false
    local resume_val=""
    local no_bridge=false
    local profile=""
    local cli_model=""
    local cli_prompt=""
    local cli_prompt_set=false
    local agent="$(_default_agent)"
    local launch_name=""
    local full_bypass=false
    local access_explicit=false
    local permission_mode=""
    local passthrough=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)
                [[ $# -ge 2 ]] || { echo -e "${RED}--agent needs a value${RESET}"; return 1; }
                agent="$2"; shift 2
                ;;
            --profile)
                [[ $# -ge 2 ]] || { echo -e "${RED}--profile needs a value${RESET}"; return 1; }
                profile="$2"; shift 2
                ;;
            --model)
                [[ $# -ge 2 ]] || { echo -e "${RED}--model needs a value${RESET}"; return 1; }
                cli_model="$2"; shift 2
                ;;
            --resume|-r)
                resume=true
                # Check if next arg is a value (not another flag)
                if [[ $# -gt 1 && "$2" != -* ]]; then
                    resume_val="$2"
                    shift
                fi
                shift
                ;;
            --no-bridge)
                no_bridge=true
                shift
                ;;
            --message|--prompt|-m)
                [[ $# -ge 2 ]] || { echo -e "${RED}$1 needs a value${RESET}"; return 1; }
                cli_prompt="$2"
                cli_prompt_set=true
                shift 2
                ;;
            --yolo|--dangerously-bypass-approvals-and-sandbox)
                full_bypass=true
                access_explicit=true
                shift
                ;;
            --permission-mode)
                [[ $# -ge 2 ]] || { echo -e "${RED}--permission-mode needs a value${RESET}"; return 1; }
                permission_mode="$2"
                access_explicit=true
                shift 2
                ;;
            --sandbox|-s|--ask-for-approval|-a)
                [[ $# -ge 2 ]] || { echo -e "${RED}$1 needs a value${RESET}"; return 1; }
                access_explicit=true
                passthrough+=("$1" "$2")
                shift 2
                ;;
            --name|-n)
                [[ $# -ge 2 ]] || { echo -e "${RED}--name needs a value${RESET}"; return 1; }
                launch_name="$2"; shift 2
                ;;
            --)
                shift
                if [[ $# -gt 0 ]]; then
                    cli_prompt="$*"
                    cli_prompt_set=true
                fi
                break
                ;;
            *)
                passthrough+=("$1")
                shift
                ;;
        esac
    done

    agent="$(_normalize_agent "$agent")" || return 1

    # Resolve profile: explicit --profile wins; else fall back to the last
    # `cctrl use` profile if recorded. Empty = no overlay (agent's own default).
    # Explicit --profile is concurrency-safe: it never touches global state.
    if [[ -z "$profile" ]]; then
        profile="$(_active_profile)"
    fi
    local pf=""
    if [[ -n "$profile" ]]; then
        if _profile_exists "$profile"; then
            pf="$(_profile_path "$profile")"
        else
            echo -e "${YELLOW}Profile '$profile' not found; launching without it.${RESET}"
        fi
    fi
    _apply_profile_overlay "$agent" "$pf"

    local final_prompt=""
    $cli_prompt_set && final_prompt="$cli_prompt"

    LAUNCH_FULL_BYPASS=$full_bypass
    LAUNCH_ACCESS_EXPLICIT=$access_explicit
    LAUNCH_PERMISSION_MODE="$permission_mode"
    LAUNCH_PASSTHROUGH=()
    [[ ${#passthrough[@]} -gt 0 ]] && LAUNCH_PASSTHROUGH=("${passthrough[@]}")
    _launch_exec_agent "$agent" "$pf" "$cli_model" "$launch_name" "$no_bridge" "$resume" "$resume_val" "$final_prompt" "$PWD"
}

_launch_detached() {
    # Launch a cctrl session in a detached tmux session (survives SSH
    # disconnect). Invoked by `cctrl start -d`. No GUI — just tmux.
    #
    # An explicit target is REQUIRED. Defaulting to $HOME would drop a
    # full-access agent into a folder with ~/.ssh, ~/.aws, browser data, etc.
    # Session management lives under `cctrl session`.

    local target="" target_kind=""   # kind: dir | shortcut
    local passthrough=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--detach)
                shift ;;
            --)
                shift
                passthrough+=("--" "$@")
                break
                ;;
            --agent|--profile|--model|--message|--prompt|-m|--permission-mode|--sandbox|-s|--ask-for-approval|-a|--name|-n)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}$1 needs a value${RESET}" >&2
                    return 1
                fi
                passthrough+=("$1" "$2")
                shift 2
                ;;
            --resume|-r)
                passthrough+=("$1")
                if [[ $# -gt 1 && "$2" != -* && "$2" != @* ]]; then
                    passthrough+=("$2")
                    shift
                fi
                shift
                ;;
            @*)
                if [[ -n "$target" ]]; then
                    passthrough+=("$1")
                else
                    target="${1#@}"
                    target_kind="shortcut"
                fi
                shift
                ;;
            -*)
                passthrough+=("$1")
                shift
                ;;
            *)
                if [[ -n "$target" ]]; then
                    passthrough+=("$1")
                else
                    target="$1"
                    target_kind="dir"
                fi
                shift
                ;;
        esac
    done

    if ! command -v tmux &>/dev/null; then
        echo -e "${RED}tmux not found.${RESET} Install with: brew install tmux" >&2
        return 1
    fi

    if [[ -z "$target" ]]; then
        echo -e "${RED}cctrl start -d requires a target.${RESET}" >&2
        echo "Usage: cctrl start -d <dir | @shortcut> [extra args]" >&2
        echo -e "${DIM}A detached session needs an explicit dir or shortcut — defaulting${RESET}" >&2
        echo -e "${DIM}to \$HOME would drop a full-access agent into ~/.ssh, ~/.aws, etc.${RESET}" >&2
        return 1
    fi

    local cctrl_q extras_q="" env_q="" shell_cmd session_name display_label friendly_name
    cctrl_q="$(printf '%q' "$SCRIPT_DIR/cctrl")"
    local env_name env_val
    for env_name in CCTRL_AGENT CCTRL_HOST_PREFIX; do
        env_val="${!env_name:-}"
        [[ -n "$env_val" ]] && env_q+=" $env_name=$(printf '%q' "$env_val")"
    done
    [[ -n "$env_q" ]] && env_q="${env_q# } "
    if [[ ${#passthrough[@]} -gt 0 ]]; then
        for a in "${passthrough[@]}"; do
            extras_q+=" $(printf '%q' "$a")"
        done
    fi

    # Detached agent display names get a "TMUX." prefix.
    if [[ "$target_kind" == "shortcut" ]]; then
        local canonical
        canonical="$(_shortcut_lookup_key "$target")"
        if [[ -z "$canonical" ]]; then
            echo -e "${RED}Shortcut not found: @$target${RESET}" >&2
            echo -e "${DIM}List with: cctrl @${RESET}" >&2
            return 1
        fi
        friendly_name="$canonical"
        local name_q cc_name_q
        name_q="$(printf '%q' "$canonical")"
        cc_name_q="$(printf '%q' "TMUX. $friendly_name")"
        shell_cmd="${env_q}$cctrl_q @$name_q --name $cc_name_q$extras_q"
        session_name="$(_session_slug "$canonical")"
        display_label="@$canonical"
    else
        local dir="$target"
        dir="${dir/#\~/$HOME}"
        if [[ ! -d "$dir" ]]; then
            echo -e "${RED}Directory not found: $dir${RESET}" >&2
            return 1
        fi
        dir="$(cd "$dir" && pwd)"
        friendly_name="$(basename "$dir")"
        local dir_q cc_name_q
        dir_q="$(printf '%q' "$dir")"
        cc_name_q="$(printf '%q' "TMUX. $friendly_name")"
        shell_cmd="cd $dir_q && ${env_q}$cctrl_q start --name $cc_name_q$extras_q"
        session_name="$(_session_slug "$dir")"
        display_label="$dir"
    fi

    # Auto-increment if session name already exists (homelab, homelab--2, ...)
    local base_name="$session_name"
    if tmux has-session -t "$session_name" 2>/dev/null; then
        local n=2
        while tmux has-session -t "${base_name}--${n}" 2>/dev/null; do
            ((n++))
        done
        session_name="${base_name}--${n}"
    fi

    tmux new-session -d -s "$session_name" "$shell_cmd"
    tmux set-option -t "$session_name" -q @cctrl_managed 1 2>/dev/null || true

    echo -e "${GREEN}✓${RESET} detached session started — ${BOLD}$display_label${RESET}"
    echo -e "${DIM}  Attach:  cctrl session attach $session_name${RESET}"
    echo -e "${DIM}  List:    cctrl session ls${RESET}"
    echo -e "${DIM}  Kill:    cctrl session kill $session_name${RESET}"

    # Machine-readable line so a remote launch can attach to the exact session
    # name (including any auto-increment suffix). See _remote_exec.
    if [[ -n "${CCTRL_EMIT_SESSION:-}" ]]; then
        printf 'CCTRL_SESSION=%s\n' "$session_name"
    fi
}

# ── Detached session management ───────────────────────────────────────

cmd_session() {
    # Manage detached tmux sessions created by `cctrl start -d`.
    local action="${1:-ls}"
    shift 2>/dev/null || true
    case "$action" in
        -h|--help|help)
            echo "Usage: cctrl session <ls | attach | kill>"
            echo ""
            echo "  cctrl session ls               List sessions (dir, agent/shell, model, state)"
            echo "    --json                       Machine-readable output"
            echo "  cctrl session attach [name]    Reattach (interactive picker if no name)"
            echo "  cctrl session kill <name>      Kill a session"
            echo ""
            echo "Create a session with:  cctrl start -d <dir | @shortcut>"
            return 0
            ;;
        ls|list)   _session_list "$@" ;;
        attach|a)  _session_attach "${1:-__picker__}" ;;
        kill|k|rm) _session_kill "${1:-}" ;;
        *)
            echo -e "${RED}Unknown session command: $action${RESET}" >&2
            echo -e "${DIM}Run 'cctrl session --help' for usage.${RESET}" >&2
            return 1
            ;;
    esac
}

_session_require_tmux() {
    command -v tmux &>/dev/null && return 0
    echo -e "${RED}tmux not found.${RESET} Install with: brew install tmux" >&2
    return 1
}

_session_agent_cmd() {
    # Echo the foreground command of a session's pane. cctrl detaches with
    # `exec <agent>`, so the pane root usually is the agent; fall back to first child.
    local sess="$1" pid cmd child ccmd
    pid="$(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null | head -1)"
    [[ -n "$pid" ]] || return 0
    cmd="$(ps -o command= -p "$pid" 2>/dev/null)"
    if [[ "$cmd" != *claude* && "$cmd" != *codex* ]]; then
        child="$(pgrep -P "$pid" 2>/dev/null | head -1)"
        if [[ -n "$child" ]]; then
            ccmd="$(ps -o command= -p "$child" 2>/dev/null)"
            [[ "$ccmd" == *claude* || "$ccmd" == *codex* ]] && cmd="$ccmd"
        fi
    fi
    printf '%s' "$cmd"
}

_session_list() {
    _session_require_tmux || return 1
    local json=false a
    for a in "$@"; do
        case "$a" in
            --json) json=true ;;
        esac
    done

    local -a names=()
    while IFS= read -r a; do [[ -n "$a" ]] && names+=("$a"); done \
        < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

    if [[ ${#names[@]} -eq 0 ]]; then
        $json && { echo "[]"; return 0; }
        echo -e "${DIM}No active sessions.${RESET}"
        return 0
    fi

    local -a json_items=()
    $json || echo -e "${DIM}✦ = cctrl-managed agent session${RESET}"
    local name cmd dir attached state kind model managed claude_yes marker disp_dir base agent
    for name in "${names[@]}"; do
        dir="$(tmux list-panes -t "$name" -F '#{pane_current_path}' 2>/dev/null | head -1)"
        attached="$(tmux display-message -p -t "$name" '#{session_attached}' 2>/dev/null)"
        cmd="$(_session_agent_cmd "$name")"
        if [[ "$cmd" == *claude* || "$cmd" == *codex* ]]; then
            [[ "$cmd" == *codex* ]] && agent="codex" || agent="claude"
            [[ "$agent" == "claude" ]] && claude_yes=true || claude_yes=false
            model="$(printf '%s' "$cmd" | grep -oE '\-\-model [^ ]+' | awk '{print $2}')"
            model="${model#claude-}"; model="${model%%\[*}"
            [[ -z "$model" ]] && model="?"
            kind="$agent ($model)"
            if [[ "$(tmux show-option -qv -t "$name" @cctrl_managed 2>/dev/null)" == "1" || "$cmd" == *"--name TMUX."* ]]; then
                managed=true
            else
                managed=false
            fi
        else
            claude_yes=false; managed=false; model=""; agent=""
            base="${cmd%% *}"; base="${base##*/}"; base="${base#-}"
            kind="shell (${base:-sh})"
        fi
        [[ "$attached" == "1" ]] && state="attached" || state="detached"
        disp_dir="${dir/#$HOME/~}"

        if $json; then
            json_items+=("$(jq -n \
                --arg name "$name" --arg kind "$kind" --arg dir "$dir" \
                --arg model "$model" --arg state "$state" --arg agent "$agent" \
                --argjson managed "$managed" --argjson claude "$claude_yes" \
                '{name:$name, managed:$managed, agent:(if $agent=="" then null else $agent end), claude:$claude, model:(if $model=="" then null else $model end), dir:$dir, attached:($state=="attached")}')")
        else
            $managed && marker="✦" || marker=" "
            printf '%s %-15s %-18s %-34s %s\n' "$marker" "$name" "$kind" "$disp_dir" "$state"
        fi
    done

    $json && printf '%s\n' "${json_items[@]}" | jq -s '.'
    return 0
}

_session_attach() {
    _session_require_tmux || return 1
    local attach_target="$1"
    local -a sessions=()
    local s choice i
    while IFS= read -r s; do
        [[ -n "$s" ]] && sessions+=("$s")
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

    if [[ ${#sessions[@]} -eq 0 ]]; then
        echo -e "${DIM}No active sessions.${RESET}"
        return 1
    fi

    # Picker mode (no argument)
    if [[ "$attach_target" == "__picker__" ]]; then
        if [[ ${#sessions[@]} -eq 1 ]]; then
            exec tmux attach-session -t "${sessions[0]}"
        fi
        echo -e "${BOLD}Active sessions:${RESET}"
        i=1
        for s in "${sessions[@]}"; do
            echo -e "  ${GREEN}[$i]${RESET} $s"
            ((i++))
        done
        echo
        echo -n "Attach to: "
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#sessions[@]} )); then
            exec tmux attach-session -t "${sessions[$((choice-1))]}"
        fi
        return 1
    fi

    # Exact match
    if tmux has-session -t "$attach_target" 2>/dev/null; then
        exec tmux attach-session -t "$attach_target"
    fi

    # Partial match
    local -a matches=()
    for s in "${sessions[@]}"; do
        [[ "$s" == *"$attach_target"* ]] && matches+=("$s")
    done

    if [[ ${#matches[@]} -eq 0 ]]; then
        echo -e "${RED}No session matching '$attach_target'.${RESET}" >&2
        echo -e "${BOLD}Active sessions:${RESET}"
        for s in "${sessions[@]}"; do echo "  $s"; done
        return 1
    elif [[ ${#matches[@]} -eq 1 ]]; then
        exec tmux attach-session -t "${matches[0]}"
    else
        echo -e "${BOLD}Multiple sessions matching '$attach_target':${RESET}"
        i=1
        for s in "${matches[@]}"; do
            echo -e "  ${GREEN}[$i]${RESET} $s"
            ((i++))
        done
        echo
        echo -n "Attach to: "
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#matches[@]} )); then
            exec tmux attach-session -t "${matches[$((choice-1))]}"
        fi
        return 1
    fi
}

_session_kill() {
    _session_require_tmux || return 1
    local kill_target="$1"
    if [[ -z "$kill_target" ]]; then
        echo -e "${RED}cctrl session kill needs a session name.${RESET}" >&2
        echo -e "${DIM}List sessions with: cctrl session ls${RESET}" >&2
        return 1
    fi
    if tmux has-session -t "$kill_target" 2>/dev/null; then
        tmux kill-session -t "$kill_target"
        echo -e "${GREEN}Killed session: $kill_target${RESET}"
    else
        echo -e "${RED}No session named '$kill_target'.${RESET}" >&2
        return 1
    fi
}

