#compdef cctrl

# Resolve cctrl's install dir from the command path (works through symlinks)
_cctrl_dir() {
    local bin="${commands[cctrl]:-$(whence -p cctrl 2>/dev/null)}"
    [[ -n "$bin" ]] || return 1
    local real="$(readlink -f "$bin" 2>/dev/null || realpath "$bin" 2>/dev/null)"
    echo "${real:h}"
}

_cctrl_profiles() {
    local dir="$(_cctrl_dir)/profiles"
    [[ -d "$dir" ]] || return
    local -a profiles
    for f in "$dir"/*.json(N); do
        profiles+=("${f:t:r}")
    done
    (( ${#profiles} )) && compadd -X "profiles" "$@" -- "${profiles[@]}"
}

_cctrl_shortcuts() {
    local file="$(_cctrl_dir)/data/shortcuts.json"
    [[ -f "$file" ]] || return
    local -a names descs
    local key val
    while IFS=$'\t' read -r key val; do
        names+=("@${key}")
        descs+=("@${key}:${val}")
    done < <(jq -r 'to_entries[] | "\(.key)\t\(.value.dir // "")"' "$file" 2>/dev/null)
    (( ${#names} )) && _describe "shortcuts" descs
}

_cctrl_shortcut_names() {
    local file="$(_cctrl_dir)/data/shortcuts.json"
    [[ -f "$file" ]] || return
    local -a names
    names=("${(@f)$(jq -r 'keys[]' "$file" 2>/dev/null)}")
    (( ${#names} )) && compadd "$@" -- "${names[@]}"
}

_cctrl_plugins() {
    local dir="$(_cctrl_dir)/plugins"
    [[ -d "$dir" ]] || return
    local -a plugs
    for f in "$dir"/cctrl-*(N); do
        [[ -x "$f" ]] && plugs+=("${${f:t}#cctrl-}")
    done
    (( ${#plugs} )) && compadd -X "plugins" "$@" -- "${plugs[@]}"
}

_cctrl_hosts() {
    # Built-in aliases for the local machine, plus any registered hosts.
    compadd "$@" -- local self
    local file="$(_cctrl_dir)/data/hosts.json"
    [[ -f "$file" ]] || return
    local -a names
    names=("${(@f)$(jq -r 'keys[]' "$file" 2>/dev/null)}")
    (( ${#names} )) && compadd "$@" -- "${names[@]}"
}

_cctrl_peers() {
    local file="$(_cctrl_dir)/data/peers.json"
    [[ -f "$file" ]] || return
    local -a names
    names=("${(@f)$(jq -r 'to_entries[] | .key, ((.value.aliases // [])[])' "$file" 2>/dev/null)}")
    (( ${#names} )) && compadd "$@" -- "${names[@]}"
}

_cctrl_message_ids() {
    local file="$(_cctrl_dir)/data/messages.jsonl"
    [[ -f "$file" ]] || return
    local -a ids
    ids=("${(@f)$(jq -r '.id // empty' "$file" 2>/dev/null)}")
    (( ${#ids} )) && compadd "$@" -- "${ids[@]}"
}

_cctrl_agents() {
    compadd "$@" -- claude codex
}

_cctrl_tmux_sessions() {
    local -a sessions
    sessions=("${(@f)$(tmux list-sessions -F '#{session_name}' 2>/dev/null)}")
    (( ${#sessions} )) && compadd "$@" -- "${sessions[@]}"
}

_cctrl() {
    local -a subcmds=(
        'use:Switch to a settings profile'
        'switch:Switch to a settings profile'
        'ls:List available profiles'
        'list:List available profiles'
        'current:Show active profile'
        'save:Save current settings as a profile'
        'diff:Diff current settings vs a profile'
        'rename:Rename a profile'
        'edit:Open a profile in \$EDITOR'
        'start:Launch selected agent (foreground, or -d for a detached session)'
        's:Launch selected agent (foreground, or -d for a detached session)'
        'session:Manage detached sessions (ls/attach/close/kill)'
        'close:Gracefully close a tmux session (default: the one you are inside)'
        'peer:Manage addressable agent peers'
        'host:Manage remote hosts'
        'whoami:Show this machine and which host aliases mean local'
        'costs:Token usage and cost breakdown'
        'usage:Plan usage and billing week breakdown'
        'statusline:Configure Claude/Codex status lines'
        'log:Show profile switch history'
        'chrome:Launch Chrome with CDP remote debugging'
        'shortcuts:Manage shortcuts'
        'help:Show help'
    )

    if (( CURRENT == 2 )); then
        _describe "commands" subcmds
        _cctrl_shortcuts
        _cctrl_plugins
        _arguments \
            '--host[Run on a remote host]:host:_cctrl_hosts' \
            '--agent[Select agent runtime]:agent:_cctrl_agents'
        return
    fi

    # Handle --agent <name> <subcommand...>
    if [[ "${words[2]}" == "--agent" ]]; then
        if (( CURRENT == 3 )); then
            _cctrl_agents
        elif (( CURRENT == 4 )); then
            _describe "commands" subcmds
        fi
        return
    fi

    # Handle --host <alias> <subcommand...>
    if [[ "${words[2]}" == "--host" ]]; then
        if (( CURRENT == 3 )); then
            _cctrl_hosts
        elif (( CURRENT == 4 )); then
            _describe "commands" subcmds
        fi
        return
    fi

    local cmd="${words[2]}"

    case "$cmd" in
        @*)
            local name="${cmd#@}"
            if [[ -z "$name" ]]; then
                if (( CURRENT == 3 )); then
                    _cctrl_shortcut_names
                    local -a shortcut_cmds=(
                        'add:Add a new shortcut'
                        'rm:Remove a shortcut'
                        'ls:List shortcuts'
                        'edit:Open shortcuts file in \$EDITOR'
                    )
                    _describe "shortcut commands" shortcut_cmds
                    return
                fi
                local subcmd="${words[3]}"
                case "$subcmd" in
                    add)
                        case $CURRENT in
                            4) ;; # name — freeform
                            5) _directories ;;
                            *)
                                _arguments \
                                    '--profile[Profile to switch to]:profile:_cctrl_profiles' \
                                    '--agent[Agent runtime]:agent:_cctrl_agents' \
                                    '--resume[Resume a session]' \
                                    '--message[Initial prompt]:message:'
                                ;;
                        esac
                        return
                        ;;
                    rm|remove|delete)
                        (( CURRENT == 4 )) && _cctrl_shortcut_names
                        return
                        ;;
                esac
            fi
            _arguments \
                '--resume[Resume a session]' \
                '--agent[Agent runtime]:agent:_cctrl_agents' \
                '--purpose[Session purpose metadata]:purpose:' \
                '--foreground[Launch directly without tmux]' \
                '--no-tmux[Launch directly without tmux]' \
                '--no-bridge[Disable the phone-control bridge]' \
                '--yolo[Full bypass mode]' \
                '--permission-mode[Claude permission mode]:mode:' \
                '--remote[Codex app-server endpoint]:addr:(unix://)' \
                '--remote-auth-token-env[Env var containing remote auth token]:envvar:' \
                {-m,--message,--prompt}'[Initial prompt]:message:' \
                '--[Everything after is the prompt]'
            ;;
        use|switch|diff|edit)
            (( CURRENT == 3 )) && _cctrl_profiles
            ;;
        rename)
            (( CURRENT == 3 || CURRENT == 4 )) && _cctrl_profiles
            ;;
        save)
            ;; # name is freeform
        start|s)
            _arguments \
                {--detach,-d}'[Start a tmux session and return without attaching]' \
                '--foreground[Launch directly without tmux]' \
                '--no-tmux[Launch directly without tmux]' \
                {--resume,-r}'[Resume a session]' \
                '--agent[Agent runtime]:agent:_cctrl_agents' \
                {--name,-n}'[Session display name]:name:' \
                '--purpose[Session purpose metadata]:purpose:' \
                '--yolo[Full bypass mode]' \
                '--permission-mode[Claude permission mode]:mode:' \
                {-m,--message,--prompt}'[Initial prompt]:message:' \
                {--sandbox,-s}'[Codex sandbox mode]:mode:(read-only workspace-write danger-full-access)' \
                {--ask-for-approval,-a}'[Codex approval policy]:policy:(untrusted on-request never)' \
                '--remote[Codex app-server endpoint]:addr:(unix://)' \
                '--remote-auth-token-env[Env var containing remote auth token]:envvar:' \
                '--no-bridge[Disable the phone-control bridge]'
            # Allow @shortcut or a directory as the target
            if (( CURRENT == 3 )); then
                _cctrl_shortcuts
                _directories
            fi
            ;;
        session|sess)
            if (( CURRENT == 3 )); then
                local -a session_cmds=(
                    'ls:List sessions (dir, agent/shell, model, state)'
                    'attach:Reattach to a session'
                    'close:Gracefully close a session (default: the one you are inside)'
                    'kill:Kill a detached session'
                )
                _describe "session commands" session_cmds
            elif (( CURRENT >= 4 )) && [[ "${words[3]}" == ls ]]; then
                _arguments \
                    '--json[Machine-readable output]'
            elif (( CURRENT >= 4 )) && [[ "${words[3]}" == (close|stop) ]]; then
                _arguments \
                    '--in[Grace period in seconds]:seconds:' \
                    '--now[Kill immediately, no grace period]' \
                    '--force[Allow closing non-cctrl sessions]' \
                    '*:session:_cctrl_tmux_sessions'
            elif (( CURRENT == 4 )) && [[ "${words[3]}" == (attach|a|kill|k|rm) ]]; then
                local -a sessions
                sessions=("${(@f)$(tmux list-sessions -F '#{session_name}' 2>/dev/null)}")
                (( ${#sessions} )) && compadd "$@" -- "${sessions[@]}"
            fi
            ;;
        close)
            _arguments \
                '--in[Grace period in seconds]:seconds:' \
                '--now[Kill immediately, no grace period]' \
                '--force[Allow closing non-cctrl sessions]' \
                '*:session:_cctrl_tmux_sessions'
            ;;
        peer)
            if (( CURRENT == 3 )); then
                local -a peer_cmds=(
                    'ls:List peers'
                    'list:List peers'
                    'resolve:Resolve a peer'
                    'register:Register a manual peer'
                    'add:Register a manual peer'
                    'alias:Add an alias to a manual peer'
                    'unregister:Remove a manual peer'
                    'rm:Remove a manual peer'
                    'whoami:Resolve peer identity'
                    'send:Queue a mailbox message'
                    'inbox:List inbound mailbox messages'
                    'outbox:List outbound mailbox messages'
                    'check:Check unread mailbox counts'
                    'recv:Receive the next mailbox message'
                    'show:Show a mailbox message'
                    'ack:Acknowledge a delivered message'
                    'help:Show peer help'
                )
                _describe "peer commands" peer_cmds
            elif (( CURRENT >= 4 )); then
                local peercmd="${words[3]}"
                case "$peercmd" in
                    ls|list)
                        _arguments '--json[Machine-readable output]'
                        ;;
                    resolve)
                        if (( CURRENT == 4 )); then
                            _cctrl_peers
                        else
                            _arguments '--json[Machine-readable output]'
                        fi
                        ;;
                    register|add)
                        if (( CURRENT == 4 )); then
                            return
                        fi
                        _arguments \
                            '--alias[Peer alias]:alias:' \
                            '--host[Host label]:host:_cctrl_hosts' \
                            '--dir[Working directory]:directory:_directories' \
                            '--agent[Agent metadata]:agent:' \
                            '--session[Tmux session name]:session:_cctrl_tmux_sessions' \
                            '--purpose[Peer purpose]:purpose:' \
                            '--capability[Capability label]:capability:'
                        ;;
                    alias)
                        (( CURRENT == 4 )) && _cctrl_peers
                        ;;
                    unregister|rm|remove|delete)
                        (( CURRENT == 4 )) && _cctrl_peers
                        ;;
                    whoami|identity)
                        _arguments \
                            '--as[Peer identity]:peer:_cctrl_peers' \
                            '--json[Machine-readable output]'
                        ;;
                    send)
                        if (( CURRENT == 4 )); then
                            _cctrl_peers
                        else
                            _arguments \
                                '--from[Sender peer]:peer:_cctrl_peers' \
                                '--as[Sender identity]:peer:_cctrl_peers' \
                                '--subject[Message subject]:subject:' \
                                '--body-file[Read message body from file or stdin]:path:_files' \
                                '--allow-unknown[Allow unknown sender or recipient]' \
                                '--json[Machine-readable output]' \
                                '--[Everything after is the message body]'
                        fi
                        ;;
                    inbox)
                        _arguments \
                            '--as[Peer identity]:peer:_cctrl_peers' \
                            '--status[Status filter]:status:(queued delivered acked)' \
                            '--json[Machine-readable output]'
                        ;;
                    outbox)
                        _arguments \
                            '--as[Peer identity]:peer:_cctrl_peers' \
                            '--status[Status filter]:status:(queued delivered acked)' \
                            '--json[Machine-readable output]'
                        ;;
                    check)
                        _arguments \
                            '--as[Peer identity]:peer:_cctrl_peers' \
                            '--json[Machine-readable output]' \
                            '--exit-on-empty[Exit 2 when no queued or delivered messages are available]'
                        ;;
                    recv)
                        _arguments \
                            '--as[Peer identity]:peer:_cctrl_peers' \
                            '--status[Status filter]:status:(queued delivered)' \
                            '--json[Machine-readable output]' \
                            '--exit-on-empty[Exit 2 when no message is available]'
                        ;;
                    show)
                        if (( CURRENT == 4 )); then
                            _cctrl_message_ids
                        else
                            _arguments '--json[Machine-readable output]'
                        fi
                        ;;
                    ack)
                        if (( CURRENT == 4 )); then
                            _cctrl_message_ids
                        else
                            _arguments \
                                '--as[Peer identity]:peer:_cctrl_peers' \
                                '--json[Machine-readable output]'
                        fi
                        ;;
                esac
            fi
            ;;
        shortcuts)
            if (( CURRENT == 3 )); then
                local -a shortcut_cmds=(
                    'add:Add a new shortcut'
                    'rm:Remove a shortcut'
                    'ls:List shortcuts'
                    'edit:Open shortcuts file in \$EDITOR'
                )
                _describe "shortcut commands" shortcut_cmds
                _cctrl_shortcut_names
            fi
            ;;
        costs|cost)
            if (( CURRENT == 3 )); then
                local -a ranges=(
                    '--today:Last 24 hours'
                    '--week:Last 7 days'
                    '--month:Last 30 days'
                    '--all:All time'
                )
                _describe "ranges" ranges
            fi
            ;;
        usage)
            (( CURRENT == 3 )) && compadd -- 1 2 3 4 5 6 7 8
            ;;
        statusline|status-line)
            if (( CURRENT == 3 )); then
                _cctrl_agents
            elif (( CURRENT == 4 )); then
                compadd -- install show help
            fi
            ;;
        host)
            if (( CURRENT == 3 )); then
                local -a host_cmds=(
                    'add:Register a remote host'
                    'list:List registered hosts'
                    'ls:List registered hosts'
                    'rm:Remove a host'
                    'doctor:Check remote host health'
                    'help:Show host help'
                )
                _describe "host commands" host_cmds
            elif (( CURRENT == 4 )); then
                local hostcmd="${words[3]}"
                case "$hostcmd" in
                    rm|remove|delete|doctor)
                        _cctrl_hosts
                        ;;
                esac
            fi
            ;;
        chrome|cdp)
            _arguments \
                {--port,-p}'[CDP port]:port:' \
                {--status,-s}'[Check if CDP is active]' \
                {--connect,-c}'[Connect gstack browse]' \
                {--kill,-k}'[Kill Chrome without relaunching]'
            ;;
        log)
            (( CURRENT == 3 )) && compadd -- 10 20 50 100
            ;;
    esac
}

_cctrl "$@"
