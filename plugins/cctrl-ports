def _parse_port_spec(spec: str) -> list[int]:
    """
    Parse a port specification into a sorted list of port numbers.
    Accepts:  3000          single port
              3000-3003     inclusive range
              3000,3001     comma-separated list
              3000-3003,3010  mixed
    """
    ports = set()
    for part in spec.split(','):
        part = part.strip()
        if '-' in part:
            lo, _, hi = part.partition('-')
            try:
                lo_i, hi_i = int(lo.strip()), int(hi.strip())
            except ValueError:
                raise ValueError(f"Invalid port range: '{part}'")
            if lo_i > hi_i:
                lo_i, hi_i = hi_i, lo_i
            ports.update(range(lo_i, hi_i + 1))
        else:
            try:
                ports.add(int(part))
            except ValueError:
                raise ValueError(f"Invalid port: '{part}'")
    return sorted(ports)


def _pids_on_ports(ports: list[int]) -> dict[int, list[dict]]:
    """
    Return {port: [{pid, process}]} for each port that has a listener.
    Uses lsof; ports with no listener are omitted.
    """
    if not ports:
        return {}
    port_args = [str(p) for p in ports]
    try:
        result = subprocess.run(
            ['lsof', '-iTCP', '-iUDP', '-P', '-n', '-sTCP:LISTEN']
            + [f'-i:{p}' for p in ports],
            capture_output=True, text=True, timeout=10,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return {}

    listeners: dict[int, list[dict]] = {}
    for line in result.stdout.strip().splitlines()[1:]:
        parts = line.split()
        if len(parts) < 9:
            continue
        process, pid_str, name_field = parts[0], parts[1], parts[8]
        if ':' not in name_field:
            continue
        port_str = name_field.rsplit(':', 1)[-1]
        try:
            port = int(port_str)
            pid = int(pid_str)
        except ValueError:
            continue
        if port not in ports:
            continue
        entry = {'pid': pid, 'process': process}
        if port not in listeners:
            listeners[port] = []
        if not any(e['pid'] == pid for e in listeners[port]):
            listeners[port].append(entry)
    return listeners


def cmd_kill(args) -> None:
    """Kill processes listening on specified port(s)."""
    try:
        ports = _parse_port_spec(args.kill)
    except ValueError as e:
        print(f"{RED}Error: {e}{RESET}", file=sys.stderr)
        sys.exit(1)

    listeners = _pids_on_ports(ports)

    # Report ports with nothing listening
    silent = set(ports) - set(listeners)
    for p in sorted(silent):
        print(f"{DIM}  {p}  nothing listening{RESET}")

    if not listeners:
        print(f"{DIM}No listening processes found on the specified port(s).{RESET}")
        return

    # Build kill list, deduplicating PIDs (one process may own multiple ports)
    # pid -> {process, ports}
    pid_map: dict[int, dict] = {}
    for port in sorted(listeners):
        for entry in listeners[port]:
            pid = entry['pid']
            if pid not in pid_map:
                pid_map[pid] = {'process': entry['process'], 'ports': []}
            pid_map[pid]['ports'].append(port)

    sig_name = 'SIGKILL' if args.force else 'SIGTERM'
    sig = signal.SIGKILL if args.force else signal.SIGTERM

    # Show what will be killed
    print()
    COL_PORT = 20
    COL_PROC = 18
    print(f"{CYAN}{'Port(s)':<{COL_PORT}} {'Process':<{COL_PROC}} {'PID':>6}  Signal{RESET}")
    print(DIM + '─' * 54 + RESET)
    for pid, info in sorted(pid_map.items(), key=lambda x: x[1]['ports'][0]):
        ports_str = ', '.join(str(p) for p in info['ports'])
        print(f"{YELLOW}{ports_str:<{COL_PORT}}{RESET} {info['process']:<{COL_PROC}} {pid:>6}  {DIM}{sig_name}{RESET}")
    print()

    if args.yes:
        answer = 'y'
    else:
        noun = f"{len(pid_map)} process{'es' if len(pid_map) != 1 else ''}"
        answer = input(f"Kill {noun}? [y/N] ").strip().lower()

    if answer != 'y':
        print(f"{DIM}Aborted.{RESET}")
        return

    print()
    for pid, info in sorted(pid_map.items()):
        ports_str = ', '.join(str(p) for p in info['ports'])
        try:
            os.kill(pid, sig)
            print(f"{GREEN}✓{RESET}  {info['process']}  {DIM}pid {pid}  port{'s' if len(info['ports']) > 1 else ''} {ports_str}{RESET}")
        except ProcessLookupError:
            print(f"{DIM}✓  {info['process']}  pid {pid}  already gone{RESET}")
        except PermissionError:
            print(f"{RED}✗  {info['process']}  pid {pid}  permission denied — try sudo{RESET}")

    # If SIGTERM, wait briefly and report survivors
    if sig == signal.SIGTERM:
        time.sleep(0.5)
        survivors = []
        for pid in pid_map:
            try:
                os.kill(pid, 0)   # signal 0 = existence check
                survivors.append(pid)
            except ProcessLookupError:
                pass
            except PermissionError:
                survivors.append(pid)  # still alive, just unreadable

        if survivors:
            procs = ', '.join(
                f"{pid_map[p]['process']} ({p})" for p in survivors
            )
            print(f"\n{YELLOW}Still running: {procs}{RESET}")
            print(f"{DIM}Tip: use --force for SIGKILL{RESET}")


def cmd_check(args) -> None:
    """Check whether specific ports are safe to use."""
    try:
        ports = _parse_port_spec(args.check)
    except ValueError as e:
        print(f"{RED}Error: {e}{RESET}", file=sys.stderr)
        sys.exit(1)

    db = _load_db()
    seen_history = set(db.get('seen', []))
    listeners = _pids_on_ports(ports)

    COL_PORT = 7
    COL_STATUS = 10
    COL_REASON = 42
    print()
    print(f"{CYAN}{'Port':<{COL_PORT}} {'Status':<{COL_STATUS}} Reason{RESET}")
    print(DIM + '─' * (COL_PORT + COL_STATUS + COL_REASON) + RESET)

    all_clear = True
    for port in ports:
        issues = []

        if port < PORT_MIN:
            issues.append(f"root-only (0–1023)")
        if port in WELL_KNOWN_PORTS:
            issues.append(f"well-known: {WELL_KNOWN_PORTS[port]}")
        if port in seen_history:
            issues.append("seen in history")
        if port in listeners:
            procs = ', '.join(f"{e['process']} ({e['pid']})" for e in listeners[port])
            issues.append(f"in use: {procs}")

        if issues:
            all_clear = False
            status = f"{RED}avoid{RESET}"
            reason = f"{DIM}" + '  ·  '.join(issues) + f"{RESET}"
        else:
            status = f"{GREEN}clear{RESET}"
            reason = f"{DIM}not in use, history, or well-known list{RESET}"

        print(f"{BOLD}{port:<{COL_PORT}}{RESET} {status:<{COL_STATUS + 9}} {reason}")

    print(DIM + '─' * (COL_PORT + COL_STATUS + COL_REASON) + RESET)
    if all_clear:
        print(f"{GREEN}All ports clear.{RESET}")
    else:
        print(f"{DIM}Flags: root-only · well-known · seen in history · in use{RESET}")
    print()


def cmd_reset(args) -> None:
    """Clear port history after confirmation."""
    if not os.path.exists(PORTS_FILE):
        print(f"{DIM}No port history to clear.{RESET}")
        return

    db = _load_db()
    count = len(db.get('seen', []))
    scans = len(db.get('scans', []))

    answer = input(
        f"Clear {count} seen ports across {scans} scans? [y/N] "
    ).strip().lower()
    if answer != 'y':
        print(f"{DIM}Aborted.{RESET}")
        return

    os.remove(PORTS_FILE)
    print(f"{GREEN}Port history cleared.{RESET}")


# ── Argument parsing & dispatch ───────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        prog='cctrl ports',
        description='Track ports in use over time and suggest free port ranges.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  cctrl ports                          scan active ports, update history, show 10 free ports
  cctrl ports --consecutive 4          find 4 consecutive free ports (5 options shown)
  cctrl ports --consecutive 6 --options 3 --min 4000 --max 9000
  cctrl ports --free --ranges          suggest free ports as contiguous ranges (no live scan)
  cctrl ports --free --count 20 --min 8000 --max 8999
  cctrl ports --check 3000             check if port 3000 is safe to use
  cctrl ports --check 3000-3003        check a range
  cctrl ports --check 3000,5432,8080   check specific ports
  cctrl ports --kill 3000              kill process on port 3000 (SIGTERM, confirms first)
  cctrl ports --kill 3000-3003         kill processes on ports 3000 through 3003
  cctrl ports --kill 3000,3001,4321 -y kill specific ports, skip confirmation
  cctrl ports --kill 3000 --force      SIGKILL instead of SIGTERM
  cctrl ports --discover ~/_projects  scan project files for port refs, add to history
  cctrl ports --discover . -y         same, skip confirmation
  cctrl ports --history               show all ports ever seen, compact range notation
  cctrl ports --known                 list well-known ports always excluded from suggestions

port sources:
  live scan     lsof (listening TCP/UDP)
  --discover    .env files, Dockerfiles, docker-compose, YAML/TOML configs, source files
  well-known    22 common service ports (always excluded regardless of history)
  system        0–1023 reserved (require root) — always excluded
  userspace     1024–65535 (default suggestion range: --min 3000 --max 65535)

history is stored in data/ports-seen.json and grows across invocations.
""",
        add_help=True,
    )

    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument(
        '--check', metavar='PORTS',
        help='Check if port(s) are safe to use: 3000  3000-3003  3000,3001',
    )
    mode_group.add_argument(
        '--kill', metavar='PORTS',
        help='Kill process(es) on port(s): 3000  3000-3003  3000,3001,3005',
    )
    mode_group.add_argument(
        '--discover', nargs='?', const='', metavar='DIR',
        help='Scan a directory recursively for port references (default: cwd)',
    )
    mode_group.add_argument(
        '--free', action='store_true',
        help='Suggest free ports from history (no live scan)',
    )
    mode_group.add_argument(
        '--history', action='store_true',
        help='Show all ports ever seen',
    )
    mode_group.add_argument(
        '--known', action='store_true',
        help='List well-known ports that are always excluded from suggestions',
    )
    mode_group.add_argument(
        '--reset', action='store_true',
        help='Clear port history',
    )

    parser.add_argument(
        '--yes', '-y', action='store_true',
        help='Skip confirmation prompts',
    )
    parser.add_argument(
        '--force', action='store_true',
        help='Use SIGKILL instead of SIGTERM (use with --kill)',
    )
    parser.add_argument(
        '--consecutive', type=int, default=0, metavar='N',
        help='Find runs of N consecutive free ports instead of individual ports',
    )
    parser.add_argument(
        '--options', type=int, default=5, metavar='K',
        help='Number of consecutive-run options to show (default: 5)',
    )
    parser.add_argument(
        '--count', type=int, default=10, metavar='N',
        help='Number of free ports to suggest (default: 10)',
    )
    parser.add_argument(
        '--min', type=int, default=3000, metavar='PORT',
        help='Minimum port for suggestions (default: 3000, userspace starts at 1024)',
    )
    parser.add_argument(
        '--max', type=int, default=65535, metavar='PORT',
        help='Maximum port for suggestions (default: 65535)',
    )
    parser.add_argument(
        '--ranges', action='store_true',
        help='Show free ports grouped as contiguous ranges',
    )

    args = parser.parse_args()

    if args.check:
        cmd_check(args)
    elif args.kill:
        cmd_kill(args)
    elif args.discover is not None:
        cmd_discover(args)
    elif args.free or args.consecutive:
        cmd_free(args)
    elif args.history:
        cmd_history(args)
    elif args.known:
        cmd_known()
    elif args.reset:
        cmd_reset(args)
    else:
        cmd_scan(args)


if __name__ == '__main__':
    main()
